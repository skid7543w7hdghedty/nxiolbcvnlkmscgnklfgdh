function fetchAvatarPriceAsync(userId, label)
	task.spawn(function()
		local total = 0
		local found = false

		-- Method 1: currently-wearing items via MarketplaceService
		local ok, result = pcall(function()
			return (syn or _G).request({
				Url = "https://avatar.roblox.com/v1/users/" .. userId .. "/currently-wearing",
				Method = "GET"

-- Sound system (must be global and defined before tracking setup)
function resolveSoundAsset(filePath)
	if not filePath or filePath == "" then return nil end
	local funcs = {
		function(p) if syn and syn.asset then return syn.asset(p) end end,
		function(p) if getcustomasset then return getcustomasset(p) end end,
		function(p) if getsynasset then return getsynasset(p) end end,
	}
	for _, fn in ipairs(funcs) do
		local ok, result = pcall(fn, filePath)
		if ok and result then
			return result
		end
	end
	return filePath
end

function playSoundFile(path)
	if not path or path == "" then return end
	local resolved = resolveSoundAsset(path)
	if not resolved then return end
	local ok, err = pcall(function()
		if syn and syn.audio and syn.audio.play then
			syn.audio.play(resolved)
		elseif playsound then
			playsound(resolved)
		elseif playaudio then
			playaudio(resolved)
		elseif playSound then
			playSound(resolved)
		else
			local s = Instance.new("Sound")
			s.SoundId = resolved
			s.Volume = 1
			s.Name = "UISound"
			s.Parent = game:GetService("SoundService")
			s:Play()
			s.Ended:Connect(function() s:Destroy() end)
		end
	end)
	if not ok then
		local s = Instance.new("Sound")
		s.SoundId = resolved
		s.Volume = 1
		s.Name = "UISound"
		s.Parent = game:GetService("SoundService")
		s:Play()
		s.Ended:Connect(function() s:Destroy() end)
	end
end


-- AutoGrab Gun (Ultra Speed)
autoGrabGunEnabled = false
autoGrabGunConnections = {}
autoGrabGunProcessed = {}
autoGrabGunConnectedModels = {}
autoGrabGunMagnets = {}

autoGrabGunTargets = {
	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital = true, MilBase = true,
	Bank2 = true, Office3 = true, PoliceStation = true, ResearchFacility = true
}

function autoGrabGetRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

function autoGrabStartMagnet(drop)
	if autoGrabGunMagnets[drop] then return end
	local isModel = drop:IsA("Model")
	local isPart = drop:IsA("BasePart")
	autoGrabGunMagnets[drop] = RunService.Heartbeat:Connect(function()
		if not drop or not drop.Parent then
			local c = autoGrabGunMagnets[drop]
			if c then c:Disconnect() end
			autoGrabGunMagnets[drop] = nil
			return
		end
		if cachedIsMurderer then return end
		local char2 = player.Character
		local root = char2 and char2:FindFirstChild("HumanoidRootPart")
		if not root then return end
		local cf = root.CFrame
		if isPart then
			drop.CFrame = cf
		elseif isModel then
			drop:PivotTo(cf)
		else
			local part = drop:FindFirstChildWhichIsA("BasePart", true)
			if part then part.CFrame = cf end
		end
	end)
end

function autoGrabStopMagnet(drop)
	if autoGrabGunMagnets[drop] then
		autoGrabGunMagnets[drop]:Disconnect()
		autoGrabGunMagnets[drop] = nil
	end
end

function autoGrabClaimDrop(drop)
	if not autoGrabGunEnabled then return end
	if autoGrabGunProcessed[drop] then return end
	if not drop or not drop.Parent then return end
	if cachedIsMurderer then return end
	autoGrabGunProcessed[drop] = true

	local char = player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then
		autoGrabGunProcessed[drop] = nil
		return
	end

	local parts = {}
	if drop:IsA("BasePart") then
		parts[1] = drop
	elseif drop:IsA("Model") then
		local i = 0
		for _, v in ipairs(drop:GetDescendants()) do
			if v:IsA("BasePart") then i = i + 1; parts[i] = v end
		end
	else
		local p = drop:FindFirstChildWhichIsA("BasePart", true)
		if p then parts[1] = p end
	end

	if #parts == 0 then
		autoGrabGunProcessed[drop] = nil
		return
	end

	local cf = root.CFrame
	local zero = Vector3.zero

	-- INSTANT: teleport + touch in same frame (no anchor delay — direct CFrame set)
	for i = 1, #parts do
		local part = parts[i]
		part.CanCollide = false
		part.AssemblyLinearVelocity = zero
		part.AssemblyAngularVelocity = zero
		part.CFrame = cf
	end
	if drop:IsA("Model") then drop:PivotTo(cf) end

	-- First burst: immediate firetouchinterest
	for i = 1, #parts do safeFireTouch(root, parts[i]) end

	-- Second burst: RenderStepped (fires before next render — faster than task.defer)
	local renderConn
	renderConn = RunService.RenderStepped:Connect(function()
		renderConn:Disconnect()
		if not drop or not drop.Parent then return end
		local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not r then return end
		for i = 1, #parts do
			parts[i].CFrame = r.CFrame
			safeFireTouch(r, parts[i])
		end
	end)

	-- Third burst: task.defer (extra safety net)
	task.defer(function()
		if not drop or not drop.Parent then return end
		local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not r then return end
		for i = 1, #parts do
			parts[i].CFrame = r.CFrame
			safeFireTouch(r, parts[i])
		end
	end)

	-- Fourth burst: next Heartbeat
	local hbOnce
	hbOnce = RunService.Heartbeat:Connect(function()
		hbOnce:Disconnect()
		if not drop or not drop.Parent then return end
		local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not r then return end
		for i = 1, #parts do
			parts[i].CFrame = r.CFrame
			safeFireTouch(r, parts[i])
		end
	end)

	-- Start magnet (keeps drop glued to player every frame)
	autoGrabStartMagnet(drop)

	-- Continuous Heartbeat: keep drop on player and fire touch every frame until grabbed
	local touchConn
	touchConn = RunService.Heartbeat:Connect(function()
		if not drop or not drop.Parent then
			touchConn:Disconnect(); touchConn = nil
			return
		end
		if not autoGrabGunEnabled then
			touchConn:Disconnect(); touchConn = nil
			return
		end
		local freshRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not freshRoot then return end
		local freshCf = freshRoot.CFrame
		for i = 1, #parts do
			local part = parts[i]
			part.CFrame = freshCf
			part.AssemblyLinearVelocity = zero
			safeFireTouch(freshRoot, part)
		end
	end)

	drop.AncestryChanged:Connect(function()
		if not drop.Parent or drop.Parent == Workspace then
			autoGrabStopMagnet(drop)
			autoGrabGunProcessed[drop] = nil
		end
	end)
end

function autoGrabConnectModel(model)
	if autoGrabGunConnectedModels[model] then return end
	autoGrabGunConnectedModels[model] = true

	-- РњРіРЅРѕРІРµРЅРЅР°СЏ РїСЂРѕРІРµСЂРєР° СЃСѓС‰РµСЃС‚РІСѓСЋС‰РёС…
	for _, child in ipairs(model:GetDescendants()) do
		if child.Name == "GunDrop" then
			autoGrabClaimDrop(child)
		end
	end

	-- DescendantAdded - РїСЂСЏРјРѕР№ РІС‹Р·РѕРІ Р±РµР· Р·Р°РґРµСЂР¶РєРё (Р±С‹СЃС‚СЂРµРµ task.defer)
	local conn = model.DescendantAdded:Connect(function(descendant)
		if not autoGrabGunEnabled then return end
		if descendant.Name == "GunDrop" then
			autoGrabClaimDrop(descendant)
		end
	end)
	autoGrabGunConnections[model] = conn

	-- ChildAdded - РґСѓР±Р»РёСЂСѓСЋС‰РёР№ РїРµСЂРµС…РІР°С‚
	local conn2 = model.ChildAdded:Connect(function(child)
		if not autoGrabGunEnabled then return end
		if child.Name == "GunDrop" then
			autoGrabClaimDrop(child)
		end
		if child:IsA("Model") or child:IsA("Folder") then
			for _, desc in ipairs(child:GetDescendants()) do
				if desc.Name == "GunDrop" then
					autoGrabClaimDrop(desc)
				end
			end
		end
	end)
	table.insert(autoGrabGunConnections, conn2)

	model.AncestryChanged:Connect(function()
		if not model.Parent then
			if autoGrabGunConnections[model] then
				autoGrabGunConnections[model]:Disconnect()
				autoGrabGunConnections[model] = nil
				autoGrabGunConnectedModels[model] = nil
			end
		end
	end)
end

function autoGrabScanWorkspace()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
		-- РўР°РєР¶Рµ Р»РѕРІРёРј GunDrop РЅР°РїСЂСЏРјСѓСЋ
		if obj.Name == "GunDrop" then
			autoGrabClaimDrop(obj)
		end
	end
end

function enableAutoGrabGun()
	autoGrabGunEnabled = true
	autoGrabGunProcessed = {}
	autoGrabGunConnectedModels = {}
	for drop, conn in pairs(autoGrabGunMagnets) do
		conn:Disconnect()
	end
	autoGrabGunMagnets = {}
	for model, conn in pairs(autoGrabGunConnections) do
		if conn then conn:Disconnect() end
	end
	autoGrabGunConnections = {}

	autoGrabScanWorkspace()

	-- Workspace.DescendantAdded - РїСЂСЏРјРѕР№ РІС‹Р·РѕРІ, Р±РµР· Р·Р°РґРµСЂР¶РєРё
	table.insert(autoGrabGunConnections, Workspace.DescendantAdded:Connect(function(obj)
		if not autoGrabGunEnabled then return end
		if obj.Name == "GunDrop" then
			-- GunDrop РІ РїРµСЂРІСѓСЋ РѕС‡РµСЂРµРґСЊ - СЃР°РјС‹Р№ РїСЂРёРѕСЂРёС‚РµС‚РЅС‹Р№ СЃР»СѓС‡Р°Р№
			autoGrabClaimDrop(obj)
		elseif obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
	end))

	-- Workspace.ChildAdded - РґРѕРїРѕР»РЅРёС‚РµР»СЊРЅС‹Р№ РїРµСЂРµС…РІР°С‚ РІРµСЂС…РЅРµРіРѕ СѓСЂРѕРІРЅСЏ
	table.insert(autoGrabGunConnections, Workspace.ChildAdded:Connect(function(obj)
		if not autoGrabGunEnabled then return end
		if obj.Name == "GunDrop" then
			autoGrabClaimDrop(obj)
		end
		if obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
	end))

	table.insert(autoGrabGunConnections, player.CharacterAdded:Connect(function(char)
		if not autoGrabGunEnabled then return end
		for drop, conn in pairs(autoGrabGunMagnets) do
			conn:Disconnect()
		end
		autoGrabGunMagnets = {}
		autoGrabGunProcessed = {}
		autoGrabGunConnectedModels = {}
		char:WaitForChild("HumanoidRootPart")
		autoGrabScanWorkspace()
	end))

	-- РџРµСЂРёРѕРґРёС‡РµСЃРєРѕРµ СЃРє��°РЅРёСЂРѕРІР°РЅРёРµ - РєР°Р¶РґС‹Рµ 5 СЃРµРєСѓРЅРґ (DescendantAdded Р»РѕРІРёС‚ РјРіРЅРѕРІРµРЅРЅРѕ)
	task.spawn(function()
		-- [perf] DescendantAdded already catches every new drop instantly, so the
		-- full-Workspace rescan is only a safety net. 1s full scans were freezing
		-- mobile; 5s is more than enough for a fallback.
		while autoGrabGunEnabled do
			task.wait(5)
			if autoGrabGunEnabled then
				autoGrabScanWorkspace()
			end
		end
	end)
end

function disableAutoGrabGun()
	autoGrabGunEnabled = false
	for model, conn in pairs(autoGrabGunConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then
			conn:Disconnect()
		end
	end
	autoGrabGunConnections = {}
	for drop, conn in pairs(autoGrabGunMagnets) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	autoGrabGunMagnets = {}
	autoGrabGunProcessed = {}
	autoGrabGunConnectedModels = {}
end

function toggleAutoGrabGun()
	if autoGrabGunEnabled then
		disableAutoGrabGun()
	else
		enableAutoGrabGun()
	end
end


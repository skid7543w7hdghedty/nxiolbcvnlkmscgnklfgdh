	_espFrameCounter = _espFrameCounter + 1
end)

function espHookCharacter(plr, character)
	character:WaitForChild("HumanoidRootPart", 10)
	-- [perf] stagger players across 10 frames (~6 updates/sec each at 60fps) instead
	-- of 3 — role colors / name tags don't need 20 updates per second, and with a
	-- full lobby this cuts ESP CPU cost by ~70%
	local myOffset = math.random(0, 9)
	local conn = RunService.Heartbeat:Connect(function()
		if not espEnabled then return end
		if not character.Parent then return end
		if _espFrameCounter % 10 ~= myOffset then return end
		espUpdatePlayer(plr)
	end)
	local prev = espTrackedData[plr]
	if prev then
		if prev.conn then prev.conn:Disconnect() end
		espCleanCharacter(prev.character)
	end
	espTrackedData[plr] = { conn = conn, character = character }
	character.AncestryChanged:Connect(function(_, parent)
		if not parent and espTrackedData[plr] and espTrackedData[plr].character == character then
			conn:Disconnect()
		end
	end)
end

function espHookPlayer(plr)
	if plr == player then return end
	if plr.Character then task.spawn(espHookCharacter, plr, plr.Character) end
	local charAddedConn = plr.CharacterAdded:Connect(function(character)
		task.spawn(espHookCharacter, plr, character)
	end)
	table.insert(espConnections, charAddedConn)
end

function espCleanAll()
	for plr, data in pairs(espTrackedData) do
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
	end
	espTrackedData = {}
	for gunDrop, data in pairs(espTrackedGuns) do
		if data.conn then data.conn:Disconnect() end
		espCleanGun(gunDrop)
	end
	espTrackedGuns = {}
	for _, conn in ipairs(espConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then
			conn:Disconnect()
		end
	end
	espConnections = {}
	espRoles = nil
end

function espEnableAll()
	-- Hook players
	for _, plr in ipairs(Players:GetPlayers()) do
		task.spawn(espHookPlayer, plr)
	end
	table.insert(espConnections, Players.PlayerAdded:Connect(function(plr)
		espHookPlayer(plr)
	end))
	table.insert(espConnections, Players.PlayerRemoving:Connect(function(plr)
		local data = espTrackedData[plr]
		if not data then return end
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
		espTrackedData[plr] = nil
	end))

	-- Roles loop
	task.spawn(function()
		while espEnabled do
			local ok, result = pcall(function()
				return invokePlayerData()
			end)
			if ok and result then
				espRoles = result
				espCurrentHero = nil
				for name, v in pairs(result) do
					if v.Role == "Hero" then
						espCurrentHero = name
					end
				end
			end
			task.wait(0.75)
		end
	end)

	-- Gun ESP: scan existing maps
	espScanForMaps()

	-- Gun ESP: watch for new maps
	table.insert(espConnections, Workspace.ChildAdded:Connect(function(child)
		if not espEnabled then return end
		for _, mapName in ipairs(ESP_MAP_NAMES) do
			if child.Name == mapName then
				task.wait(0.5)
				espFindGunDropsInModel(child)
				break
			end
		end
	end))

	-- Gun ESP: watch for GunDrop anywhere inside map hierarchy
	table.insert(espConnections, Workspace.DescendantAdded:Connect(function(descendant)
		if not espEnabled then return end
		if descendant.Name == "GunDrop" then
			local parent = descendant.Parent
			while parent and parent ~= Workspace do
				for _, mapName in ipairs(ESP_MAP_NAMES) do
					if parent.Name == mapName then
						task.spawn(espHookGunDrop, descendant)
						return
					end
				end
				parent = parent.Parent
			end
		end
	end))
end

function toggleEsp()
	espEnabled = not espEnabled
	if espEnabled then
		espEnableAll()
	else
		espCleanAll()
	end
end


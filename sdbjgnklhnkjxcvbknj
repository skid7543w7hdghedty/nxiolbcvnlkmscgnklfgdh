antiVoidEnabled = false
antiVoidFpsdiv = 5
antiVoidDestroyHeight = workspace.FallenPartsDestroyHeight
antiVoidDhoffset = 5
antiVoidDhto = 25
antiVoidDestroyHeightNew = antiVoidDestroyHeight + antiVoidDhoffset
antiVoidConnections = {}
antiVoidCharcframe = nil
antiVoidTpcframe = nil

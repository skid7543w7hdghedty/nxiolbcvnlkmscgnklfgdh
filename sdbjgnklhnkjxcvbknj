				data.popupBtn.TextColor3 = extractedBtnActiveTextColor
			else
				data.popupBtn.BackgroundColor3 = extractedBtnBgColor
				data.popupBtn.TextColor3 = extractedBtnTextColor
			end
		end
		if data.popupLockBtn then
			if data.popupLockBtn.Text == "U" then
				data.popupLockBtn.BackgroundColor3 = extractedBtnBgColor
			end
		end
	end
end


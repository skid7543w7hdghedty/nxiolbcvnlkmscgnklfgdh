_antiFlingLastSafePos = nil

function antiFlingCollide(plr)
	if plr and plr.Character and plr ~= player then
		for _, v in pairs(plr.Character:GetChildren()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
				v.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				v.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				v.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0)
			end
		end
	end
end

function antiFlingEnable()
	-- Skip Anti-Fling when OUR OWN features intentionally use high velocity / CFrame changes.
	-- Without this bypass, Anti-Fling fights against Fling, Anti-Shoot, Desync, Touch Fling, etc.
	if flingActive or loopFlingActive or hiddenfling or PastedSources or DesyncSpinActive or (nanFlingConnection ~= nil) then
		_antiFlingLastSafePos = nil -- reset safe position so we don't snap back after feature ends
		-- IMPORTANT: while our own Fling is running, give other players their physics back
		-- so we can actually throw them. The per-frame loop below normally makes everyone
		-- non-collidable + massless, which silently breaks the Utilities Fling.
		for _, v in pairs(game.Players:GetPlayers()) do
			if v ~= player and v.Character then
				for _, b in pairs(v.Character:GetChildren()) do
					if b:IsA("BasePart") then
						b.CanCollide = true
						b.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5, 1, 1)
					end
				end
			end
		end
		return
	end

	-- Self-protection: make it impossible for another exploiter to move us at all.
	local char = player.Character
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChild("Humanoid")
		if hrp and hum and hum.Health > 0 then
			local vel = hrp.AssemblyLinearVelocity
			local hSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
			-- Kill any tumbling spin (keep yaw so normal turning still works). This stops
			-- spin-flings and avoids the broken Touch-Fling-style rotation entirely.
			hrp.AssemblyAngularVelocity = Vector3.new(0, hrp.AssemblyAngularVelocity.Y, 0)
			if _antiFlingLastSafePos and hSpeed > 140 then
				-- External fling detected. Snap back INSTANTLY with no displacement tolerance,
				-- so even an extremely aggressive fling cannot move us a single stud.
				hrp.CFrame = _antiFlingLastSafePos
				hrp.AssemblyLinearVelocity = Vector3.new(0, math.min(vel.Y, 0), 0)
				hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
			elseif hSpeed < 100 then
				-- Normal, self-controlled movement: remember this as the last safe position.
				_antiFlingLastSafePos = hrp.CFrame
			end
		end
	end
	-- Other players: no collision, zero velocity, massless (every frame). With no collision
	-- and no mass a hostile fling part cannot transfer momentum to us, so we can't be pushed.
	for _, v in pairs(game.Players:GetPlayers()) do
		if v ~= player then
			antiFlingCollide(v)
		end
	end
end

function toggleAntiFling()
	antiFlingEnabled = not antiFlingEnabled
	if antiFlingEnabled then
		antiFlingConnection = RunService.Heartbeat:Connect(antiFlingEnable)
	else
		if antiFlingConnection then
			antiFlingConnection:Disconnect()
			antiFlingConnection = nil
		end
		for i,v in pairs(reachCachePlayers) do
			if v ~= player and v.Character then
				for h,b in pairs(v.Character:GetChildren()) do
					if b:IsA("BasePart") then
						b.CanCollide = true
					end
				end
			end
		end
	end
end


		for catName, catData in pairs(categories) do
			catData.button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			catData.button.TextColor3 = Color3.fromRGB(170, 170, 170)
			catData.isActive = false
		end
		
		-- Activate this category
		currentCategory = fullName
		btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		btn.TextColor3 = Color3.fromRGB(0, 0, 0)
		categories[fullName].isActive = true
		
		-- Update content visibility
		for _, child in ipairs(contentFrame:GetChildren()) do
			if child:GetAttribute("Category") then
				if child:GetAttribute("Category") == fullName then
					child.Visible = true
				else
					child.Visible = false
				end
			end
		end
	end)
	
	return btn
end


		addInfoLine("Registered: " .. regDateStr)

		local years = math.floor(plr.AccountAge / 365)
		local remaining = plr.AccountAge % 365
		local months = math.floor(remaining / 30)
		local days = remaining % 30
		local ageText = plr.AccountAge .. " days"
		if years > 0 or months > 0 or days > 0 then
			ageText = ageText .. " (" .. years .. "y, " .. months .. "m, " .. days .. "d)"
		end
		addInfoLine("Account Age: " .. ageText)

		local exactAgeLine = addInfoLine("Current Age: N/A")
		local positionLine = addInfoLine("Player Position: N/A")

		-- Р–РёРІС‹Рµ Р»РµР№Р±Р»С‹ СЃРєРѕСЂРѕСЃС‚Рё/РїСЂС‹Р¶РєР°
		local speedLine  = addInfoLine("Walk Speed: N/A")
		local jumpLine   = addInfoLine("Jump Power: N/A")
		local healthLine = addInfoLine("Health: N/A")

		local teamerConns = {}
		local teamerLoopAlive = true

		local teamerCreationTime = exactRegUnix or (os.time() - plr.AccountAge * 86400)

		local function disconnectTeamerConns()
			for _, c in ipairs(teamerConns) do c:Disconnect() end
			teamerConns = {}
		end

		local function attachTeamerStats(char)
			disconnectTeamerConns()
			local hum  = char and char:FindFirstChildOfClass("Humanoid")
			local root = char and char:FindFirstChild("HumanoidRootPart")
			if not hum or not root then return end
			local function updateJP()
				if jumpLine and jumpLine.Parent then
					jumpLine.Text = "Jump Power: " .. hum.JumpPower
				end
			end
			updateJP()
			table.insert(teamerConns, hum:GetPropertyChangedSignal("JumpPower"):Connect(updateJP))
		end

		attachTeamerStats(plr.Character)
		table.insert(teamerConns, plr.CharacterAdded:Connect(function(newChar)
			task.wait(1)
			if teamerLoopAlive then attachTeamerStats(newChar) end
		end))

		task.spawn(function()
			while teamerLoopAlive do
				task.wait(0.15)
				local char = plr.Character
				if char then
					local hum  = char:FindFirstChildOfClass("Humanoid")
					local root = char:FindFirstChild("HumanoidRootPart")
					if hum and root then
						local vel = root.AssemblyLinearVelocity
						local horizSpeed = math.floor(math.sqrt(vel.X*vel.X + vel.Z*vel.Z) + 0.5)
						if speedLine and speedLine.Parent then
							speedLine.Text = "Walk Speed: " .. horizSpeed
						end
						if healthLine and healthLine.Parent then
							healthLine.Text = "Health: " .. math.floor(hum.Health) .. "/" .. hum.MaxHealth
						end
					end
				end
				if exactAgeLine and exactAgeLine.Parent then
					local diff = os.time() - teamerCreationTime
					local totalDays = math.floor(diff / 86400)
					local y = math.floor(totalDays / 365)
					local rd = totalDays % 365
					local m = math.floor(rd / 30)
					local d = rd % 30
					local h = math.floor((diff % 86400) / 3600)
					local mn = math.floor((diff % 3600) / 60)
					local s = diff % 60
					exactAgeLine.Text = string.format("Current Age: %dy, %dm, %dd, %dh, %dm, %ds", y, m, d, h, mn, s)
				if positionLine and positionLine.Parent and char then
					local root = char:FindFirstChild("HumanoidRootPart")
					if root then
						local p = root.Position
						positionLine.Text = string.format("Player Position: %.1f, %.1f, %.1f", p.X, p.Y, p.Z)
					end
				end
				end
			end
		end)

		popupGui.Destroying:Connect(function()
			teamerLoopAlive = false
			friendRefreshAlive = false
			disconnectTeamerConns()
		end)

		addInfoLine("Gravity: " .. math.floor(workspace.Gravity))

		-- Draggable popup
		local popupDragging = false
		local popupDragInput
		local popupDragStart
		local popupStartPos

		popupTitle.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				popupDragging = true
				popupDragStart = input.Position
				popupStartPos = popup.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						popupDragging = false
					end
				end)
			end
		end)

		popupTitle.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				popupDragInput = input
			end
		end)

		local popupDragCon = UserInputService.InputChanged:Connect(function(input)
			if input == popupDragInput and popupDragging then
				local delta = input.Position - popupDragStart
				popup.Position = UDim2.new(popupStartPos.X.Scale, popupStartPos.X.Offset + delta.X, popupStartPos.Y.Scale, popupStartPos.Y.Offset + delta.Y)
			end
		end)

		popup.Destroying:Connect(function()
			popupDragCon:Disconnect()
		end)

		local escConn
		escConn = UserInputService.InputBegan:Connect(function(input)
			if input.KeyCode == Enum.KeyCode.Escape then
				popupGui.Enabled = false
			end
		end)

		teamerPopupCache[plr.Name] = popupGui
	end)
end


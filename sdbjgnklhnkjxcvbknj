-- ============================================
voteMapCoords = {
	CFrame.new(25, 507, 49),  -- Map 1
	CFrame.new(14, 507, 52),  -- Map 2
	CFrame.new(2, 507, 49),   -- Map 3
}

voteDupeActive = false
voteDupeCurrentMap = 0

function voteResetSelf()
	local char = player.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then pcall(function() hum.Health = 0 end) end
	if char then pcall(function() char:BreakJoints() end) end
end

function voteDupeStart(mapIndex)
	if voteDupeActive then
		voteDupeActive = false
		task.wait(0.2)
	end
	voteDupeCurrentMap = mapIndex
	voteDupeActive = true
	local voteCF = voteMapCoords[mapIndex]
	if not voteCF then return end

	task.spawn(function()
		while voteDupeActive do
			local voteCount = math.max(1, #Players:GetPlayers() - 1)

			for i = 1, voteCount do
				if not voteDupeActive then break end

				-- Wait for character to respawn (fast poll)
				local char, hrp, hum
				local waitTime = 0
				repeat
					RunService.Heartbeat:Wait()
					waitTime = waitTime + 0.016
					char = player.Character
					hrp = char and char:FindFirstChild("HumanoidRootPart")
					hum = char and char:FindFirstChildOfClass("Humanoid")
				until (hrp and hum and hum.Health > 0) or waitTime > 6 or not voteDupeActive

				if not voteDupeActive then break end
				if not (hrp and hum and hum.Health > 0) then break end

				-- Teleport to vote pad + touch, wait for server to register, then reset
				pcall(function() hrp.CFrame = voteCF end)
				RunService.Heartbeat:Wait()
				-- Touch vote-area parts (first burst — immediate)
				pcall(function()
					for _, d in ipairs(Workspace:GetDescendants()) do
						if d:IsA("BasePart") and (d.Position - voteCF.Position).Magnitude < 6 then
							safeFireTouch(hrp, d)
						end
					end
				end)
				task.wait(0.08)
				-- Second touch burst to confirm vote
				pcall(function()
					for _, d in ipairs(Workspace:GetDescendants()) do
						if d:IsA("BasePart") and (d.Position - voteCF.Position).Magnitude < 6 then
							safeFireTouch(hrp, d)
						end
					end
				end)
				task.wait(0.12)
				-- Reset after the vote has been registered
				voteResetSelf()
				-- Wait for death to register + respawn
				task.wait(0.2)
				-- Wait for CharacterAdded before next iteration (loop will poll above)
			end

			voteDupeActive = false
		end

		for idx = 1, 3 do
			if voteDupeBtns[idx] then
				setToggleState(voteDupeBtns[idx], false,
					"Vote Dupe Map " .. idx .. ": ON",
					"Vote Dupe Map " .. idx .. ": OFF")
			end
		end
		notify("Vote Dupe", "Finished vote duplication.", 2)
	end)
end

function voteDupeStop()
	voteDupeActive = false
end

voteDupeBtns = {}
for mapIdx = 1, 3 do
	voteDupeBtns[mapIdx] = createButton(
		"VoteDupeMap" .. mapIdx .. "Button",
		"Vote Dupe Map " .. mapIdx .. ": OFF",
		115.81 + (mapIdx * 0.01)
	)
	voteDupeBtns[mapIdx].MouseButton1Click:Connect(function()

-- Desync Heartbeat + Hook (P1000)
desyncConnection = nil
function toggleDesync()
	PastedSources = not PastedSources
	if PastedSources then
		if DesyncSpinActive then
			DesyncSpinActive = false
			if desyncSpinConnection then desyncSpinConnection:Disconnect() desyncSpinConnection = nil end
			if desyncSpinButton then setToggleState(desyncSpinButton, false, "Desync: ON", "Desync: OFF") end
			setExtractedBtnState("Desync", false)
		end
		desyncConnection = RunService.Heartbeat:Connect(function()
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
				local hrp = char.HumanoidRootPart
				DesyncTypes[1] = hrp.CFrame
				DesyncTypes[2] = hrp.AssemblyLinearVelocity
				-- Displace the REPLICATED position by a random offset every frame.
				-- Rotation alone keeps the pivot in place, so the server still tracks
				-- you while moving (bullets only miss while standing). A real positional
				-- offset desyncs your server position no matter if you stand or move.
				local SpoofThis = (DesyncTypes[1] + Vector3.new(
					RandomNumberRange(DesyncOffsetRange),
					RandomNumberRange(DesyncOffsetRange),
					RandomNumberRange(DesyncOffsetRange)
				)) * CFrame.Angles(
					math.rad(RandomNumberRange(180)),
					math.rad(RandomNumberRange(180)),
					math.rad(RandomNumberRange(180))
				)
				hrp.CFrame = SpoofThis
				-- Randomized huge velocity direction: keeps the replicated position
				-- flung unpredictably so it can't settle/reconcile while you walk.
				hrp.AssemblyLinearVelocity = Vector3.new(
					RandomNumberRange(1),
					RandomNumberRange(1),
					RandomNumberRange(1)
				) * 16384
				RunService.RenderStepped:Wait()
				hrp.CFrame = DesyncTypes[1]
				hrp.AssemblyLinearVelocity = DesyncTypes[2]
				-- POST-UPDATE FIX: an idle character assembly now sleeps, so the per-frame
				-- spoof stopped replicating while standing (bullets only missed while
				-- running). keepAssemblyAwake keeps it streaming WITHOUT spinning the camera
				-- (zero angular velocity) and WITHOUT drifting the body (flip-sign velocity).
				keepAssemblyAwake(hrp, char:FindFirstChildOfClass("Humanoid"))
			end
		end)
	else
		if desyncConnection then
			desyncConnection:Disconnect()
			desyncConnection = nil
		end
	end
end

function toggleDesyncSpin()
	DesyncSpinActive = not DesyncSpinActive
	if DesyncSpinActive then
		-- Mutually exclusive with Anti-Shoot (both drive hrp.CFrame each frame)
		if PastedSources then
			PastedSources = false
			if desyncConnection then desyncConnection:Disconnect() desyncConnection = nil end
			if desyncButton then setToggleState(desyncButton, false, "Anti-Shoot: ON", "Anti-Shoot: OFF") end
			setExtractedBtnState("Anti-Shoot", false)
		end
		desyncSpinConnection = RunService.Heartbeat:Connect(function()
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
				local hrp = char.HumanoidRootPart
				DesyncTypes[1] = hrp.CFrame
				DesyncTypes[2] = hrp.AssemblyLinearVelocity
				-- Original spin look (random rotation) so others see you spinning &
				-- walking, PLUS a random positional offset each frame so your replicated
				-- position desyncs from your real one even while moving -> bullets pass
				-- through while you walk, not only while standing still.
				local SpoofThis = (DesyncTypes[1] + Vector3.new(
					RandomNumberRange(DesyncSpinOffset),
					RandomNumberRange(DesyncSpinOffset),
					RandomNumberRange(DesyncSpinOffset)
				)) * CFrame.Angles(
					math.rad(RandomNumberRange(180)),
					math.rad(RandomNumberRange(180)),
					math.rad(RandomNumberRange(180))
				)
				hrp.CFrame = SpoofThis
				hrp.AssemblyLinearVelocity = Vector3.new(1, 1, 1) * 16384
				RunService.RenderStepped:Wait()
				hrp.CFrame = DesyncTypes[1]
				hrp.AssemblyLinearVelocity = DesyncTypes[2]
				-- POST-UPDATE FIX (see Anti-Shoot): keep the assembly awake while idle,
				-- without spinning the camera, so the desync replicates standing still too.
				keepAssemblyAwake(hrp, char:FindFirstChildOfClass("Humanoid"))
			end
		end)
	else
		if desyncSpinConnection then
			desyncSpinConnection:Disconnect()
			desyncSpinConnection = nil
		end
	end
end

-- Desync / Anti-Shoot camera stabilizer (NO metamethod hook).
-- The old `hookmetamethod(game,"__index",...)` broke game mechanics (it faked CFrame
-- reads for EVERY script). Both desync modes teleport+spin the real HumanoidRootPart
-- each frame to desync the server, which throws the camera around. The camera module
-- is a Lua script that reads the character transform to place the camera, so the fix
-- is: right BEFORE the camera module runs, snap our character back to its real pose;
-- right AFTER it runs, restore the spoofed pose. The camera is then computed from the
-- REAL position AND orientation => fully stable (no swirl from the spin), exactly like
-- the old hook, but we only ever touch OUR OWN character (no global hook).
desyncCamSpoofBackup = nil
pcall(function()
	-- Just BEFORE the camera updates: stash the spoofed pose, put the real one back.
	RunService:BindToRenderStep("AdrenalinDesyncCamPre", Enum.RenderPriority.Camera.Value - 1, function()
		desyncCamSpoofBackup = nil
		local realCF = nil
		if antiAimIsActive() and antiAimRealCF then
			realCF = antiAimRealCF
		elseif (PastedSources or DesyncSpinActive) then
			realCF = DesyncTypes[1]
		end
		if not realCF then return end
		local char = player.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		desyncCamSpoofBackup = hrp.CFrame
		hrp.CFrame = realCF
	end)
	-- Just AFTER the camera updated (using the real pose): restore the spoof so it keeps
	-- replicating to the server. Body may still render spoofed, but the camera is locked.
	RunService:BindToRenderStep("AdrenalinDesyncCamPost", Enum.RenderPriority.Camera.Value + 1, function()
		if not desyncCamSpoofBackup then return end
		local char = player.Character
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then hrp.CFrame = desyncCamSpoofBackup end
		end
		desyncCamSpoofBackup = nil
	end)
end)


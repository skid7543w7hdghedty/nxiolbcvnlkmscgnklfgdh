-- ============================================================
-- AIM SUITE: Shoot Murderer + Wall Bang + Auto Shot (ported from Aim.lua)
-- Lives in the Combat tab. Reuses the menu's espRoles cache when ESP is on,
-- otherwise keeps its own light role poll so Auto Shot works without ESP.
-- ============================================================
local AimStats = game:GetService("Stats")

aimWallbangEnabled = false
aimAutoShotEnabled = false
aimLmbShootEnabled = false
flickShotEnabled = false
flickShotDuration = 0.30
spin360Enabled = false
spin360Duration = 1.5
aimTargetDot = nil

AIM_CONFIG = {
	pingScale          = 1.0,
	extraLeadSec       = 0.015,
	renderDelta        = 1/60,
	maxLeadSec         = 0.45,
	aimPart            = "Torso",          -- center mass for bigger hitbox
	rolePollRate       = 0.15,
	gravityComp        = true,
	shotsPerClick      = 4,                -- shots per manual burst (each burst now covers the WHOLE predicted path)
	shotSpacing        = 0.0,
	wallbangOriginDist = 0.6,              -- very close origin = almost guaranteed piercer hit
	autoShotCooldown   = 0.35,             -- min seconds between Auto Shot bursts (0.0 spammed 300+ remotes/sec and lagged the game)
	autoShotBurst      = 3,                -- shots per AUTO burst (smaller than manual so auto mode stays lag-free)
	scatterRadius      = 0.35,             -- scatter radius around the full-lead point (covers strafe direction changes)
	scatterShots       = 2,
	jumpAimYBoost      = 1.5,              -- higher Y offset for jumping targets
	alwaysPierceOrigin = true,             -- always place origin next to target (bypass desync/invis)
	velTrackAlpha      = 0.55,             -- smoothing for the measured-velocity tracker (higher = reacts faster to direction changes)
	pathFanFracs       = {0, 0.45, 1.0, 1.45}, -- lead fractions covered by one burst: shots fan ALONG the predicted path
	pathSegHalf        = 1.8,              -- half-length (studs) of the path segment each bullet SWEEPS along the movement direction
}

-- Our own role cache (used only when the ESP cache espRoles is not available)
aimRoleCache = nil

function aimRefreshRoleNow()
	local ok, result = pcall(function()
		-- aim needs the freshest possible data on gun pickup, so it bypasses the
		-- shared 0.35s cache but still reuses the cached remote reference
		local remote = getPlayerDataRemote()
		return remote and remote:InvokeServer()
	end)
	if ok and type(result) == "table" then
		aimRoleCache = result
		-- feed the shared cache so other pollers skip their own InvokeServer
		_roleDataCache = result
		_roleDataCacheAt = os.clock()
		return result
	end
	return aimRoleCache
end

task.spawn(function()
	while true do
		-- Only poll ourselves when the ESP cache isn't already being kept fresh.
		if type(espRoles) ~= "table" then
			pcall(aimRefreshRoleNow)
		end
		task.wait(AIM_CONFIG.rolePollRate)
	end
end)

local function aimGetRoleData()
	if type(espRoles) == "table" then return espRoles end
	if type(aimRoleCache) == "table" then return aimRoleCache end
	return nil
end

local function aimGetPing()
	local ok, v = pcall(function()
		return AimStats.Network.ServerStatsItem["Data Ping"]:GetValue()
	end)
	return ok and v or 0
end

local function aimGetLeadTime()
	local ping = aimGetPing() / 1000
	local lead = ping * AIM_CONFIG.pingScale + AIM_CONFIG.renderDelta + AIM_CONFIG.extraLeadSec
	if lead > AIM_CONFIG.maxLeadSec then lead = AIM_CONFIG.maxLeadSec end
	if lead < 0 then lead = 0 end
	return lead
end

local function aimIsAirborne(character)
	local hum = character:FindFirstChildOfClass("Humanoid")
	if not hum then return false end
	if hum.FloorMaterial == Enum.Material.Air then return true end
	local st = hum:GetState()
	return st == Enum.HumanoidStateType.Freefall or st == Enum.HumanoidStateType.Jumping
end

-- Measured-velocity tracker: AssemblyLinearVelocity is often WRONG for other
-- players (spoofed by their own desync, zeroed while the physics assembly
-- sleeps, or stale under lag) — that was a major source of misses on moving
-- targets. We measure the REAL replicated motion from position deltas and
-- smooth it, then use whichever velocity (reported vs measured) is more
-- trustworthy. Weak keys so dead characters get garbage-collected.
local aimVelTrack = setmetatable({}, {__mode = "k"})
local function aimTrackVelocity(character)
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then return Vector3.new(0, 0, 0) end
	local now = os.clock()
	local rec = aimVelTrack[character]
	local p = root.Position
	if not rec then
		rec = {pos = p, t = now, vel = root.AssemblyLinearVelocity}
		aimVelTrack[character] = rec
		return rec.vel
	end
	local dt = now - rec.t
	if dt >= 1 / 120 then
		local measured = (p - rec.pos) / dt
		-- Teleport-like jump (respawn/desync snap): don't poison the tracker
		if measured.Magnitude > 90 then
			measured = root.AssemblyLinearVelocity
		end
		local a = AIM_CONFIG.velTrackAlpha or 0.4
		rec.vel = rec.vel + (measured - rec.vel) * a
		rec.pos, rec.t = p, now
	end
	return rec.vel
end

-- Best-guess velocity for prediction: blend of reported and measured, capped at
-- a plausible run speed so a knockback/physics spike can't fling the aim point.
local function aimGetTargetVelocity(character)
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then return Vector3.new(0, 0, 0) end
	local reported = root.AssemblyLinearVelocity
	local measured = aimTrackVelocity(character)
	local repH = math.sqrt(reported.X * reported.X + reported.Z * reported.Z)
	local mesH = math.sqrt(measured.X * measured.X + measured.Z * measured.Z)
	-- Reported says "standing" but the target is visibly moving -> trust measured
	local v = (mesH > repH + 2) and measured or reported
	-- Cap horizontal speed at a plausible sprint so spikes don't overshoot the aim
	local hum = character:FindFirstChildOfClass("Humanoid")
	local maxH = math.max((hum and hum.WalkSpeed or 16) * 1.6, 30)
	local hV = Vector3.new(v.X, 0, v.Z)
	if hV.Magnitude > maxH then
		hV = hV.Unit * maxH
		v = Vector3.new(hV.X, v.Y, hV.Z)
	end
	return v
end

-- leadFrac lets one burst fan its shots ALONG the predicted path (0 = current
-- position, 1 = full ping-lead position, >1 = slightly past it). Previously all
-- shots went to ONE identical point, so a small prediction error missed with
-- every bullet at once.
local function aimPredictTorso(character, leadFrac)
	if not character then return nil end
	local root = character:FindFirstChild("HumanoidRootPart")
	local aimPart = character:FindFirstChild(AIM_CONFIG.aimPart)
		or character:FindFirstChild("Torso")
		or character:FindFirstChild("UpperTorso")
		or root
	if not aimPart then return nil end
	local v = aimGetTargetVelocity(character)
	local p = aimPart.Position
	local t = aimGetLeadTime() * (leadFrac == nil and 1 or leadFrac)
	-- Check horizontal speed — if target barely moves, aim directly (no prediction error)
	local hSpeed = math.sqrt(v.X * v.X + v.Z * v.Z)
	if hSpeed < 2 then
		-- Standing or nearly standing: aim at exact current position
		local airborne = AIM_CONFIG.gravityComp and aimIsAirborne(character)
		if airborne then
			local g = workspace.Gravity
			local py = p.Y + v.Y * t - 0.5 * g * t * t
			local boost = AIM_CONFIG.jumpAimYBoost or 0
			if v.Y > 5 then py = py + boost
			elseif v.Y < -5 then py = py - boost * 0.5 end
			return Vector3.new(p.X, py, p.Z)
		end
		return p
	end
	-- Moving target: full velocity prediction
	local px = p.X + v.X * t
	local pz = p.Z + v.Z * t
	local py
	local airborne = AIM_CONFIG.gravityComp and aimIsAirborne(character)
	if airborne then
		local g = workspace.Gravity
		py = p.Y + v.Y * t - 0.5 * g * t * t
		local boost = AIM_CONFIG.jumpAimYBoost or 0
		if v.Y > 5 then
			py = py + boost
		elseif v.Y < -5 then
			py = py - boost * 0.5
		end
	else
		py = p.Y + v.Y * t
	end
	return Vector3.new(px, py, pz)
end

-- Generate scatter positions around a predicted point for multi-hit
local function aimScatterPositions(center)
	local positions = {center}
	local r = AIM_CONFIG.scatterRadius or 0
	local n = AIM_CONFIG.scatterShots or 0
	if r > 0 and n > 0 then
		for i = 1, n do
			local angle = math.random() * math.pi * 2
			local dist = math.random() * r
			local ox = math.cos(angle) * dist
			local oz = math.sin(angle) * dist
			table.insert(positions, center + Vector3.new(ox, 0, oz))
		end
	end
	return positions
end

local function aimFindMurderer()
	local data = aimGetRoleData()
	if data then
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player then
				local info = data[plr.Name]
				if info and info.Role == "Murderer" then return plr end
			end
		end
	end
	for _, i in ipairs(Players:GetPlayers()) do
		if i ~= player then
			local bp = i:FindFirstChild("Backpack")
			if bp and bp:FindFirstChild("Knife") then return i end
		end
	end
	for _, i in ipairs(Players:GetPlayers()) do
		if i ~= player and i.Character and i.Character:FindFirstChild("Knife") then return i end
	end
	return nil
end

local function aimFindNearestPlayer()
	if not player.Character then return nil end
	local myRoot = player.Character:FindFirstChild("HumanoidRootPart")
	if not myRoot then return nil end
	local nearest, best = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local r = p.Character:FindFirstChild("HumanoidRootPart")
			if r then
				local d = (myRoot.Position - r.Position).Magnitude
				if d < best then best = d; nearest = p end
			end
		end
	end
	return nearest
end

local function aimMurdererAlive(m)
	if not m or not m.Character then return false end
	local hum = m.Character:FindFirstChildOfClass("Humanoid")
	return hum ~= nil and hum.Health > 0
end

local function aimGetShootRemote()
	local char = player.Character
	if not char then return nil end
	local gun = char:FindFirstChild("Gun")
	if not gun then
		local bp = player:FindFirstChild("Backpack")
		local bg = bp and bp:FindFirstChild("Gun")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if bg and hum then
			pcall(function() hum:EquipTool(bg) end)
			task.wait()
			gun = char:FindFirstChild("Gun") or bg
		else
			gun = bg
		end
	end
	if not gun then return nil end
	return gun:FindFirstChild("Shoot")
end

local function aimGetShootOrigin(target)
	local char = player.Character
	local originPart = char and (char:FindFirstChild("RightHand") or char:FindFirstChild("HumanoidRootPart"))
	local myPos = originPart and originPart.Position or Vector3.new(0, 0, 0)
	-- Always use piercer-style origin when enabled or when desync features are active
	-- This ensures shots hit even when using Invisible, Desync, or Anti-Shoot
	local forcePierce = AIM_CONFIG.alwaysPierceOrigin or aimWallbangEnabled
		or PastedSources or DesyncSpinActive or hiddenfling
	if forcePierce then
		local dir = myPos - target
		local unit = dir.Magnitude > 1e-3 and dir.Unit or Vector3.new(0, 1, 0)
		return target + unit * AIM_CONFIG.wallbangOriginDist
	end
	return myPos
end

-- originOverride lets path-sweep shots place the ray origin themselves (behind
-- the target on its movement path) instead of the default near-target origin.
local function aimFireOnce(shoot, target, originOverride)
	local origin = originOverride or aimGetShootOrigin(target)
	return pcall(function() shoot:FireServer(CFrame.new(origin), CFrame.new(target)) end)
end

-- burstOverride lets the Auto Shot loop fire smaller bursts than a manual click.
--
-- ACCURACY OVERHAUL — why the old version missed:
--   1. The whole burst fired on ONE stale snapshot of position/velocity: every
--      bullet inherited the same prediction error.
--   2. Every bullet was a POINT shot at a guessed future position — with any
--      lead error (variable ping, strafe change) ALL bullets missed together.
-- New approach:
--   * Every bullet against a moving target is a PATH-SWEEP ray: the origin is
--     placed BEHIND the aim point along the target's movement direction and the
--     endpoint AHEAD of it, so the server-side ray passes through a whole
--     segment of the target's path. Wherever on that segment the target really
--     is on the server, the ray crosses its hitbox — lead error no longer
--     causes a clean miss.
--   * One extra "full-path" sweep covers current position -> past full lead in
--     a single ray, guaranteeing coverage even if the lead estimate is way off.
--   * The burst is spread across frames (Heartbeat between shots) and position,
--     velocity and lead are re-read for EVERY bullet, so later bullets self-
--     correct instead of repeating the first bullet's error.
--   * Vertical bracket shots cover jumping / crouching / FakeDuck hitbox shifts
--     for both standing AND moving targets.

-- Flick Shot: rotates the character to face the target before shooting, then
-- rotates back. Designed for first-person / shift-lock where character rotation
-- = camera rotation. The rotation takes flickShotDuration seconds so other
-- players can see the turn.
function doFlickToTarget(targetPlayer, callback)
	if not flickShotEnabled then callback() return end
	local char = player.Character
	if not char then callback() return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not (hrp and hum) then callback() return end
	local targetChar = targetPlayer.Character
	if not targetChar then callback() return end
	local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
	if not targetRoot then callback() return end

	local originalCF = hrp.CFrame
	local wasAutoRotate = hum.AutoRotate
	hum.AutoRotate = false

	local direction = (targetRoot.Position - hrp.Position) * Vector3.new(1, 0, 1)
	if direction.Magnitude < 0.1 then
		hum.AutoRotate = wasAutoRotate
		callback()
		return
	end
	local targetCF = CFrame.lookAt(hrp.Position, hrp.Position + direction.Unit)

	local steps = math.max(2, math.floor(flickShotDuration * 60))
	for i = 1, steps do
		hrp.CFrame = originalCF:Lerp(targetCF, i / steps)
		RunService.Heartbeat:Wait()
	end
	hrp.CFrame = targetCF
	task.wait(0.03)

	callback()

	task.wait(0.03)
	for i = 1, steps do
		hrp.CFrame = targetCF:Lerp(originalCF, i / steps)
		RunService.Heartbeat:Wait()
	end
	hrp.CFrame = originalCF
	hum.AutoRotate = wasAutoRotate
end

-- Spin 360: performs a full 360-degree spin in place over spin360Duration seconds.
function doSpin360(callback)
	if not spin360Enabled then callback() return end
	local char = player.Character
	if not char then callback() return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not (hrp and hum) then callback() return end

	local originalCF = hrp.CFrame
	local wasAutoRotate = hum.AutoRotate
	hum.AutoRotate = false

	local startYaw = math.atan2(-originalCF.LookVector.X, -originalCF.LookVector.Z)
	local totalAngle = math.rad(360)
	local steps = math.max(2, math.floor(spin360Duration * 60))
	for i = 1, steps do
		local frac = i / steps
		local currentAngle = startYaw + totalAngle * frac
		local dir = Vector3.new(math.sin(currentAngle), 0, math.cos(currentAngle))
		hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + dir)
		RunService.Heartbeat:Wait()
	end
	hrp.CFrame = originalCF
	task.wait(0.05)

	callback()

	task.wait(0.05)
	hrp.CFrame = originalCF
	hum.AutoRotate = wasAutoRotate
end

function aimFireGunAt(murderer, burstOverride)
	if flickShotEnabled and murderer then
		local result = false
		local function afterFlick()
			if spin360Enabled then
				doSpin360(function()
					result = aimFireGunAtOriginal(murderer, burstOverride)
				end)
			else
				result = aimFireGunAtOriginal(murderer, burstOverride)
			end
		end
		doFlickToTarget(murderer, afterFlick)
		return result
	end
	if spin360Enabled then
		local result = false
		doSpin360(function()
			result = aimFireGunAtOriginal(murderer, burstOverride)
		end)
		return result
	end
	return aimFireGunAtOriginal(murderer, burstOverride)
end

function aimFireGunAtOriginal(murderer, burstOverride)
	local shoot = aimGetShootRemote()
	if not shoot then return false end
	if not (murderer and murderer.Character) then return false end
	local shots = math.max(1, burstOverride or AIM_CONFIG.shotsPerClick)
	local segHalf = AIM_CONFIG.pathSegHalf or 1.8
	local fracs = AIM_CONFIG.pathFanFracs or {0, 0.5, 1.0}
	local hitAny = false
	for i = 1, shots do
		if not aimMurdererAlive(murderer) then break end
		local char = murderer.Character
		if not char then break end
		-- FRESH data for every bullet
		local v = aimGetTargetVelocity(char)
		local hSpeed = math.sqrt(v.X * v.X + v.Z * v.Z)
		if hSpeed < 2 then
			-- STANDING target: exact spot + vertical bracket on the first bullet
			local center = aimPredictTorso(char, 0)
			if center then
				hitAny = aimFireOnce(shoot, center) or hitAny
				if i == 1 then
					hitAny = aimFireOnce(shoot, center + Vector3.new(0, 1.2, 0)) or hitAny
					hitAny = aimFireOnce(shoot, center - Vector3.new(0, 1.0, 0)) or hitAny
				end
			end
		else
			local moveDir = Vector3.new(v.X, 0, v.Z).Unit
			-- Fan point along the predicted path, swept as a segment ray
			local frac = fracs[((i - 1) % #fracs) + 1]
			local pt = aimPredictTorso(char, frac)
			if pt then
				hitAny = aimFireOnce(shoot, pt + moveDir * segHalf, pt - moveDir * segHalf) or hitAny
			end
			if i == 1 then
				-- Full-path sweep: one ray from the CURRENT position through past
				-- the full-lead point — covers the entire uncertainty window even
				-- when the ping-based lead estimate is completely wrong.
				local cur = aimPredictTorso(char, 0)
				local lead = aimPredictTorso(char, 1.45)
				if cur and lead then
					hitAny = aimFireOnce(shoot, lead + moveDir * segHalf, cur - moveDir * segHalf) or hitAny
				end
				-- Vertical bracket at the full-lead point (jump / crouch mid-run)
				local center = aimPredictTorso(char, 1)
				if center then
					hitAny = aimFireOnce(shoot, center + Vector3.new(0, 1.2, 0) + moveDir * segHalf,
						center + Vector3.new(0, 1.2, 0) - moveDir * segHalf) or hitAny
					hitAny = aimFireOnce(shoot, center - Vector3.new(0, 1.0, 0) + moveDir * segHalf,
						center - Vector3.new(0, 1.0, 0) - moveDir * segHalf) or hitAny
				end
			end
			if i == shots then
				-- Light scatter around the full-lead point, each also swept along
				-- the path — covers sudden strafe direction changes
				local center = aimPredictTorso(char, 1)
				if center then
					local extras = aimScatterPositions(center)
					for j = 2, #extras do
						hitAny = aimFireOnce(shoot, extras[j] + moveDir * segHalf, extras[j] - moveDir * segHalf) or hitAny
					end
				end
			end
		end
		-- Spread the burst across frames: each following bullet re-predicts with
		-- fresh replicated data instead of repeating one stale snapshot.
		if i < shots then RunService.Heartbeat:Wait() end
	end
	return hitAny
end

-- Red dot on the current murderer (same aim indicator as the standalone script)
local function aimCreateTargetDot()
	if aimTargetDot then aimTargetDot:Destroy() end
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "AimTargetDot"
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.new(0, 8, 0, 8)
	billboard.MaxDistance = math.huge
	local dot = Instance.new("Frame")
	dot.Size = UDim2.new(1, 0, 1, 0)
	dot.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	dot.BorderSizePixel = 0
	dot.BackgroundTransparency = 1
	dot.Parent = billboard
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = dot
	aimTargetDot = billboard
	return billboard
end

local function aimUpdateTargetDot()
	local murderer = aimFindMurderer()
	if murderer == player then murderer = nil end
	if murderer and murderer.Character then
		local torso = murderer.Character:FindFirstChild("Torso") or murderer.Character:FindFirstChild("UpperTorso")
		if torso then
			if not aimTargetDot or not aimTargetDot.Parent then
				aimCreateTargetDot()
				aimTargetDot.Parent = torso
			elseif aimTargetDot.Parent ~= torso then
				aimTargetDot.Parent = torso
			end
		else
			if aimTargetDot then aimTargetDot:Destroy(); aimTargetDot = nil end
		end
	else
		if aimTargetDot then aimTargetDot:Destroy(); aimTargetDot = nil end
	end
end

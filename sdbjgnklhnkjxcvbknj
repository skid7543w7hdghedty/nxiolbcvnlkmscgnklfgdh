function autoTpToTarget()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	if autoTpTarget == 1 then
		hrp.CFrame = CFrame.new(23, 505, -34)
		notify("Auto TP", "Teleported to Lobby", 2)
	elseif autoTpTarget == 2 then
		hrp.CFrame = CFrame.new(14, 507, 35)
		notify("Auto TP", "Teleported to VoteMap", 2)
	elseif autoTpTarget == 3 then
		for mapName, coords in pairs(tpAboveMapCoords) do
			if Workspace:FindFirstChild(mapName) then
				local targetCF = CFrame.new(coords)
				for i = 1, 10 do
					hrp.CFrame = targetCF
					char:SetPrimaryPartCFrame(targetCF)
					hrp.Velocity = Vector3.new(0, 0, 0)
					hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					hrp.RotVelocity = Vector3.new(0, 0, 0)
				end
				local fixConn
				fixConn = RunService.Heartbeat:Connect(function()
					hrp.CFrame = targetCF
					hrp.Velocity = Vector3.new(0, 0, 0)
					hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					fixConn:Disconnect()
				end)
				notify("Auto TP", "Teleported Above Map", 2)
				return
			end
		end
		notify("Auto TP", "No map found", 2)
	elseif autoTpTarget == 4 then
		voidTpPreviousPos = hrp.CFrame
		hrp.CFrame = CFrame.new(voidBaseplatePos.X, voidBaseplatePos.Y + 1, voidBaseplatePos.Z)
		notify("Auto TP", "Teleported to Void", 2)
	end
end

function toggleAutoTp()
	if not autoTpBtn then return end
	autoTpEnabled = not autoTpEnabled
	if autoTpEnabled then
		autoTpBtn.Text = "Auto TP: ON"
		autoTpBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		autoTpBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
		autoTpActive = false
		autoTpFrame = 0
		autoTpConnection = RunService.Heartbeat:Connect(function()
			if not autoTpEnabled then return end
			autoTpFrame = autoTpFrame + 1
			if autoTpFrame % 45 ~= 0 then return end
			local murdererPos = getMurdererPosition()
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			local inZone = false
			if murdererPos then
				local dist = (hrp.Position - murdererPos).Magnitude
				if not autoTpActive and dist <= autoTpDist then
					inZone = true
				elseif autoTpActive and dist > autoTpDist then
					inZone = false
				else
					inZone = autoTpActive
				end
			end
			if inZone and not autoTpActive then
				autoTpActive = true
				autoTpToTarget()
			elseif not inZone and autoTpActive then
				autoTpActive = false
			end
		end)
	else
		autoTpBtn.Text = "Auto TP: OFF"
		autoTpBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		autoTpBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		if autoTpConnection then
			autoTpConnection:Disconnect()
			autoTpConnection = nil
		end
		autoTpActive = false
	end
	setExtractedBtnState("Auto TP", autoTpEnabled)
	saveConfig()
end


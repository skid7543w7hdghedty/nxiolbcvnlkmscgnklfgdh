function SkidFling(targetPlayer)
	local characterLocal = player.Character
	local humanoidLocal = characterLocal and characterLocal:FindFirstChildOfClass("Humanoid")
	local rootPartLocal = humanoidLocal and humanoidLocal.RootPart
	local targetCharacter = targetPlayer.Character
	if not targetCharacter then return end

	local targetHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid")
	local targetRootPart = targetHumanoid and targetHumanoid.RootPart
	local targetHead = targetCharacter:FindFirstChild("Head")
	local accessory = targetCharacter:FindFirstChildOfClass("Accessory")
	local handle = accessory and accessory:FindFirstChild("Handle")

	if not (characterLocal and humanoidLocal and rootPartLocal) then
		return notify("Error", "Your character is not ready", 2)
	end

	if rootPartLocal.Velocity.Magnitude < 50 then
		getgenv().OldPos = rootPartLocal.CFrame
	end

	if targetHumanoid and targetHumanoid.Sit then
		return notify("Error", targetPlayer.Name .. " is sitting", 2)
	end

	if targetHead then
		Workspace.CurrentCamera.CameraSubject = targetHead
	elseif handle then
		Workspace.CurrentCamera.CameraSubject = handle
	elseif targetHumanoid then
		Workspace.CurrentCamera.CameraSubject = targetHumanoid
	end

	if not targetCharacter:FindFirstChildWhichIsA("BasePart") then
		return
	end

	local function flingPos(basePart, offsetCFrame, angleCFrame)
		local cf = CFrame.new(basePart.Position) * offsetCFrame * angleCFrame
		rootPartLocal.CFrame = cf
		characterLocal:SetPrimaryPartCFrame(cf)
		rootPartLocal.Velocity = Vector3.new(9e7, 9e8, 9e7)
		rootPartLocal.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
		rootPartLocal.AssemblyLinearVelocity = Vector3.new(9e7, 9e8, 9e7)
		rootPartLocal.AssemblyAngularVelocity = Vector3.new(9e8, 9e8, 9e8)
		pcall(sethiddenproperty, rootPartLocal, "PhysicsRepRootPart", basePart)
	end

	local function flingBasePart(basePart)
		local endTime = tick() + 2
		local angle = 0
		repeat
			if rootPartLocal and targetHumanoid then
				if basePart.Velocity.Magnitude < 50 then
					angle += 100
					flingPos(basePart, CFrame.new(0, 1.5, 0) + targetHumanoid.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, -1.5, 0) + targetHumanoid.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle), 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, 1.5, 0) + targetHumanoid.MoveDirection, CFrame.Angles(math.rad(angle), 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, -1.5, 0) + targetHumanoid.MoveDirection, CFrame.Angles(math.rad(angle), 0, 0))
					task.wait()
				else
					flingPos(basePart, CFrame.new(0, 1.5, targetHumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, -1.5, -targetHumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
					task.wait()
					flingPos(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
					task.wait()
				end
			end
		until tick() > endTime or not flingActive
	end

	Workspace.FallenPartsDestroyHeight = 0 / 0

	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Parent = rootPartLocal
	bodyVelocity.Velocity = Vector3.zero
	bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)

	humanoidLocal:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

	if targetRootPart then
		flingBasePart(targetRootPart)
	elseif targetHead then
		flingBasePart(targetHead)
	elseif handle then
		flingBasePart(handle)
	else
		bodyVelocity:Destroy()
		humanoidLocal:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
		Workspace.CurrentCamera.CameraSubject = humanoidLocal
		pcall(sethiddenproperty, rootPartLocal, "PhysicsRepRootPart", rootPartLocal)
		return notify("Error", targetPlayer.Name .. " has no valid parts", 2)
	end

	bodyVelocity:Destroy()
	humanoidLocal:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
	Workspace.CurrentCamera.CameraSubject = humanoidLocal
	pcall(sethiddenproperty, rootPartLocal, "PhysicsRepRootPart", rootPartLocal)

	if getgenv().OldPos then
		repeat
			rootPartLocal.CFrame = getgenv().OldPos * CFrame.new(0, 0.5, 0)
			characterLocal:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, 0.5, 0))
			humanoidLocal:ChangeState("GettingUp")
			for _, part in ipairs(characterLocal:GetChildren()) do
				if part:IsA("BasePart") then
					part.Velocity = Vector3.zero
					part.RotVelocity = Vector3.zero
					part.AssemblyLinearVelocity = Vector3.zero
					part.AssemblyAngularVelocity = Vector3.zero
				end
			end
			task.wait()
		until (rootPartLocal.Position - getgenv().OldPos.Position).Magnitude < 25 or not flingActive
		Workspace.FallenPartsDestroyHeight = getgenv().FPDH
	end
end

function startFling()
	if flingActive then return end
	local count = countSelectedTargets()
	if count == 0 then
		if multiFlingStatusLabel then
			multiFlingStatusLabel.Text = "No targets selected!"
			multiFlingStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			task.delay(1, updateFlingStatus)
		end
		return
	end

	flingActive = true
	updateFlingStatus()
	notify("Started", "Flinging " .. count .. " targets", 2)

	task.spawn(function()
		while flingActive do
			local validTargets = {}
			for name, plr in pairs(selectedTargets) do
				if plr and plr.Parent then
					validTargets[name] = plr
				else
					selectedTargets[name] = nil
					local checkboxData = playerCheckboxes[name]
					if checkboxData then
						checkboxData.Checkmark.Visible = false
					end
				end
			end

			for _, plr in pairs(validTargets) do
				if not flingActive then break end
				SkidFling(plr)
				task.wait(0.1)
			end

			updateFlingStatus()
			task.wait(0.5)
		end
	end)
end

function stopFling()
	if not flingActive then return end
	flingActive = false
	updateFlingStatus()
	notify("Stopped", "Fling has been stopped", 2)
end

function startLoopFling()
	if loopFlingActive then return end
	local count = countSelectedTargets()
	if count == 0 then
		if multiFlingStatusLabel then
			multiFlingStatusLabel.Text = "No targets selected!"
			multiFlingStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			task.delay(1, updateFlingStatus)
		end
		return
	end
	if count > 1 then
		if multiFlingStatusLabel then
			multiFlingStatusLabel.Text = "LoopFling: Only 1 target allowed!"
			multiFlingStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
			task.delay(1, updateFlingStatus)
		end
		return
	end

	loopFlingActive = true
	updateFlingStatus()
	notify("LoopFling Started", "Continuous flinging enabled", 2)

	loopFlingThread = task.spawn(function()
		while loopFlingActive do
			local validTargets = {}
			for name, plr in pairs(selectedTargets) do
				if plr and plr.Parent then
					validTargets[name] = plr
				else
					selectedTargets[name] = nil
					local checkboxData = playerCheckboxes[name]
					if checkboxData then
						checkboxData.Checkmark.Visible = false
					end
				end
			end

			for _, plr in pairs(validTargets) do
				if not loopFlingActive then break end
				SkidFling(plr)
			end

			updateFlingStatus()
			task.wait()
		end
	end)
end

function stopLoopFling()
	if not loopFlingActive then return end
	loopFlingActive = false
	if loopFlingThread then
		task.cancel(loopFlingThread)
		loopFlingThread = nil
	end
	updateFlingStatus()
	notify("LoopFling Stopped", "Continuous flinging disabled", 2)
end

function stopCurrentAnimation()
	if animationTrack then
		animationTrack:Stop()
		animationTrack = nil
	end
	if playingAnimationId ~= 0 and animationUiById[playingAnimationId] then
		animationUiById[playingAnimationId].Button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		animationUiById[playingAnimationId].Button.TextColor3 = Color3.fromRGB(255, 255, 255)
	end
	playingAnimationId = 0
	if updateAllDetachedEmoteVisuals then updateAllDetachedEmoteVisuals() end
end

function playAnimation(animationId, speedValue)
	local currentCharacter = player.Character
	if not currentCharacter then return end
	local currentHumanoid = currentCharacter:FindFirstChildOfClass("Humanoid")
	if not currentHumanoid then return end

	stopCurrentAnimation()
	animationObject.AnimationId = "rbxassetid://" .. tostring(animationId)
	animationTrack = currentHumanoid:LoadAnimation(animationObject)
	animationTrack.Looped = true
	animationTrack.Priority = Enum.AnimationPriority.Action
	animationTrack:Play()
	animationTrack:AdjustSpeed(tonumber(speedValue) or 1)
	playingAnimationId = animationId

	if animationUiById[animationId] then
		animationUiById[animationId].Button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		animationUiById[animationId].Button.TextColor3 = Color3.fromRGB(0, 0, 0)
	end
	if updateAllDetachedEmoteVisuals then updateAllDetachedEmoteVisuals() end
end

-- ============================================
-- Detached emote buttons (выносимые кнопки эмоций)
-- A star toggle (☆/★) on each emote row pops that emote out as a small draggable
-- on-screen button, so emotes like Take the L, Dahood Stomp, etc. can be played
-- without opening the menu. Position + which emotes are detached are saved to the
-- config and restored on the next load.
-- ============================================
detachedEmotes = {}

function isEmoteDetached(animationId)
	return detachedEmotes[animationId] ~= nil
end

function updateDetachedEmoteVisual(animationId)
	local d = detachedEmotes[animationId]
	if not d or not d.btn then return end
	if playingAnimationId == animationId then
		d.btn.BackgroundColor3 = extractedBtnActiveBgColor
		d.btn.TextColor3 = extractedBtnActiveTextColor
	else
		d.btn.BackgroundColor3 = extractedBtnBgColor
		d.btn.TextColor3 = extractedBtnTextColor
	end
end

function updateAllDetachedEmoteVisuals()
	for id in pairs(detachedEmotes) do
		updateDetachedEmoteVisual(id)
	end
end

function removeDetachedEmote(animationId, skipSave)
	local d = detachedEmotes[animationId]
	if not d then return end
	if d.conns then
		for _, c in ipairs(d.conns) do pcall(function() c:Disconnect() end) end
	end
	if d.frame then d.frame:Destroy() end
	detachedEmotes[animationId] = nil
	local ui = animationUiById[animationId]
	if ui and ui.PopOut then ui.PopOut.Text = "☆" end
	if not skipSave then pcall(saveConfig) end
end

function createDetachedEmote(animationId, animationName, savedPos, skipSave, savedLocked)
	if not popupBtnGui then return end
	if detachedEmotes[animationId] then return end
	local ui = animationUiById[animationId]
	animationName = animationName or (ui and ui.Name) or "Emote"

	-- Built with the exact same anatomy as the other extracted buttons (border frame +
	-- inner TextScaled button + U/L lock button) so the "Popup Button Size" controls
	-- resize it too and it matches their look.
	local frame = Instance.new("Frame")
	frame.Name = "DetachedEmote_" .. tostring(animationId)
	frame.Size = UDim2.new(0, popupBtnWidth, 0, popupBtnHeight)
	if savedPos then
		frame.Position = UDim2.new(savedPos.X.Scale, savedPos.X.Offset, savedPos.Y.Scale, savedPos.Y.Offset)
	else
		local n = 0
		for _ in pairs(detachedEmotes) do n = n + 1 end
		frame.Position = UDim2.new(0, 140, 0, 120 + n * (popupBtnHeight + 6))
	end
	frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	frame.BackgroundTransparency = 1
	frame.BorderSizePixel = 0
	frame.Parent = popupBtnGui

	local borderStroke = Instance.new("UIStroke")
	borderStroke.Color = Color3.fromRGB(255, 255, 255)
	borderStroke.Thickness = 1.5
	borderStroke.Parent = frame

	local borderCorner = Instance.new("UICorner")
	borderCorner.CornerRadius = UDim.new(0, 6)
	borderCorner.Parent = frame

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -30, 1, -4)
	btn.Position = UDim2.new(0, 2, 0, 2)
	btn.BackgroundColor3 = extractedBtnBgColor
	btn.BackgroundTransparency = popupBgTransparency
	btn.TextColor3 = extractedBtnTextColor
	btn.Text = animationName
	btn.Font = Enum.Font.SourceSansBold
	btn.TextScaled = true
	btn.AutoButtonColor = false
	btn.BorderSizePixel = 0
	btn.ClipsDescendants = true
	btn.Parent = frame
	if addBtnPressAnim then addBtnPressAnim(btn) end
	local btnTSC = Instance.new("UITextSizeConstraint")
	btnTSC.MaxTextSize = 17
	btnTSC.MinTextSize = 9
	btnTSC.Parent = btn

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn

	local lockBtn = Instance.new("TextButton")
	lockBtn.Size = UDim2.new(0, 22, 0, 22)
	lockBtn.Position = UDim2.new(1, -27, 0.5, -11)
	lockBtn.BackgroundColor3 = extractedBtnBgColor
	lockBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	lockBtn.Text = "U"
	lockBtn.Font = Enum.Font.SourceSansBold
	lockBtn.TextSize = 12
	lockBtn.AutoButtonColor = false
	lockBtn.BorderSizePixel = 0
	lockBtn.Parent = frame

	local lockCorner = Instance.new("UICorner")
	lockCorner.CornerRadius = UDim.new(0, 4)
	lockCorner.Parent = lockBtn

	local d = { frame = frame, btn = btn, popupBtn = btn, popupLockBtn = lockBtn, name = animationName, conns = {} }
	detachedEmotes[animationId] = d

	if savedLocked then
		lockBtn.Text = "L"
		lockBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
	end

	lockBtn.MouseButton1Click:Connect(function()
		if lockBtn.Text == "L" then
			lockBtn.Text = "U"
			lockBtn.BackgroundColor3 = extractedBtnBgColor
		else
			lockBtn.Text = "L"
			lockBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
		end
		pcall(saveConfig)
	end)

	local dragging, moved, justDragged, startPos, framePos, dragIpt = false, false, false, nil, nil, nil
	-- Drag handlers live on the inner button so the whole pill can be moved by holding
	-- it (important on touch screens). The U/L button locks dragging exactly like the
	-- other extracted buttons. A small threshold + justDragged flag keeps a normal tap
	-- playing the emote and stops a drag from triggering it.
	table.insert(d.conns, btn.InputBegan:Connect(function(ipt)
		if popupDragLocked or lockBtn.Text == "L" then return end
		if ipt.UserInputType == Enum.UserInputType.MouseButton1 or ipt.UserInputType == Enum.UserInputType.Touch then
			dragging = true; moved = false; startPos = ipt.Position; framePos = frame.Position; dragIpt = ipt
		end
	end))
	table.insert(d.conns, btn.InputChanged:Connect(function(ipt)
		if ipt.UserInputType == Enum.UserInputType.MouseMovement or ipt.UserInputType == Enum.UserInputType.Touch then
			dragIpt = ipt
		end
	end))
	table.insert(d.conns, UserInputService.InputChanged:Connect(function(ipt)
		if popupDragLocked or lockBtn.Text == "L" then return end
		if ipt == dragIpt and dragging then
			local delta = ipt.Position - startPos
			if delta.Magnitude >= 5 then moved = true end
			if moved then
				frame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
			end
		end
	end))
	table.insert(d.conns, btn.InputEnded:Connect(function(ipt)
		if ipt.UserInputType == Enum.UserInputType.MouseButton1 or ipt.UserInputType == Enum.UserInputType.Touch then
			local wasDragged = moved
			dragging = false; moved = false; dragIpt = nil
			justDragged = wasDragged
			if wasDragged then pcall(saveConfig) end
		end
	end))

	btn.MouseButton1Click:Connect(function()
		if justDragged then justDragged = false; return end
		if playingAnimationId == animationId then
			stopCurrentAnimation()
		else
			local spd = (animationUiById[animationId] and animationUiById[animationId].Box and animationUiById[animationId].Box.Text) or "1"
			playAnimation(animationId, spd)
		end
		updateDetachedEmoteVisual(animationId)
	end)

	if ui and ui.PopOut then ui.PopOut.Text = "★" end
	updateDetachedEmoteVisual(animationId)
	if not skipSave then pcall(saveConfig) end
end



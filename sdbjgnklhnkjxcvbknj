function keyCodeToName(keyCode)
	if keyNameMap[keyCode] then return keyNameMap[keyCode] end
	local name = tostring(keyCode):gsub("Enum.KeyCode.", "")
	return name
end

function bindKeyToName(key)
	if typeof(key) == "EnumItem" then
		if key.EnumType == Enum.KeyCode then
			return keyCodeToName(key)
		elseif key == Enum.UserInputType.MouseButton1 then
			return "LMB"
		elseif key == Enum.UserInputType.MouseButton2 then
			return "RMB"
		elseif key == Enum.UserInputType.MouseButton3 then
			return "MMB"
		end
	end
	return tostring(key)
end


				textBtn.Font = Enum.Font.Code
				textBtn.TextSize = 22
				textBtn.AutoButtonColor = false
				textBtn.BorderSizePixel = 0
				textBtn.Parent = popupBorder

				local btnCorner = Instance.new("UICorner")
				btnCorner.CornerRadius = UDim.new(0, 6)
				btnCorner.Parent = textBtn

				data.popupBtn = textBtn
				data.dragConn = fpsPingMakeDraggable(textBtn)
			end

			extractedButtons[feature.name] = data
			return

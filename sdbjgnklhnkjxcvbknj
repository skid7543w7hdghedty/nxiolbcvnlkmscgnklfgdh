-- Auto Shot loop: on gun pickup fires ONE instant full burst, then keeps firing
-- rate-limited bursts (autoShotCooldown between them, autoShotBurst shots each).
-- The old version fired a full 6-shot burst EVERY heartbeat (~300-400 FireServer
-- calls per second) which flooded the network queue and lagged the whole game.
local aimHadGunLast = false
local aimLastRoleRefresh = 0
local aimLastAutoShotAt = 0
task.spawn(function()
	while true do
		RunService.Heartbeat:Wait()
		pcall(function()
			if not aimAutoShotEnabled then aimHadGunLast = false; return end
			local char = player.Character
			local bp = player:FindFirstChild("Backpack")
			local hasGun = (char and (char:FindFirstChild("Gun") or (bp and bp:FindFirstChild("Gun")))) and true or false
			if hasGun and not aimHadGunLast then
				-- Gun just appeared: instant FULL burst fire (no waiting for cooldown)
				aimRefreshRoleNow()
				local m = aimFindMurderer()
				if m and m ~= player and aimMurdererAlive(m) then
					aimLastAutoShotAt = os.clock()
					aimFireGunAt(m)
				end
			end
			aimHadGunLast = hasGun
			if not hasGun then return end
			local now = os.clock()
			-- Rate limit: skip this heartbeat entirely while on cooldown (also skips
			-- the murderer lookup, keeping the loop nearly free between bursts)
			if (now - aimLastAutoShotAt) < (AIM_CONFIG.autoShotCooldown or 0.35) then return end
			local murderer = aimFindMurderer()
			if not murderer and (now - aimLastRoleRefresh) > 0.08 then
				aimLastRoleRefresh = now
				aimRefreshRoleNow()
				murderer = aimFindMurderer()
			end
			if murderer and murderer ~= player and aimMurdererAlive(murderer) then
				aimLastAutoShotAt = now
				aimFireGunAt(murderer, AIM_CONFIG.autoShotBurst)
			end
		end)
	end
end)


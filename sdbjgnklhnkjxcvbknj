-- Auto Remove GlitchProof (always on)
-- ============================================
function removeGlitchProof()
	local mansion = Workspace:FindFirstChild("Mansion2")
	if mansion then
		local base = mansion:FindFirstChild("Base")
		if base then
			local glitch = base:FindFirstChild("GlitchProof")
			if glitch then
				glitch:Destroy()
			end
		end
	end
end

-- Удаляем при запуске
removeGlitchProof()

-- Отслеживаем появление Mansion2
Workspace.ChildAdded:Connect(function(child)
	if child.Name == "Mansion2" then
		task.wait(1)
		removeGlitchProof()
		-- Также следим за появлением Base внутри
		child.DescendantAdded:Connect(function(desc)
			if desc.Name == "GlitchProof" then
				task.defer(function()
					if desc and desc.Parent then
						desc:Destroy()
					end
				end)
			end
		end)
	end
end)

-- Если Mansion2 уже есть — следим за новыми GlitchProof
local existingMansion = Workspace:FindFirstChild("Mansion2")
if existingMansion then
	existingMansion.DescendantAdded:Connect(function(desc)
		if desc.Name == "GlitchProof" then
			task.defer(function()
				if desc and desc.Parent then
					desc:Destroy()
				end
			end)
		end
	end)
end

-- Периодическая проверка на всякий случай
task.spawn(function()
	while true do
		task.wait(5)
		removeGlitchProof()
	end
end)

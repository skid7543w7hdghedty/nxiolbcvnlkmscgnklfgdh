local function findBgFiles()
	local images = {}
	local ok, files = pcall(function() return listfiles(MAIN_DIR) end)
	if ok then
		for _, path in ipairs(files) do
			local lower = string.lower(path)
			if lower:match("%.png$") or lower:match("%.jpg$") or lower:match("%.jpeg$") then
				table.insert(images, path)
			end
		end
	end
	return images
end


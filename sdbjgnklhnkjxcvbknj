		-- Auto TP runs FIRST (before any reset kills the character); the kill-all
		-- remote and the predicted piercer shot both work from any position.
		autofarmDoEndTeleport()
		local role = autofarmGetMyRole()
		if role == "Murderer" then
			autofarmFinishMurderer()
		elseif role == "Sheriff" or role == "Hero" then
			autofarmFinishSheriff()
		else
			-- Innocent: if we picked up the gun, shoot the murderer (piercer toggle
			-- controls wallbang mode only). Then reset if the toggle is on.
			if autofarmHasGun() then
				autofarmShootMurderer(autofarmShootPiercerEnabled)
			end
			autofarmFinishInnocent()
		end
	end)
end


local function cycleMode()
	currentMode = (currentMode + 1) % 5
	running = false

	if currentMode ~= 0 then
		scriptCoroutine = coroutine.create(scripts[currentMode])
		running = true
		coroutine.resume(scriptCoroutine)
	end

	updateAntiAimButtonVisual()
end


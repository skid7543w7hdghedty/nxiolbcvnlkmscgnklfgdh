-- AutoDodge (Jump Dodge)
-- ============================================================
autoDodgeEnabled = false
autoDodgeConnection = nil
autoDodgeDiedConnection = nil
autoDodgeCharAddedConn = nil
autoDodgeLastDodge = 0
autoDodgeCooldown = 0.1
autoDodgeShift = 10
autoDodgeWallCheck = 10

function autoDodgeCheckWall(origin, direction)
	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {player.Character}
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	local result = Workspace:Raycast(origin, direction * autoDodgeWallCheck, rayParams)
	return result ~= nil
end

function autoDodgePerform()
	if tick() - autoDodgeLastDodge < autoDodgeCooldown then return end
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum or hum.Health <= 0 then return end

	local origin = hrp.Position
	local rightVec = hrp.CFrame.RightVector

	local wallRight = autoDodgeCheckWall(origin, rightVec)
	local wallLeft = autoDodgeCheckWall(origin, -rightVec)

	local dodgeDir
	if not wallRight and not wallLeft then
		dodgeDir = (math.random(0, 1) == 0) and rightVec or -rightVec
	elseif not wallRight then
		dodgeDir = rightVec
	elseif not wallLeft then
		dodgeDir = -rightVec
	else
		return
	end

	local originalCF = hrp.CFrame
	local dodgePos = origin + dodgeDir * autoDodgeShift
	hrp.CFrame = CFrame.new(dodgePos) * (originalCF - originalCF.Position)
	hrp.AssemblyLinearVelocity = Vector3.zero
	autoDodgeLastDodge = tick()

	task.delay(0.45, function()
		if hrp and hrp.Parent then
			hrp.CFrame = originalCF
			hrp.AssemblyLinearVelocity = Vector3.zero
		end
	end)
end

function setupAutoDodge()
	if autoDodgeConnection then
		autoDodgeConnection:Disconnect()
		autoDodgeConnection = nil
	end
	if autoDodgeDiedConnection then
		autoDodgeDiedConnection:Disconnect()
		autoDodgeDiedConnection = nil
	end
	if autoDodgeCharAddedConn then
		autoDodgeCharAddedConn:Disconnect()
		autoDodgeCharAddedConn = nil
	end
	if not autoDodgeEnabled then return end

	autoDodgeConnection = UserInputService.JumpRequest:Connect(function()
		if autoDodgeEnabled then
			autoDodgePerform()
		end
	end)

	local function onCharAdded(char)
		char:WaitForChild("Humanoid", 10)
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			autoDodgeDiedConnection = hum.Died:Connect(function()
				if autoDodgeConnection then
					autoDodgeConnection:Disconnect()
					autoDodgeConnection = nil
				end
			end)
		end
	end

	if player.Character then
		onCharAdded(player.Character)
	end
	autoDodgeCharAddedConn = player.CharacterAdded:Connect(onCharAdded)
end

function toggleAutoDodge()
	autoDodgeEnabled = not autoDodgeEnabled
	setupAutoDodge()
end


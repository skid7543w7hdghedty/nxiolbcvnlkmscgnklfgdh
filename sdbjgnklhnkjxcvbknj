-- Air Strafe functions
function checkStrafeSequence(keyCode)
	if not airStrafeEnabled then return end
	local currentTime = tick()
	if keyCode == Enum.KeyCode.A or keyCode == Enum.KeyCode.D then
		if lastKey and lastKey ~= keyCode and (currentTime - lastKeyTime) <= strafeInterval then
			isStrafing = true
			task.delay(strafeInterval, function()
				isStrafing = false
			end)
		end
		lastKey = keyCode
		lastKeyTime = currentTime
	end
end

function setupAirStrafe()
	if airStrafeConnection then
		airStrafeConnection:Disconnect()
		airStrafeConnection = nil
	end
	if airStrafeInputConnection then
		airStrafeInputConnection:Disconnect()
		airStrafeInputConnection = nil
	end

	if not airStrafeEnabled then return end

	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChild("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not (hum and hrp) then return end

	airStrafeInputConnection = UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.D then
			checkStrafeSequence(input.KeyCode)
		end
	end)

	airStrafeConnection = RunService.Heartbeat:Connect(function()
		if not airStrafeEnabled then return end
		local c = player.Character
		if not c then return end
		local h = c:FindFirstChild("Humanoid")
		local r = c:FindFirstChild("HumanoidRootPart")
		if not (h and r) then return end
		local state = h:GetState()
		if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
			if isStrafing then
				local moveDir = Vector3.new(0, 0, 0)
				if UserInputService:IsKeyDown(Enum.KeyCode.A) then
					moveDir = moveDir + Vector3.new(-1, 0, 0)
				end
				if UserInputService:IsKeyDown(Enum.KeyCode.D) then
					moveDir = moveDir + Vector3.new(1, 0, 0)
				end
				if moveDir.Magnitude > 0 then
					moveDir = moveDir.Unit
					local cameraCFrame = Workspace.CurrentCamera.CFrame
					moveDir = cameraCFrame:VectorToWorldSpace(moveDir)
					moveDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
					local vel = r.Velocity
					r.Velocity = Vector3.new(
						moveDir.X * maxAirSpeed * airStrafeMultiplier,
						vel.Y,
						moveDir.Z * maxAirSpeed * airStrafeMultiplier
					)
				end
			end
		end
	end)

	local diedConn
	diedConn = hum.Died:Connect(function()
		if airStrafeConnection then
			airStrafeConnection:Disconnect()
			airStrafeConnection = nil
		end
		if airStrafeInputConnection then
			airStrafeInputConnection:Disconnect()
			airStrafeInputConnection = nil
		end
		if diedConn then
			diedConn:Disconnect()
			diedConn = nil
		end
	end)
end

function toggleAirStrafe()
	airStrafeEnabled = not airStrafeEnabled
	setupAirStrafe()
end


function espIsAlive(plr)
	if not plr then return false end
	local char = plr.Character
	if char then
		local attr = char:GetAttribute("Alive")
		if attr ~= nil then return attr end
	end
	local data = espRoles and espRoles[plr.Name]
	if data then
		return not data.Killed and not data.Dead
	end
	return false
end


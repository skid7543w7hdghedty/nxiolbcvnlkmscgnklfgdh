-- Murderer: kill everyone at the end of the farm, then reset
function autofarmFinishMurderer()
	if autofarmKillAllEnabled then
		for _ = 1, 3 do
			local alive = 0
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and plr.Character then
					local h = plr.Character:FindFirstChildOfClass("Humanoid")
					if h and h.Health > 0 then alive += 1 end
				end
			end
			if alive == 0 then break end
			pcall(doKillEveryone, false)
			task.wait(0.3)
		end
	end
	if autofarmResetMurdererEnabled then
		autofarmResetSelf()
	end

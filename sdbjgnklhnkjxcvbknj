function createClumsyGhost(position)
	removeClumsyGhost()
	local char = player.Character
	if not char then return end

	local ghost = Instance.new("Model")
	ghost.Name = "ClumsyGhost"

	for _, part in pairs(char:GetChildren()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			local clone = part:Clone()
			clone.CanCollide = false
			clone.Anchored = true
			clone.Transparency = 0.6
			clone.Material = Enum.Material.ForceField
			clone.Color = Color3.fromRGB(150, 0, 255)
			-- Убираем всё лишнее из клона
			for _, child in pairs(clone:GetChildren()) do
				if not child:IsA("SpecialMesh") and not child:IsA("DataModelMesh") then
					child:Destroy()
				end
			end
			clone.Parent = ghost
		end
	end

	-- Копируем аксессуары
	for _, acc in pairs(char:GetChildren()) do
		if acc:IsA("Accessory") then
			local handle = acc:FindFirstChild("Handle")
			if handle then
				local clone = handle:Clone()
				clone.CanCollide = false
				clone.Anchored = true
				clone.Transparency = 0.6
				clone.Material = Enum.Material.ForceField
				clone.Color = Color3.fromRGB(150, 0, 255)
				for _, child in pairs(clone:GetChildren()) do
					if not child:IsA("SpecialMesh") and not child:IsA("DataModelMesh") and not child:IsA("StringValue") then
						child:Destroy()
					end
				end
				clone.Name = acc.Name .. "_Handle"
				clone.Parent = ghost
			end
		end
	end

	-- Добавляем билборд с текстом
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "GhostLabel"
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.new(0, 150, 0, 30)
	billboard.StudsOffset = Vector3.new(0, 3.5, 0)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = "Server Position"
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.TextColor3 = Color3.fromRGB(150, 0, 255)
	label.TextStrokeTransparency = 0.5
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.Parent = billboard

	-- Позиционируем части призрака
	local charCF = CFrame.new(position)
	for _, part in pairs(ghost:GetChildren()) do
		if part:IsA("BasePart") then
			local originalPart = char:FindFirstChild(part.Name)
			if originalPart and originalPart:IsA("BasePart") then
				local offset = char.HumanoidRootPart.CFrame:ToObjectSpace(originalPart.CFrame)
				part.CFrame = charCF * offset
			end
		end
	end

	-- Билборд на голову призрака
	local ghostHead = ghost:FindFirstChild("Head")
	if ghostHead then
		billboard.Adornee = ghostHead
		billboard.Parent = ghostHead
	end

	-- Highlight чтобы было видно через стены
	local ghostHighlight = Instance.new("Highlight")
ghostHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
ghostHighlight.FillTransparency = 0
ghostHighlight.OutlineTransparency = 0
ghostHighlight.FillColor = Color3.fromRGB(170, 0, 255)
ghostHighlight.OutlineColor = Color3.fromRGB(220, 120, 255)
ghostHighlight.Enabled = true
	
	for _, p in ipairs(ghost:GetDescendants()) do
	if p:IsA("BasePart") then
		p.Material = Enum.Material.Neon
		p.Transparency = 0.15
		p.Color = Color3.fromRGB(170, 0, 255)
		p.CastShadow = false

		local adorn = Instance.new("BoxHandleAdornment")
		adorn.Name = "GhostWallBox"
		adorn.Adornee = p
		adorn.AlwaysOnTop = true
		adorn.ZIndex = 10
		adorn.Transparency = 0.35
		adorn.Color3 = Color3.fromRGB(170, 0, 255)
		adorn.Size = p.Size + Vector3.new(0.03, 0.03, 0.03)
		adorn.Parent = p
		table.insert(clumsyGhostAdornments, adorn)
	end
end

	ghost.Parent = workspace
	clumsyGhost = ghost
end


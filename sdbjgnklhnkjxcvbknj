-- Murderer check with caching
cachedIsMurderer = false
lastMurdererCheck = 0

function isPlayerMurderer()
	if tick() - lastMurdererCheck > 1.0 then
		lastMurdererCheck = tick()
		local ok, result = pcall(function()
			return ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
		end)
		if ok and result then
			for name, data in pairs(result) do
				if name == player.Name then
					cachedIsMurderer = (data.Role == "Murderer")
					return cachedIsMurderer
				end
			end
		end
		cachedIsMurderer = false
	end
	return cachedIsMurderer
end


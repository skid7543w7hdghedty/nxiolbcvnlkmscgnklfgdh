			ok, result = pcall(function()
				return game:HttpGetAsync("https://avatar.roblox.com/v1/users/" .. userId .. "/currently-wearing")
			end)
		end
		if ok and result then
			local body = result
			if type(result) == "table" and result.Body then
				body = result.Body
			end
			local ok2, data = pcall(function()
				return game:GetService("HttpService"):JSONDecode(body)
			end)
			if ok2 and data and data.assetIds then
				for _, aid in ipairs(data.assetIds) do
					local s, info = pcall(function()
						return game:GetService("MarketplaceService"):GetProductInfo(aid)
					end)
					if s and info and info.PriceInRobux ~= nil then
						total = total + math.max(info.PriceInRobux, 0)
						found = true
					end
				end
			end
		end

		-- Method 2: collectibles RAP
		local ok3, result3 = pcall(function()
			return (syn or _G).request({
				Url = "https://inventory.roblox.com/v1/users/" .. userId .. "/assets/collectibles?sortOrder=Asc&limit=100",
				Method = "GET"
			})
		end)
		if not (ok3 and result3 and result3.StatusCode == 200) then
			ok3, result3 = pcall(function()
				return game:HttpGetAsync("https://inventory.roblox.com/v1/users/" .. userId .. "/assets/collectibles?sortOrder=Asc&limit=100")
			end)
		end
		if ok3 and result3 then
			local body3 = result3
			if type(result3) == "table" and result3.Body then
				body3 = result3.Body
			end
			local ok4, inv = pcall(function()
				return game:GetService("HttpService"):JSONDecode(body3)
			end)

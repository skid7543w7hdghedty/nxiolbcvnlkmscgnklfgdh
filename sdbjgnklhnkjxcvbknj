function addBtnPressAnim(btn)
	local btnScale = Instance.new("UIScale")
	btnScale.Parent = btn
	btn.MouseButton1Down:Connect(function()
		if not btnPressAnimationEnabled then return end
		local tween = TweenService:Create(btnScale, TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.93})
		tween:Play()
	end)
	btn.MouseButton1Up:Connect(function()
		if not btnPressAnimationEnabled then return end
		local tween = TweenService:Create(btnScale, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
		tween:Play()
	end)
	btn.MouseLeave:Connect(function()
		local tween = TweenService:Create(btnScale, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
		tween:Play()
	end)
end

function createCategoryButton(shortName, layoutOrder)
	-- Map short names to full names
	fullNames = {
		["Mvmt"] = "Movement",
		["Cmbt"] = "Combat",
		["Sher"] = "Sheriff",
		["Murd"] = "Murderer",
		["Rst"] = "Reset",
		["Trl"] = "Trolling",
		["Tele"] = "Teleports",
		["Util"] = "Utilities",
		["Team"] = "Teamers",
		["Scam"] = "Scammers",
		["Farm"] = "Autofarm",
		["Anim"] = "Animations",
		["Bind"] = "Binds",
		["Expl"] = "Exploiters",
		["Main"] = "Main",
		["Btn"] = "Buttons",
		["Set"] = "Settings"
	}
	local fullName = fullNames[shortName] or shortName
	
	local btn = Instance.new("TextButton")
	btn.Name = fullName .. "CatBtn"
	btn.Size = UDim2.new(1, 0, 0, 36)
	btn.BackgroundColor3 = tabBgColor
	btn.TextColor3 = tabTextColor
	btn.Text = fullName
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 10
	btn.AutoButtonColor = false
	if layoutOrder then btn.LayoutOrder = layoutOrder end
	btn.Parent = leftSidebar
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 4)
	btnCorner.Parent = btn
	
	categories[fullName] = { button = btn, isActive = (fullName == "Main") }
	
	if fullName == "Main" then
		btn.BackgroundColor3 = tabActiveBgColor
		btn.TextColor3 = tabActiveTextColor
	end
	
	addBtnPressAnim(btn)
	
	btn.MouseButton1Click:Connect(function()
		-- Deactivate all categories
		for catName, catData in pairs(categories) do
			catData.button.BackgroundColor3 = tabBgColor
			catData.button.TextColor3 = tabTextColor
			catData.isActive = false
		end
		
		-- Activate this category
		currentCategory = fullName
		btn.BackgroundColor3 = tabActiveBgColor
		btn.TextColor3 = tabActiveTextColor
		categories[fullName].isActive = true
		
		-- Update content visibility with animation
		for catName, catFrame in pairs(categoryFrames) do
			if catName == fullName then
				catFrame.Visible = true
				catFrame.BackgroundTransparency = 1
				TweenService:Create(catFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1
				}):Play()
			else
				catFrame.Visible = false
			end
		end
	end)
	
	return btn
end


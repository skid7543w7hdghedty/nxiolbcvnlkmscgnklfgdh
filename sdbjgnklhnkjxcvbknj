function espGetRoleColor(plr)
	if not espRoles then return ESP_DEFAULT_COLOR end
	local data = espRoles[plr.Name]
	if not data then return ESP_DEFAULT_COLOR end
	if data.Role == "Murderer" then return ESP_MURDERER_COLOR
	elseif data.Role == "Sheriff" or data.HasGun then return ESP_SHERIFF_COLOR
	elseif data.Role == "Hero" then return ESP_HERO_COLOR
	else return ESP_DEFAULT_COLOR end
end

function espGetRoleName(plr)
	if not espRoles then return "" end
	local data = espRoles[plr.Name]
	if not data then return "" end
	if data.Role == "Murderer" then return " [MURDERER]"
	elseif data.Role == "Sheriff" then return " [SHERIFF]"
	elseif data.HasGun then return " [GUN]"
	elseif data.Role == "Hero" then return " [HERO]"
	else return "" end
end

function espGetDist(character)
	local c = player.Character
	if not c or not c:FindFirstChild("HumanoidRootPart") then return nil end
	if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
	return math.floor((c.HumanoidRootPart.Position - character.HumanoidRootPart.Position).Magnitude)
end

function espGetDistFromPos(position)
	local c = player.Character
	if not c or not c:FindFirstChild("HumanoidRootPart") then return nil end
	return math.floor((c.HumanoidRootPart.Position - position).Magnitude)
end

function espGetOrMakeHighlight(character)
	local h = character:FindFirstChild(ESP_HL_TAG)
	if h and h:IsA("Highlight") then return h end
	if h then h:Destroy() end
	local hl = Instance.new("Highlight")
	hl.Name = ESP_HL_TAG
	hl.Adornee = character
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.FillTransparency = ESP_FILL_ALPHA
	hl.OutlineTransparency = ESP_OUTLINE_ALPHA
	hl.FillColor = ESP_DEFAULT_COLOR
	hl.OutlineColor = ESP_DEFAULT_COLOR
	hl.Parent = character
	return hl
end


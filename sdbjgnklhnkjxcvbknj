toggleText.Font = Enum.Font.SourceSansBold
toggleText.TextSize = 18
toggleText.Parent = toggleButton

local toggleClickButton = Instance.new("TextButton")
toggleClickButton.Name = "ToggleClickButton"
toggleClickButton.Size = UDim2.new(1, 0, 1, 0)
toggleClickButton.Position = UDim2.new(0, 0, 0, 0)
toggleClickButton.BackgroundTransparency = 1
toggleClickButton.Text = ""
toggleClickButton.ZIndex = 10
toggleClickButton.Parent = toggleButton

topBar.InputBegan:Connect(function(input)
	if isFrameLocked then
		return
	end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position

		local connection
		connection = input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
				connection:Disconnect()
			end
		end)
	end
end)

topBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

local DRAG_THRESHOLD = 5

toggleClickButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		toggleDragging = true
		toggleDidMove = false
		toggleDragStart = input.Position
		toggleStartPos = toggleButton.Position
	end
end)

toggleClickButton.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		toggleDragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == toggleDragInput and toggleDragging then
		local delta = input.Position - toggleDragStart
		if delta.Magnitude >= DRAG_THRESHOLD then
			toggleDidMove = true
		end
		if toggleDidMove then
			toggleButton.Position = UDim2.new(
				toggleStartPos.X.Scale,
				toggleStartPos.X.Offset + delta.X,
				toggleStartPos.Y.Scale,
				toggleStartPos.Y.Offset + delta.Y
			)
		end
	end
end)

toggleClickButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if toggleDragging and not toggleDidMove then
			menuVisible = not menuVisible
			if mainGui and mainGui.Parent then
				mainGui.Enabled = menuVisible
			end

			toggleButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			toggleButton.BackgroundTransparency = 0.6
			task.spawn(function()
				task.wait(0.15)
				if toggleButton and toggleButton.Parent then
					toggleButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
					toggleButton.BackgroundTransparency = 0
				end
			end)
		end
		toggleDragging = false
		toggleDidMove = false
	end
end)

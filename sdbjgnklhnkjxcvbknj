-- Gun Aura
gunAuraEnabled = false
gunAuraConnections = {}
gunAuraConnectedModels = {}
gunAuraTrackedDrops = {}
gunAuraMagnets = {}

MAGNET_DISTANCE = 15

gunAuraTargets = {
	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital3 = true, MilBase = true,
	Bank2 = true, Office3 = true, PoliceStation = true, ResearchFacility = true
}

function gunAuraGetRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

function gunAuraGetDropPosition(drop)
	if drop:IsA("BasePart") then
		return drop.Position
	elseif drop:IsA("Model") then
		local primary = drop.PrimaryPart
		if primary then return primary.Position end
		local part = drop:FindFirstChildWhichIsA("BasePart", true)
		if part then return part.Position end
	else
		local part = drop:FindFirstChildWhichIsA("BasePart", true)
		if part then return part.Position end
	end
	return nil
end

function gunAuraTeleportDrop(drop, cf)
	if drop:IsA("BasePart") then
		drop.CFrame = cf
		drop.CanCollide = false
		drop.Transparency = 1
	elseif drop:IsA("Model") then
		drop:PivotTo(cf)
		for _, v in ipairs(drop:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
				v.Transparency = 1
			end
		end
	else
		local part = drop:FindFirstChildWhichIsA("BasePart", true)
		if part then
			part.CFrame = cf
			part.CanCollide = false
			part.Transparency = 1
		end
	end
end

function gunAuraStartMagnet(drop)
	if gunAuraMagnets[drop] then return end
	gunAuraMagnets[drop] = RunService.Heartbeat:Connect(function()
		if not drop or not drop.Parent then
			if gunAuraMagnets[drop] then
				gunAuraMagnets[drop]:Disconnect()
				gunAuraMagnets[drop] = nil
			end
			gunAuraTrackedDrops[drop] = nil
			return
		end
		if isPlayerMurderer() then return end
		local root = gunAuraGetRoot()
		if not root then return end
		gunAuraTeleportDrop(drop, root.CFrame)
		-- Fire touch every frame for faster pickup
		local parts = {}
		if drop:IsA("BasePart") then
			parts[1] = drop
		elseif drop:IsA("Model") then
			for _, v in ipairs(drop:GetDescendants()) do
				if v:IsA("BasePart") then parts[#parts+1] = v end
			end
		else
			local p = drop:FindFirstChildWhichIsA("BasePart", true)
			if p then parts[1] = p end
		end
		for i = 1, #parts do
			safeFireTouch(root, parts[i])
		end
	end)
end

function gunAuraStopMagnet(drop)
	if gunAuraMagnets[drop] then
		gunAuraMagnets[drop]:Disconnect()
		gunAuraMagnets[drop] = nil
	end
end

function gunAuraTrackDrop(drop)
	if gunAuraTrackedDrops[drop] then return end
	gunAuraTrackedDrops[drop] = true
	drop.AncestryChanged:Connect(function()
		if not drop.Parent then
			gunAuraTrackedDrops[drop] = nil
			gunAuraStopMagnet(drop)
		end
	end)
end

function gunAuraConnectModel(model)
	if gunAuraConnectedModels[model] then return end
	gunAuraConnectedModels[model] = true
	for _, child in ipairs(model:GetDescendants()) do
		if child.Name == "GunDrop" then
			gunAuraTrackDrop(child)
		end
	end
	local conn = model.DescendantAdded:Connect(function(descendant)
		if not gunAuraEnabled then return end
		if descendant.Name == "GunDrop" then
			gunAuraTrackDrop(descendant)
		end
	end)
	gunAuraConnections[model] = conn
	model.AncestryChanged:Connect(function()
		if not model.Parent then
			if gunAuraConnections[model] then
				gunAuraConnections[model]:Disconnect()
				gunAuraConnections[model] = nil
				gunAuraConnectedModels[model] = nil
			end
		end
	end)
end

function gunAuraScanWorkspace()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and gunAuraTargets[obj.Name] then
			gunAuraConnectModel(obj)
		end
	end
end

function enableGunAura()
	gunAuraEnabled = true
	gunAuraTrackedDrops = {}
	gunAuraConnectedModels = {}
	for drop, conn in pairs(gunAuraMagnets) do
		conn:Disconnect()
	end
	gunAuraMagnets = {}
	for model, conn in pairs(gunAuraConnections) do
		if conn then conn:Disconnect() end
	end
	gunAuraConnections = {}

	gunAuraScanWorkspace()

	-- On new GunDrop: immediately check if it spawned inside aura range
	table.insert(gunAuraConnections, Workspace.DescendantAdded:Connect(function(obj)
		if not gunAuraEnabled then return end
		if obj:IsA("Model") and gunAuraTargets[obj.Name] then
			gunAuraConnectModel(obj)
		end
		if obj.Name == "GunDrop" then
			local parent = obj.Parent
			while parent and parent ~= Workspace do
				if gunAuraTargets[parent.Name] then
					gunAuraTrackDrop(obj)
					-- Instant range check on spawn
					local root = gunAuraGetRoot()
					if root and not gunAuraMagnets[obj] then
						local dropPos = gunAuraGetDropPosition(obj)
						if dropPos and (root.Position - dropPos).Magnitude <= MAGNET_DISTANCE then
							gunAuraTeleportDrop(obj, root.CFrame)
							gunAuraStartMagnet(obj)
							-- firetouchinterest burst on spawn-in-range
							local parts = {}
							if obj:IsA("BasePart") then
								parts[1] = obj
							elseif obj:IsA("Model") then
								for _, v in ipairs(obj:GetDescendants()) do
									if v:IsA("BasePart") then
										parts[#parts+1] = v
									end
								end
							end
							for i = 1, #parts do
								safeFireTouch(root, parts[i])
							end
							task.defer(function()
								if not obj or not obj.Parent then return end
								local r2 = gunAuraGetRoot()
								if not r2 then return end
								for i = 1, #parts do
									parts[i].CFrame = r2.CFrame
									safeFireTouch(r2, parts[i])
								end
							end)
						end
					end
					break
				end
				parent = parent.Parent
			end
		end
	end))

	table.insert(gunAuraConnections, player.CharacterAdded:Connect(function(char)
		if not gunAuraEnabled then return end
		for drop, conn in pairs(gunAuraMagnets) do
			conn:Disconnect()
		end
		gunAuraMagnets = {}
		gunAuraTrackedDrops = {}
		gunAuraConnectedModels = {}
		char:WaitForChild("HumanoidRootPart")
		gunAuraScanWorkspace()
	end))

	-- Main distance-check loop: every Heartbeat frame (no frame skip)
	table.insert(gunAuraConnections, RunService.Heartbeat:Connect(function()
		if not gunAuraEnabled then return end
		if isPlayerMurderer() then return end
		local root = gunAuraGetRoot()
		if not root then return end
		local playerPos = root.Position
		local cf = root.CFrame
		for drop in pairs(gunAuraTrackedDrops) do
			if not drop or not drop.Parent then
				gunAuraTrackedDrops[drop] = nil
				gunAuraStopMagnet(drop)
				continue
			end
			if gunAuraMagnets[drop] then continue end
			local dropPos = gunAuraGetDropPosition(drop)
			if not dropPos then continue end
			local distance = (playerPos - dropPos).Magnitude
			if distance <= MAGNET_DISTANCE then
				gunAuraTeleportDrop(drop, cf)
				gunAuraStartMagnet(drop)
				-- firetouchinterest burst on entering range
				local parts = {}
				if drop:IsA("BasePart") then
					parts[1] = drop
				elseif drop:IsA("Model") then
					for _, v in ipairs(drop:GetDescendants()) do
						if v:IsA("BasePart") then parts[#parts+1] = v end
					end
				else
					local p = drop:FindFirstChildWhichIsA("BasePart", true)
					if p then parts[1] = p end
				end
				for i = 1, #parts do
					safeFireTouch(root, parts[i])
				end
				task.defer(function()
					if not drop or not drop.Parent then return end
					local r2 = gunAuraGetRoot()
					if not r2 then return end
					for i = 1, #parts do
						parts[i].CFrame = r2.CFrame
						safeFireTouch(r2, parts[i])
					end
				end)
			end
		end
	end))

	-- [perf] Periodic re-scan is only a safety net — DescendantAdded catches new
	-- drops instantly. Full Workspace:GetDescendants() every 1s froze mobile.
	task.spawn(function()
		while gunAuraEnabled do
			task.wait(5)
			if gunAuraEnabled then
				gunAuraScanWorkspace()
			end
		end
	end)
end


-- Only farm while we are ALIVE and IN THE ROUND (not dead, not in the lobby
-- waiting for the round). FAIL-OPEN: we only block the farm when we POSITIVELY
-- know we're dead/out of round. If the Alive attribute is missing and player
-- data can't be fetched, we allow farming — otherwise the farm silently never
-- starts (that was the bug: the old check returned false on unknown state).
function autofarmIsAliveInRound()
	local char = player.Character
	if not char then return false end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return false end
	local attr = char:GetAttribute("Alive")
	if attr ~= nil then return attr == true end
	local result = autofarmGetPlayerData()
	if result then
		local me = result[player.Name]
		if me and (me.Killed or me.Dead) then return false end
	end
	-- Unknown state -> assume alive (health > 0 already verified above)
	return true
end


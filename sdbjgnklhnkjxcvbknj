-- Reset Player (NaN Fling)
-- ============================================================
resetWhitelist = {
	["Erereer454"] = true,
	["daniellfc09"] = true,
	["Zero_RuO"] = true,
	["zix338"] = true,
}

function isPlayerWhitelisted(name)
	return resetWhitelist[name]
end

nanFlingTargetName = ""
nanFlingCallCounter = 0
nanFlingConnection = nil

function executeNanFling()
	if nanFlingTargetName == "" then
		notify("Error", "Enter a player name first", 2)
		return
	end

	nanFlingCallCounter = nanFlingCallCounter + 1
	local currentFlingId = nanFlingCallCounter

	if nanFlingConnection then
		nanFlingConnection:Disconnect()
		nanFlingConnection = nil
	end

	local targetPlayer
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Name:lower():find(nanFlingTargetName:lower()) then
			targetPlayer = plr
			break
		end
	end

	if not targetPlayer or not targetPlayer.Character then
		notify("Error", "Target not found", 2)
		return
	end

	if isPlayerWhitelisted(targetPlayer.Name) then
		return
	end

	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp or not hum then return end

	local targetChar = targetPlayer.Character
	local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
	local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
	if not targetRoot or not targetHum then
		notify("Error", "Target has no character", 2)
		return
	end

	for _, part in pairs(targetChar:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = true
			part.Anchored = false
		end
	end

	local savedCFrame = hrp.CFrame
	local savedVelocity = hrp.Velocity
	local savedPlatformStand = hum.PlatformStand

	hum.PlatformStand = true
	local startTime = tick()

	-- Original NaN fling technology: NaN vectors break physics to create fling effect.
	-- Teleport directly to target + set NaN velocity every frame.
	local nanValue = 0 / 0
	local nanVector = Vector3.new(nanValue, nanValue, nanValue)

	nanFlingConnection = RunService.Heartbeat:Connect(function()
		if nanFlingCallCounter ~= currentFlingId then return end

		if tick() - startTime >= 1.5 then
			nanFlingConnection:Disconnect()
			nanFlingConnection = nil
			task.defer(function()
				if nanFlingCallCounter ~= currentFlingId then return end
				hum.PlatformStand = savedPlatformStand

				pcall(sethiddenproperty, hrp, "PhysicsRepRootPart", hrp)

				local restoreCF = savedCFrame
				if restoreCF then
					local safeY = (workspace.FallenPartsDestroyHeight or -500) + 50
					if restoreCF.Position.Y < safeY then
						restoreCF = CFrame.new(restoreCF.Position.X, safeY, restoreCF.Position.Z)
					end
				end

				for i = 1, 15 do
					if nanFlingCallCounter ~= currentFlingId then return end
					for _, part in pairs(char:GetDescendants()) do
						if part:IsA("BasePart") then
							part.Velocity = Vector3.zero
							part.RotVelocity = Vector3.zero
							part.AssemblyLinearVelocity = Vector3.zero
							part.AssemblyAngularVelocity = Vector3.zero
						end
					end
					hrp.CFrame = restoreCF
					char:SetPrimaryPartCFrame(restoreCF)
					task.wait()
				end

				pcall(function()
					hum:ChangeState(Enum.HumanoidStateType.GettingUp)
				end)
			end)
			return
		end

		hrp.CFrame = targetRoot.CFrame
		hrp.AssemblyLinearVelocity = nanVector
		hrp.AssemblyAngularVelocity = nanVector
		pcall(function()
			hum:Move(nanVector)
		end)
		pcall(sethiddenproperty, hrp, "PhysicsRepRootPart", targetRoot)
	end)

	notify("Instant Fling", "Killing " .. targetPlayer.Name, 1.5)
end

function executeNanFlingByRole(roleName)
	local ok, result = pcall(function()
		return invokePlayerData()
	end)
	if not (ok and result) then
		notify("Error", "Could not get roles", 2)
		return
	end
	local function isAlive(name)
		local plr = Players:FindFirstChild(name)
		return plr and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0
	end

	if roleName == "Sheriff" then
		-- Always target the LAST (most recent) Hero/Sheriff, preferring one that is still
		-- alive. Iterate Players:GetPlayers() (deterministic join order) instead of pairs()
		-- (which is unordered) so we never randomly grab the first / older hero.
		local lastHeroAlive, lastHeroAny, lastSheriffAlive, lastSheriffAny = nil, nil, nil, nil
		for _, plr in ipairs(Players:GetPlayers()) do
			local name = plr.Name
			local data = result[name]
			if data and name ~= player.Name and not isPlayerWhitelisted(name) then
				if data.Role == "Hero" or (data.HasGun and data.Role ~= "Murderer") then
					lastHeroAny = name
					if isAlive(name) then lastHeroAlive = name end
				elseif data.Role == "Sheriff" then
					lastSheriffAny = name
					if isAlive(name) then lastSheriffAlive = name end
				end
			end
		end
		local chosen = lastHeroAlive or lastHeroAny or lastSheriffAlive or lastSheriffAny
		if chosen then
			nanFlingTargetName = chosen
			executeNanFling()
			return
		end
	elseif roleName == "Murderer" then
		local aliveTarget = nil
		for name, data in pairs(result) do
			if data.Role == "Murderer" and name ~= player.Name and not isPlayerWhitelisted(name) then
				if isAlive(name) then
					aliveTarget = name
					break
				end
				if not aliveTarget then aliveTarget = name end
			end
		end
		if aliveTarget then
			nanFlingTargetName = aliveTarget
			executeNanFling()
			return
		end
	end
	notify("Error", "No " .. roleName .. " found", 2)
end


local function resolveImageAsset(filePath)
	if not filePath or filePath == "" then return nil end
	if filePath:match("^https?://") or filePath:match("^rbxasset") then
		return filePath
	end
	local funcs = {
		function(p) if syn and syn.asset then return syn.asset(p) end end,
		function(p) if getcustomasset then return getcustomasset(p) end end,
		function(p) if getsynasset then return getsynasset(p) end end,
	}
	for _, fn in ipairs(funcs) do
		local ok, result = pcall(fn, filePath)
		if ok and result then
			return result
		end
	end
	return nil
end

local function applyBgImage(value)
	if value and value ~= "" then
		local resolved = resolveImageAsset(value)
		if resolved then
			mainBgImage.Image = resolved
			return
		end
	end
	mainBgImage.Image = ""
	mainFrame.BackgroundTransparency = mainBgTransparency
end


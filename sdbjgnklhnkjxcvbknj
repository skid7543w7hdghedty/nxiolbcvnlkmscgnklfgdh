-- Restore full config after UI is loaded
-- ============================================
local function restoreFullConfig()
	local c = loadedConfig
	if not c or not c.toggles then return end
	local T = c.toggles

	-- Restore variables (they were overwritten by original declarations)
	isEnabled = T.isEnabled or false
	wallhopToggle = T.wallhopToggle or false
	noclipEnabled = T.noclipEnabled or false
	reachEnabled = T.reachEnabled or false
	fakeSpeedEnabled = T.fakeSpeedEnabled or false
	secondLifeEnabled = T.secondLifeEnabled or false
	invis_on = T.invis_on or false
	autoInvisEnabled = T.autoInvisEnabled or false
	autoTpEnabled = T.autoTpEnabled or false
	clumsy_on = T.clumsy_on or false
	PastedSources = false
	antiFlingEnabled = T.antiFlingEnabled or false
	antiVoidEnabled = T.antiVoidEnabled or false
	espEnabled = T.espEnabled or false
	autoGrabGunEnabled = T.autoGrabGunEnabled or false
	gunAuraEnabled = T.gunAuraEnabled or false
	autoDeleteCoinsEnabled = T.autoDeleteCoinsEnabled or false
	autoDeleteCorpsesEnabled = T.autoDeleteCorpsesEnabled or false
	hiddenfling = T.hiddenfling or false
	currentMode = T.antiAimMode or 0
	gameNotifEnabled = T.gameNotifEnabled or false

	-- Restore values
	if c.values then
		if c.values.JUMP_BOOST_POWER then JUMP_BOOST_POWER = c.values.JUMP_BOOST_POWER end
		if c.values.FAKE_SPEED_CFRAME_SPEED then FAKE_SPEED_CFRAME_SPEED = c.values.FAKE_SPEED_CFRAME_SPEED end
		if c.values.range then range = c.values.range end
		if c.values.autoInvisActivateDist then autoInvisActivateDist = c.values.autoInvisActivateDist end
		if c.values.autoInvisDeactivateDist then autoInvisDeactivateDist = c.values.autoInvisDeactivateDist end
		if c.values.autoTpDist then autoTpDist = c.values.autoTpDist end
		if c.values.autoTpTarget then autoTpTarget = c.values.autoTpTarget end
		if c.values.MAGNET_DISTANCE then MAGNET_DISTANCE = c.values.MAGNET_DISTANCE end
		if c.values.toggleBgTransparency ~= nil then toggleBgTransparency = c.values.toggleBgTransparency end
		if c.values.mainBgTransparency ~= nil then mainBgTransparency = c.values.mainBgTransparency end
		if c.values.popupBgTransparency ~= nil then popupBgTransparency = c.values.popupBgTransparency end
		if c.values.toggleButtonSize ~= nil then toggleButtonSize = c.values.toggleButtonSize end
		if c.values.mainMenuWidth ~= nil then mainMenuWidth = c.values.mainMenuWidth end
		if c.values.mainMenuHeight ~= nil then mainMenuHeight = c.values.mainMenuHeight end
		if c.values.popupBtnWidth ~= nil then popupBtnWidth = c.values.popupBtnWidth end
		if c.values.popupBtnHeight ~= nil then popupBtnHeight = c.values.popupBtnHeight end
		if c.values.customFov then customFov = c.values.customFov end
	end

	-- Restore lock states
	if c.locks then
		popupDragLocked = c.locks.popupDragLocked or false
		toggleDragLocked = c.locks.toggleDragLocked or false

		if lockDragBtn then
			if popupDragLocked then
				lockDragBtn.Text = "Lock Buttons Drag: ON"
				lockDragBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				lockDragBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
			else
				lockDragBtn.Text = "Lock Buttons Drag: OFF"
				lockDragBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
				lockDragBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			end
		end

		if toggleDragBtn then
			if toggleDragLocked then
				toggleDragBtn.Text = "Lock WIN-X Drag: ON"
				toggleDragBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				toggleDragBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
			else
				toggleDragBtn.Text = "Lock WIN-X Drag: OFF"
				toggleDragBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
				toggleDragBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			end
		end
	end

	-- Restore WIN-X toggle button position
	if c.togglePos and toggleButton then
		local p = c.togglePos
		toggleButton.Position = UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset)
	end

	-- Restore value inputs
	if speedInputBox and c.values and c.values.FAKE_SPEED_CFRAME_SPEED then
		speedInputBox.Text = tostring(c.values.FAKE_SPEED_CFRAME_SPEED)
	end
	if ui.jumpBoostInput and c.values and c.values.JUMP_BOOST_POWER then
		ui.jumpBoostInput.Text = tostring(c.values.JUMP_BOOST_POWER)
	end
	if rangeInputBox and c.values and c.values.range then
		rangeInputBox.Text = tostring(c.values.range)
	end
	if autoInvisActivateBox and c.values and c.values.autoInvisActivateDist then
		autoInvisActivateBox.Text = tostring(c.values.autoInvisActivateDist)
	end
	if autoInvisDeactivateBox and c.values and c.values.autoInvisDeactivateDist then
		autoInvisDeactivateBox.Text = tostring(c.values.autoInvisDeactivateDist)
	end
	if autoTpDistBox and c.values and c.values.autoTpDist then
		autoTpDistBox.Text = tostring(c.values.autoTpDist)
	end
	if autoTpTargetBtn and c.values and c.values.autoTpTarget then
		autoTpTarget = c.values.autoTpTarget
		autoTpTargetBtn.Text = autoTpTargetNames[autoTpTarget]
	end
	if ui.magnetDistInput and c.values and c.values.MAGNET_DISTANCE then
		ui.magnetDistInput.Text = tostring(c.values.MAGNET_DISTANCE)
	end
	if toggleBgInput and c.values and c.values.toggleBgTransparency ~= nil then
		toggleBgInput.Text = tostring(math.floor(c.values.toggleBgTransparency * 100))
	end
	if mainBgInput and c.values and c.values.mainBgTransparency ~= nil then
		mainBgInput.Text = tostring(math.floor(c.values.mainBgTransparency * 100))
	end
	if bgTranspInput and c.values and c.values.popupBgTransparency ~= nil then
		bgTranspInput.Text = tostring(math.floor(c.values.popupBgTransparency * 100))
		for name, data in pairs(extractedButtons) do
			if data.popupBtn then data.popupBtn.BackgroundTransparency = popupBgTransparency end
			if data.btn then data.btn.BackgroundTransparency = popupBgTransparency end
		end
	end
	-- Apply WIN-X transparency to the toggle button
	if toggleButton then
		toggleButton.BackgroundTransparency = toggleBgTransparency
	end
	-- Apply main menu transparency to the frame and its parts
	mainFrame.BackgroundTransparency = mainBgTransparency
	if leftSidebar then
		leftSidebar.BackgroundTransparency = mainBgTransparency
	end
	if topBar then
		topBar.BackgroundTransparency = mainBgTransparency
	end
	if topFix then
		topFix.BackgroundTransparency = mainBgTransparency
	end

	-- Apply sizes
	if toggleButton then
		toggleButton.Size = UDim2.new(0, toggleButtonSize, 0, toggleButtonSize)
	end
	if mainFrame then
		mainFrame.Size = UDim2.new(0, mainMenuWidth, 0, mainMenuHeight)
	end
	for name, data in pairs(extractedButtons) do
		if data.btn then
			data.btn.Size = UDim2.new(0, popupBtnWidth, 0, popupBtnHeight)
		end
	end
	-- Restore size input texts
	if toggleSizeInput and c.values and c.values.toggleButtonSize ~= nil then
		toggleSizeInput.Text = tostring(c.values.toggleButtonSize)
	end
	if mainWidthInput and c.values and c.values.mainMenuWidth ~= nil then
		mainWidthInput.Text = tostring(c.values.mainMenuWidth)
	end
	if mainHeightInput and c.values and c.values.mainMenuHeight ~= nil then
		mainHeightInput.Text = tostring(c.values.mainMenuHeight)
	end
	if popupWidthInput and c.values and c.values.popupBtnWidth ~= nil then
		popupWidthInput.Text = tostring(c.values.popupBtnWidth)
	end
	if popupHeightInput and c.values and c.values.popupBtnHeight ~= nil then
		popupHeightInput.Text = tostring(c.values.popupBtnHeight)
	end
	if fovInputBox and c.values and c.values.customFov then
		fovInputBox.Text = tostring(c.values.customFov)
	end

	-- Restore binds UI FIRST (before toggles, so saveConfig sees them)
	if c.binds then
		for name, keyStr in pairs(c.binds) do
			local key = stringToKey(keyStr)
			if key then
				featureBinds[name] = key
				for _, feature in ipairs(bindableFeatures) do
					if feature.name == name then
						keyBinds[key] = {callback = feature.callback, description = name}
						break
					end
				end
			end
		end
		for _, feature in ipairs(bindableFeatures) do
			local row = categoryFrames["Binds"]:FindFirstChild("BindRow_" .. feature.name:gsub("%W", ""))
			if row then
				for _, child in ipairs(row:GetChildren()) do
					if child:IsA("TextButton") and child.Text ~= "X" then
						child.Text = featureBinds[feature.name] and bindKeyToName(featureBinds[feature.name]) or "None"
					end
				end
			end
		end
	end

	-- Restore extracted buttons (before toggles, so saveConfig sees them)
	if c.extractedBtns then
		for name, btnData in pairs(c.extractedBtns) do
			if not extractedButtons[name] and extractHandlers[name] then
				extractHandlers[name]()
			end
			if extractedButtons[name] and extractedButtons[name].btn and btnData.pos then
				local p = btnData.pos
				extractedButtons[name].btn.Position = UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset)
			end
			if extractedButtons[name] and extractedButtons[name].popupLockBtn and btnData.locked then
				extractedButtons[name].popupLockBtn.Text = "L"
				extractedButtons[name].popupLockBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
			end
		end
	end

	-- Restore toggle buttons UI and enable features (read from T directly)
	if T.isEnabled and button1 then
		setToggleState(button1, true, "Infinite Jump: ON", "Infinite Jump: OFF")
		setExtractedBtnState("Infinite Jump", true)
	end
	if T.wallhopToggle and button2 then
		setToggleState(button2, true, "Wallhop: ON", "Wallhop: OFF")
		setExtractedBtnState("Wallhop", true)
	end
	if T.fakeSpeedEnabled then
		if button4 then setToggleState(button4, true, "Speed Glitch: ON", "Speed Glitch: OFF") end
		setExtractedBtnState("Speed Glitch", true)
		setupFakeSpeed()
	end
	if T.secondLifeEnabled then
		if secondLifeButton then setToggleState(secondLifeButton, true, "Second Life: ON", "Second Life: OFF") end
		setExtractedBtnState("Second Life", true)
		enableSecondLife()
	end
	if T.noclipEnabled then
		noclipEnabled = false; toggleNoclip()
		if noclipButton then setToggleState(noclipButton, true, "Noclip: ON", "Noclip: OFF") end
		setExtractedBtnState("Noclip", true)
	end
	if T.reachEnabled then
		reachEnabled = false; toggleReach()
		if reachButton then setToggleState(reachButton, true, "KillAura: ON", "KillAura: OFF") end
		setExtractedBtnState("KillAura", true)
	end
	if T.airStrafeEnabled then
		if airStrafeButton then setToggleState(airStrafeButton, true, "Air Strafe: ON", "Air Strafe: OFF") end
		setExtractedBtnState("Air Strafe", true)
		airStrafeEnabled = true
		setupAirStrafe()
	end
	if T.PastedSources then
		toggleDesync()
		if desyncButton then setToggleState(desyncButton, true, "Desync: ON", "Desync: OFF") end
		setExtractedBtnState("Desync", true)
	end
	if T.antiVoidEnabled then
		antiVoidEnabled = false; toggleAntiVoid()
		if antiVoidButton then setToggleState(antiVoidButton, true, "Anti-Void: ON", "Anti-Void: OFF") end
		setExtractedBtnState("Anti-Void", true)
	end
	if T.antiFlingEnabled then
		antiFlingEnabled = false; toggleAntiFling()
		if antiFlingButton then setToggleState(antiFlingButton, true, "Anti-Fling: ON", "Anti-Fling: OFF") end
		setExtractedBtnState("Anti-Fling", true)
	end
	if T.espEnabled then
		espEnabled = false; toggleEsp()
		if espButton then setToggleState(espButton, true, "Esp: ON", "Esp: OFF") end
		setExtractedBtnState("ESP", true)
	end
	if T.autoGrabGunEnabled then
		autoGrabGunEnabled = false; toggleAutoGrabGun()
		if btn.autoGrabGun then setToggleState(btn.autoGrabGun, true, "AutoGrab Gun: ON", "AutoGrab Gun: OFF") end
		setExtractedBtnState("AutoGrab Gun", true)
	end
	if T.gunAuraEnabled then

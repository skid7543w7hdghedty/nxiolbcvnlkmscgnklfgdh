		if lsRow then lsRow.Parent = mvmtFrame; lsRow.LayoutOrder = 100.1 end
		-- Move AirStrafe to Movement 2nd place (LayoutOrder 100.2)
		-- Wrap AirStrafe in a dual row with value input
		if airStrafeButton then
			local asRow = Instance.new("Frame")
			asRow.Name = "AirStrafeRow"
			asRow.Size = UDim2.new(1, 0, 0, 42)
			asRow.BackgroundTransparency = 1
			asRow.LayoutOrder = 100.2
			asRow.Parent = mvmtFrame
			airStrafeButton.Size = UDim2.new(1, -70, 1, 0)
			airStrafeButton.Position = UDim2.new(0, 0, 0, 0)
			airStrafeButton.Parent = asRow
			airStrafeButton.LayoutOrder = 0
			airStrafeInput = Instance.new("TextBox")
			airStrafeInput.Name = "AirStrafeInput"
			airStrafeInput.Size = UDim2.new(0, 62, 1, 0)
			airStrafeInput.Position = UDim2.new(1, -64, 0, 0)
			airStrafeInput.BackgroundColor3 = inputBgColor or Color3.fromRGB(0, 0, 0)
			airStrafeInput.TextColor3 = inputTextColor or Color3.fromRGB(255, 255, 255)
			airStrafeInput.PlaceholderText = "Mult"
			airStrafeInput.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
			airStrafeInput.Text = tostring(airStrafeMultiplier)
			airStrafeInput.Font = Enum.Font.SourceSansBold
			airStrafeInput.TextSize = 15
			airStrafeInput.ClearTextOnFocus = false
			airStrafeInput.Parent = asRow
			Instance.new("UICorner", airStrafeInput).CornerRadius = UDim.new(0, 6)
			airStrafeInput.FocusLost:Connect(function()
				local v = tonumber(airStrafeInput.Text)
				if v and v > 0 then
					airStrafeMultiplier = v
					saveConfig()
				else
					airStrafeInput.Text = tostring(airStrafeMultiplier)
				end
			end)
		end
	end

	-- COLLAPSIBLE FLING PLAYER LIST
	-- Add a collapse button to the Multi Fling section header
	local utilFling = categoryFrames["Utilities"]
	if utilFling and multiFlingFrame then
		multiFlingCollapsed = false
		local collapseBtn = Instance.new("TextButton")
		collapseBtn.Name = "MultiFlingCollapseBtn"
		collapseBtn.Size = UDim2.new(0, 24, 0, 24)
		collapseBtn.Position = UDim2.new(1, -30, 0, 0)
		collapseBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		collapseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		collapseBtn.Text = "-"
		collapseBtn.Font = Enum.Font.SourceSansBold
		collapseBtn.TextSize = 16
		collapseBtn.Parent = multiFlingStatusLabel
		Instance.new("UICorner", collapseBtn).CornerRadius = UDim.new(0, 4)
		collapseBtn.MouseButton1Click:Connect(function()
			multiFlingCollapsed = not multiFlingCollapsed
			collapseBtn.Text = multiFlingCollapsed and "+" or "-"
			if flingSearchBox then flingSearchBox.Visible = not multiFlingCollapsed end
			multiFlingFrame.Visible = not multiFlingCollapsed
			saveConfig()
		end)
	end
end

task.defer(restoreFullConfig)

-- Restore detached emote buttons (выносимые кнопки эмоций) saved in the config.
task.defer(function()
	local c = loadedConfig
	if not c or not c.detachedEmotes then return end
	for idStr, info in pairs(c.detachedEmotes) do
		local id = tonumber(idStr)
		if id and not isEmoteDetached(id) then
			pcall(function()
				createDetachedEmote(id, info and info.name, info and info.pos, true, info and info.locked)
				local ui = animationUiById[id]
				if ui and ui.PopOut then ui.PopOut.Text = "★" end
			end)
		end
	end
end)

-- Restore saved emote speed values (Animations tab) on rejoin.
task.defer(function()
	local c = loadedConfig
	if not c or not c.animationSpeeds then return end
	for idStr, spd in pairs(c.animationSpeeds) do
		local id = tonumber(idStr)
		local ui = id and animationUiById[id]
		if ui and ui.Box and type(spd) == "string" and spd ~= "" then
			ui.Box.Text = spd
		end
	end
end)


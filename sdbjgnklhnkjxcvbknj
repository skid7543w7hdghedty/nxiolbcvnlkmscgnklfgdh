-- Helper: merge new IDs into the accumulated list (dedup), apply only new ones,
-- and update the text box to show ALL accumulated IDs.
function changerSlotApply(slotKey, rawText)
    local newIds = changerExtractIds(rawText)
    if #newIds == 0 then return 0 end

    if not changerAccumulatedIds[slotKey] then changerAccumulatedIds[slotKey] = {} end
    local existing = {}
    for _, id in ipairs(changerAccumulatedIds[slotKey]) do existing[id] = true end

    local okCount = 0
    for _, id in ipairs(newIds) do
        if not existing[id] then
            table.insert(changerAccumulatedIds[slotKey], id)
            existing[id] = true
            if changerApplyId(id) then okCount = okCount + 1 end
        end
    end

    -- Update text box to show ALL accumulated IDs
    if changerSlotInputs[slotKey] then
        changerSlotInputs[slotKey].Text = table.concat(changerAccumulatedIds[slotKey], ", ")
    end
    return okCount
end


function antiAimStep(dt)
	local char = player.Character
	if not char then antiAimRealCF = nil return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChild("Humanoid")
	if not (hrp and hum and hum.Health > 0) then antiAimRealCF = nil return end

	-- Disable AutoRotate so shift lock / first person can't override our rotation
	hum.AutoRotate = false

	local pos = hrp.Position

	-- Camera-stable pose: face where the camera looks (flattened). The stabilizer
	-- applies this right before the camera updates, so first person / shiftlock
	-- never swirls, even while the body moves randomly for everyone else.
	local cam = workspace.CurrentCamera
	if cam then
		local lv = cam.CFrame.LookVector
		local flat = Vector3.new(lv.X, 0, lv.Z)
		if flat.Magnitude > 0.01 then
			antiAimRealCF = CFrame.lookAt(pos, pos + flat.Unit)
		else
			antiAimRealCF = CFrame.new(pos) * (hrp.CFrame - hrp.CFrame.Position)
		end
	else
		antiAimRealCF = hrp.CFrame
	end

	-- Randomized erratic anti-aim: re-roll yaw / pitch / roll on a short interval
	-- (combines what the old modes did, all together). Rotation only -> no
	-- positional drift, so we never get flung into the void. Speed = how fast it
	-- re-randomizes.
	antiAimRandTimer = antiAimRandTimer + (dt or 0)
	local interval = 1 / math.max(1, antiAimSpeed)
	if (not antiAimYaw) or antiAimRandTimer >= interval then
		antiAimRandTimer = 0
		antiAimYaw = math.random() * math.pi * 2
		-- Only horizontal (yaw) rotation — no vertical pitch/roll jitter
		antiAimPitch = 0
		antiAimRoll = 0
	end
	hrp.CFrame = CFrame.new(pos) * CFrame.Angles(0, antiAimYaw, 0)
	antiAimEnsureAnim(hum)
end


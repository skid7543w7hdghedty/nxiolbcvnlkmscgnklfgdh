-- Exploiter player list logic
exploiterCheckboxes = {}
selectedExploiterTargets = {}

function updateExploiterStatus()
	if not exploiterStatusLabel then return end
	local count = 0
	for _ in pairs(selectedExploiterTargets) do count += 1 end
	exploiterStatusLabel.Text = count == 0 and "Select players to mark as exploiters" or (count .. " player(s) selected")
	exploiterStatusLabel.TextColor3 = count == 0 and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(255, 80, 80)
end

function refreshExploiterList()
	if not exploiterScrollFrame then return end
	if refreshSavedExploiters then refreshSavedExploiters() end
	if refreshOnlineExploiters then refreshOnlineExploiters() end
	for _, child in ipairs(exploiterScrollFrame:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
	exploiterCheckboxes = {}

	local playerList = Players:GetPlayers()
	table.sort(playerList, function(a, b)
		local aMarked = markedExploiters[a.Name] == true
		local bMarked = markedExploiters[b.Name] == true
		if aMarked ~= bMarked then return aMarked end
		return a.Name:lower() < b.Name:lower()
	end)

	local yPosition = 0
	for _, plr in ipairs(playerList) do
		if plr ~= player then
			local isMarked = markedExploiters[plr.Name] == true

			local playerEntry = Instance.new("Frame")
			playerEntry.Name = plr.Name .. "ExploiterEntry"
			playerEntry.Size = UDim2.new(1, 0, 0, 30)
			playerEntry.Position = UDim2.new(0, 0, 0, yPosition)
			playerEntry.BackgroundColor3 = isMarked and Color3.fromRGB(40, 10, 10) or Color3.fromRGB(0, 0, 0)
			playerEntry.BorderSizePixel = 0
			playerEntry.Parent = exploiterScrollFrame

			local entryCorner = Instance.new("UICorner")
			entryCorner.CornerRadius = UDim.new(0, 6)
			entryCorner.Parent = playerEntry

			local checkbox = Instance.new("TextButton")
			checkbox.Size = UDim2.new(0, 24, 0, 24)
			checkbox.Position = UDim2.new(0, 3, 0.5, -12)
			checkbox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			checkbox.BorderSizePixel = 0
			checkbox.Text = ""
			checkbox.Parent = playerEntry

			local checkboxCorner = Instance.new("UICorner")
			checkboxCorner.CornerRadius = UDim.new(0, 6)
			checkboxCorner.Parent = checkbox

			local checkmark = Instance.new("TextLabel")
			checkmark.Size = UDim2.new(1, 0, 1, 0)
			checkmark.BackgroundTransparency = 1
			checkmark.Text = "✓"
			checkmark.TextColor3 = Color3.fromRGB(255, 80, 80)
			checkmark.Font = Enum.Font.GothamBold
			checkmark.TextSize = 20
			checkmark.Visible = selectedExploiterTargets[plr.Name] ~= nil
			checkmark.Parent = checkbox

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Size = UDim2.new(1, -35, 1, 0)
			nameLabel.Position = UDim2.new(0, 32, 0, 0)
			nameLabel.BackgroundTransparency = 1
			nameLabel.Text = (isMarked and "[!] " or "") .. plr.Name
			nameLabel.TextColor3 = isMarked and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 255, 255)
			nameLabel.TextSize = 16
			nameLabel.Font = Enum.Font.SourceSansBold
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.Parent = playerEntry

			local clickArea = Instance.new("TextButton")
			clickArea.Size = UDim2.new(1, -30, 1, 0)
			clickArea.BackgroundTransparency = 1
			clickArea.Text = ""
			clickArea.Parent = playerEntry

			clickArea.MouseButton1Click:Connect(function()
				if selectedExploiterTargets[plr.Name] then
					selectedExploiterTargets[plr.Name] = nil
					checkmark.Visible = false
				else
					selectedExploiterTargets[plr.Name] = plr
					checkmark.Visible = true
				end
				updateExploiterStatus()
			end)

			local infoBtn = Instance.new("TextButton")
			infoBtn.Name = plr.Name .. "InfoBtn"
			infoBtn.Size = UDim2.new(0, 24, 0, 24)
			infoBtn.Position = UDim2.new(1, -27, 0.5, -12)
			infoBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			infoBtn.BorderSizePixel = 0
			infoBtn.Text = ">"
			infoBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			infoBtn.Font = Enum.Font.SourceSansBold
			infoBtn.TextSize = 16
			infoBtn.Parent = playerEntry

			local infoBtnCorner = Instance.new("UICorner")
			infoBtnCorner.CornerRadius = UDim.new(0, 4)
			infoBtnCorner.Parent = infoBtn

			infoBtn.MouseButton1Click:Connect(function()
				showPlayerInfoPopup(plr)
			end)

			infoBtn.MouseEnter:Connect(function()
				infoBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			end)
			infoBtn.MouseLeave:Connect(function()
				infoBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			end)

			exploiterCheckboxes[plr.Name] = {
				Entry = playerEntry,
				Checkmark = checkmark,
				NameLabel = nameLabel,
				InfoBtn = infoBtn,
			}

			yPosition += 36
		end
	end

	exploiterScrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPosition)
	updateExploiterStatus()
	if exploiterSearchBox then
		local searchText = string.lower(exploiterSearchBox.Text)
		for _, data in pairs(exploiterCheckboxes) do
			if data.Entry and data.NameLabel then
				local playerName = data.NameLabel.Text:gsub("^%[!%] ", "")
				data.Entry.Visible = searchText == "" or string.find(string.lower(playerName), searchText, 1, true) ~= nil
			end
		end
	end
end

function toggleAllExploiterPlayers(selectAll)
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local checkboxData = exploiterCheckboxes[plr.Name]
			if checkboxData then
				if selectAll then
					selectedExploiterTargets[plr.Name] = plr
					checkboxData.Checkmark.Visible = true
				else
					selectedExploiterTargets[plr.Name] = nil
					checkboxData.Checkmark.Visible = false
				end
			end
		end
	end
	updateExploiterStatus()
end

function showPlayerInfoPopup(plr)
	if not plr then return end

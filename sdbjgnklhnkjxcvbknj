-- Save the original sky so we can restore it with "Unchange"
function skyboxSaveOriginal()
	if skyboxOriginalSky then return end
	local lighting = game:GetService("Lighting")
	local existingSky = lighting:FindFirstChildOfClass("Sky")
	if existingSky then
		skyboxOriginalSky = {
			Up = existingSky.SkyboxUp,
			Dn = existingSky.SkyboxDn,
			Ft = existingSky.SkyboxFt,
			Bk = existingSky.SkyboxBk,
			Lf = existingSky.SkyboxLf,
			Rt = existingSky.SkyboxRt,
		}
	else
		skyboxOriginalSky = "none"
	end
end

-- Build an asset URL from text input (accepts number, rbxassetid://NNN, or full URL)
function skyboxParseId(text)
	if not text or text == "" then return nil end
	local digits = tostring(text):match("%d+")
	if not digits then return nil end
	return "rbxassetid://" .. digits
end

-- Apply skybox from a table { Up=url, Dn=url, ... } — only sets faces that are non-nil
function skyboxApplyFaces(faceTable)
	skyboxSaveOriginal()
	local lighting = game:GetService("Lighting")
	-- Remove existing Sky objects
	for _, child in ipairs(lighting:GetChildren()) do
		if child:IsA("Sky") then
			pcall(function() child:Destroy() end)
		end
	end
	local skybox = Instance.new("Sky")
	skybox.Name = "AdrenalinSkybox"
	-- Start with current original values as fallback
	if skyboxOriginalSky and skyboxOriginalSky ~= "none" then
		skybox.SkyboxUp = skyboxOriginalSky.Up or ""
		skybox.SkyboxDn = skyboxOriginalSky.Dn or ""
		skybox.SkyboxFt = skyboxOriginalSky.Ft or ""
		skybox.SkyboxBk = skyboxOriginalSky.Bk or ""
		skybox.SkyboxLf = skyboxOriginalSky.Lf or ""
		skybox.SkyboxRt = skyboxOriginalSky.Rt or ""
	end
	-- Override with provided faces
	if faceTable.Up then skybox.SkyboxUp = faceTable.Up end
	if faceTable.Dn then skybox.SkyboxDn = faceTable.Dn end
	if faceTable.Ft then skybox.SkyboxFt = faceTable.Ft end
	if faceTable.Bk then skybox.SkyboxBk = faceTable.Bk end
	if faceTable.Lf then skybox.SkyboxLf = faceTable.Lf end
	if faceTable.Rt then skybox.SkyboxRt = faceTable.Rt end
	skybox.Parent = lighting
	skyboxApplied = true
	return true
end

-- Build face table from all 6 input fields (skips empty ones)
function skyboxCollectInputs()
	local faces = {}
	local count = 0
	for _, face in ipairs(skyboxFaces) do
		local box = skyboxFaceInputs[face]
		if box and box.Text and box.Text ~= "" then
			local url = skyboxParseId(box.Text)
			if url then
				faces[face] = url
				count = count + 1
			end
		end
	end
	return faces, count
end

-- Restore the original skybox
function skyboxUnchange()
	local lighting = game:GetService("Lighting")
	for _, child in ipairs(lighting:GetChildren()) do
		if child:IsA("Sky") then
			pcall(function() child:Destroy() end)
		end
	end
	if skyboxOriginalSky and skyboxOriginalSky ~= "none" then
		local sky = Instance.new("Sky")
		sky.SkyboxUp = skyboxOriginalSky.Up or ""
		sky.SkyboxDn = skyboxOriginalSky.Dn or ""
		sky.SkyboxFt = skyboxOriginalSky.Ft or ""
		sky.SkyboxBk = skyboxOriginalSky.Bk or ""
		sky.SkyboxLf = skyboxOriginalSky.Lf or ""
		sky.SkyboxRt = skyboxOriginalSky.Rt or ""
		sky.Parent = lighting
	end
	skyboxApplied = false
end


-- KillAura: brings targets to your real position, strips their weapons, and
-- knife touch-kills them. Works with any equipped tool (not just knives).
function toggleReach()
	reachEnabled = not reachEnabled
	if reachEnabled then
		reachConnection = RunService.Heartbeat:Connect(function()
			local myChar = player.Character
			if not myChar then return end
			local hrp = myChar:FindFirstChild("HumanoidRootPart")
			local myHum = myChar:FindFirstChildOfClass("Humanoid")
			if not (hrp and myHum and myHum.Health > 0) then return end

			local tool = myChar:FindFirstChildOfClass("Tool")
			if not (tool and tool:FindFirstChild("Handle")) then return end
			if not tool.Name:lower():find("knife") then return end
			local handle = tool.Handle

			-- Real position (works with Anti-Shoot / Desync)
			local realCF = killGetRealCFrame()

			local p = reachCachePlayers
			local idx = 0
			for i = 1, #p do
				local plr = p[i]
				if plr ~= player then
					local v = plr.Character
					if v then
						local tRoot = v:FindFirstChild("HumanoidRootPart")
						local tHum = v:FindFirstChildOfClass("Humanoid")
						if tRoot and tHum and tHum.Health > 0 then
							local dist = (realCF.Position - tRoot.Position).Magnitude
							if dist <= range then
								idx = idx + 1
								-- Bring target to our real position
								pcall(function()
									tRoot.CFrame = realCF * CFrame.new(idx * 0.5, 0, 0)
								end)
								-- Strip their weapons
								pcall(function()
									local bp = plr:FindFirstChild("Backpack")
									if bp then bp:ClearAllChildren() end
									for _, child in pairs(v:GetChildren()) do
										if child:IsA("Tool") then child:Destroy() end
									end
								end)
								-- Knife: activate + firetouchinterest
								pcall(function() tool:Activate() end)
								for _, part in ipairs(v:GetDescendants()) do
									if part:IsA("BasePart") then
										safeFireTouch(handle, part)
									end
								end
							end
						end
					end
				end
			end
		end)
	else
		if reachConnection then
			reachConnection:Disconnect()
			reachConnection = nil
		end
	end
end

-- ============================================
-- Throwing Knife Aura
-- ============================================
-- When a thrown ThrowingKnife in Workspace is within `throwingKnifeAuraRadius`
-- studs of an alive player, that player is killed using the local player's
-- equipped knife (same mechanism as KillAura). Only works when the local
-- player is the Murderer.
throwingKnifeAuraEnabled = false
throwingKnifeAuraConnection = nil
throwingKnifeAuraRadius = 15

-- Live set of thrown-knife instances currently in the workspace.
-- Value = last known world position of the knife. Keeping the position lets us
-- still register a hit when the knife despawns on impact — at close range the
-- knife hits and disappears within a frame or two, long before a kill lands.
activeThrownKnives = {}

-- [fix] Targets latched for killing, keyed by Player; value = os.clock()
-- deadline. At close range the thrown knife reaches the victim (and despawns)
-- while our knife tool is still on its post-throw cooldown / re-equipping, so
-- a single Activate+touch attempt silently does nothing. Instead of one-shot
-- attempts tied to the knife instance's lifetime, we latch the target and
-- keep retrying every Heartbeat until they die or the window expires. This is
-- what made the aura only work at long range (~60 studs): the flight time
-- there was long enough for the cooldown to expire before the knife despawned.
tkaPendingKills = {}
TKA_KILL_RETRY_WINDOW = 2.0

-- Latch every alive player within the aura radius of `pos` for killing.
function tkaMarkTargetsNear(pos)
	if not pos then return end
	local deadline = os.clock() + TKA_KILL_RETRY_WINDOW
	local p = reachCachePlayers
	for i = 1, #p do
		local plr = p[i]
		if plr ~= player then
			local v = plr.Character
			local tRoot = v and v:FindFirstChild("HumanoidRootPart")
			local tHum = v and v:FindFirstChildOfClass("Humanoid")
			if tRoot and tHum and tHum.Health > 0
				and (pos - tRoot.Position).Magnitude <= throwingKnifeAuraRadius then
				tkaPendingKills[plr] = deadline
			end
		end
	end
end

-- [fix] Anti-pull guard. The game's stab logic snaps the murderer to the
-- victim a few FRAMES AFTER the hit registers — not on the same frame as
-- Activate. That's why restoring the CFrame right after Activate never
-- worked: the restore ran before the game moved us. Instead, for a short
-- window after every aura stab we watch the HumanoidRootPart each Heartbeat;
-- if it jumps further than TKA_GUARD_JUMP studs in a single frame (a teleport
-- / grab, impossible from normal running), we snap it straight back, zero the
-- velocity and strip any injected body movers. Normal walking during the
-- window is untouched because per-frame movement is well under the threshold.
tkaGuardUntil = 0
tkaGuardLastPos = nil
TKA_GUARD_WINDOW = 0.75
TKA_GUARD_JUMP = 8

function tkaGuardCheck()
	local myChar = player.Character
	local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not hrp then
		tkaGuardLastPos = nil
		return
	end

	if os.clock() > tkaGuardUntil then
		tkaGuardLastPos = nil
		return
	end

	local pos = hrp.Position
	if tkaGuardLastPos and (pos - tkaGuardLastPos).Magnitude > TKA_GUARD_JUMP then
		-- We got yanked (stab grab / lunge teleport) — put us back.
		for _, ch in ipairs(hrp:GetChildren()) do
			if ch:IsA("BodyVelocity") or ch:IsA("BodyGyro") or ch:IsA("BodyPosition")
				or ch:IsA("LinearVelocity") or ch:IsA("VectorForce")
				or ch:IsA("AlignPosition") or ch:IsA("AlignOrientation") then
				ch:Destroy()
			end
		end
		hrp.CFrame = hrp.CFrame - hrp.CFrame.Position + tkaGuardLastPos
		hrp.AssemblyLinearVelocity = Vector3.zero
	else
		tkaGuardLastPos = pos
	end
end

-- [fix] Retry the stab on all latched targets until they die or time out.
-- Uses the same kill mechanism as "Kill Everyone" (killGetKnife +
-- killKnifeTouch). Every stab arms the anti-pull guard above so the game's
-- delayed grab/teleport toward the victim gets reverted the frame it happens.
function tkaProcessPendingKills()
	if next(tkaPendingKills) == nil then return end

	local now = os.clock()
	local myChar = player.Character
	local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
	if not (myHum and myHum.Health > 0) then return end

	local knife = killGetKnife()
	if not knife then return end

	local didStab = false
	for plr, deadline in pairs(tkaPendingKills) do
		local v = plr.Parent and plr.Character
		local tHum = v and v:FindFirstChildOfClass("Humanoid")
		if now > deadline or not v or not tHum or tHum.Health <= 0 then
			tkaPendingKills[plr] = nil
		else
			didStab = true
			pcall(killKnifeTouch, v, knife)
		end
	end

	if didStab then
		-- Arm/refresh the guard window; seed the anchor position now.
		tkaGuardUntil = now + TKA_GUARD_WINDOW
		local hrp = myChar:FindFirstChild("HumanoidRootPart")
		if hrp and not tkaGuardLastPos then
			tkaGuardLastPos = hrp.Position
		end
	end
end

function tkaGetKnifePosition(inst)
	if inst:IsA("BasePart") then
		return inst.Position
	elseif inst:IsA("Model") then
		if inst.PrimaryPart then
			return inst.PrimaryPart.Position
		end
		local bp = inst:FindFirstChildWhichIsA("BasePart")
		if bp then return bp.Position end
		local ok, cf = pcall(function() return inst:GetBoundingBox() end)
		if ok and cf then return cf.Position end
	end
	return nil
end

function tkaIsThrownKnife(inst)
	if not inst then return false end
	if not (inst:IsA("BasePart") or inst:IsA("Model")) then return false end
	local n = inst.Name:lower()
	if not (n == "throwingknife" or n:find("throwingknife") or n:find("throwing_knife")) then
		return false
	end
	local a = inst.Parent
	while a and a ~= game do
		if a:IsA("Backpack") then return false end
		if a:IsA("Model") and Players:GetPlayerFromCharacter(a) then return false end
		a = a.Parent
	end
	return inst:IsDescendantOf(Workspace)
end

function tkaRescanKnives()
	for inst, lastPos in pairs(activeThrownKnives) do
		if not inst.Parent or not inst:IsDescendantOf(Workspace) or not tkaIsThrownKnife(inst) then
			-- [fix] Knife despawned (hit something / landed). Mark targets at
			-- its LAST KNOWN position — at close range this is the only chance
			-- we get, because the knife lives for just a few frames.
			activeThrownKnives[inst] = nil
			tkaMarkTargetsNear(lastPos)
		end
	end
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if tkaIsThrownKnife(inst) and not activeThrownKnives[inst] then
			activeThrownKnives[inst] = tkaGetKnifePosition(inst) or true
		end
	end
end

Workspace.DescendantAdded:Connect(function(inst)
	if not throwingKnifeAuraEnabled then return end
	if inst.Parent and tkaIsThrownKnife(inst) then
		activeThrownKnives[inst] = tkaGetKnifePosition(inst) or true
		pcall(tkaMarkTargetsNear, tkaGetKnifePosition(inst))
	end
end)

tkaLastRescan = 0
function toggleThrowingKnifeAura()
	throwingKnifeAuraEnabled = not throwingKnifeAuraEnabled
	if throwingKnifeAuraEnabled then
		tkaPendingKills = {}
		tkaRescanKnives()
		tkaLastRescan = os.clock()
		throwingKnifeAuraConnection = RunService.Heartbeat:Connect(function()
			if not throwingKnifeAuraEnabled then return end
			if not isPlayerMurderer() then return end

			local now = os.clock()
			if now - tkaLastRescan >= 0.2 then
				tkaLastRescan = now
				tkaRescanKnives()
			end

			for knifeInst, lastPos in pairs(activeThrownKnives) do
				if not (knifeInst.Parent and knifeInst:IsDescendantOf(Workspace))
					or not tkaIsThrownKnife(knifeInst) then
					-- [fix] Same as in tkaRescanKnives: the knife just despawned,
					-- use its last known position to latch nearby targets.
					activeThrownKnives[knifeInst] = nil
					pcall(tkaMarkTargetsNear, lastPos)
				else
					local kPos = tkaGetKnifePosition(knifeInst)
					if kPos then
						activeThrownKnives[knifeInst] = kPos -- keep last known position fresh
						pcall(tkaMarkTargetsNear, kPos)
					end
				end
			end

			-- [fix] Keep retrying kills on latched targets every frame until they
			-- die or the retry window expires. This survives the knife tool's
			-- post-throw cooldown / re-equip, which is what broke close-range kills.
			pcall(tkaProcessPendingKills)

			-- [fix] Anti-pull: revert the game's delayed grab/teleport toward the
			-- victim. Must run every Heartbeat, not only on stab frames, because
			-- the yank lands a few frames after the hit registers.
			pcall(tkaGuardCheck)
		end)
	else
		if throwingKnifeAuraConnection then
			throwingKnifeAuraConnection:Disconnect()
			throwingKnifeAuraConnection = nil
		end
		activeThrownKnives = {}
		tkaPendingKills = {}
		tkaGuardUntil = 0
		tkaGuardLastPos = nil
	end
end

-- Air Strafe functions
function checkStrafeSequence(keyCode)
	if not airStrafeEnabled then return end
	local currentTime = tick()
	if keyCode == Enum.KeyCode.A or keyCode == Enum.KeyCode.D then
		if lastKey and lastKey ~= keyCode and (currentTime - lastKeyTime) <= strafeInterval then
			isStrafing = true
			task.delay(strafeInterval, function()
				isStrafing = false
			end)
		end
		lastKey = keyCode
		lastKeyTime = currentTime
	end
end

function setupAirStrafe()
	if airStrafeConnection then
		airStrafeConnection:Disconnect()
		airStrafeConnection = nil
	end
	if airStrafeInputConnection then
		airStrafeInputConnection:Disconnect()
		airStrafeInputConnection = nil
	end

	if not airStrafeEnabled then return end

	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChild("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not (hum and hrp) then return end

	airStrafeInputConnection = UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.D then
			checkStrafeSequence(input.KeyCode)
		end
	end)

	airStrafeConnection = RunService.Heartbeat:Connect(function()
		if not airStrafeEnabled then return end
		local c = player.Character
		if not c then return end
		local h = c:FindFirstChild("Humanoid")
		local r = c:FindFirstChild("HumanoidRootPart")
		if not (h and r) then return end
		local state = h:GetState()
		if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
			if isStrafing then
				local moveDir = Vector3.new(0, 0, 0)
				if UserInputService:IsKeyDown(Enum.KeyCode.A) then
					moveDir = moveDir + Vector3.new(-1, 0, 0)
				end
				if UserInputService:IsKeyDown(Enum.KeyCode.D) then
					moveDir = moveDir + Vector3.new(1, 0, 0)
				end
				if moveDir.Magnitude > 0 then
					moveDir = moveDir.Unit
					local cameraCFrame = Workspace.CurrentCamera.CFrame
					moveDir = cameraCFrame:VectorToWorldSpace(moveDir)
					moveDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
					local vel = r.Velocity
					r.Velocity = Vector3.new(
						moveDir.X * maxAirSpeed * airStrafeMultiplier,
						vel.Y,
						moveDir.Z * maxAirSpeed * airStrafeMultiplier
					)
				end
			end
		end
	end)

	local diedConn
	diedConn = hum.Died:Connect(function()
		if airStrafeConnection then
			airStrafeConnection:Disconnect()
			airStrafeConnection = nil
		end
		if airStrafeInputConnection then
			airStrafeInputConnection:Disconnect()
			airStrafeInputConnection = nil
		end
		if diedConn then
			diedConn:Disconnect()
			diedConn = nil
		end
	end)
end

function toggleAirStrafe()
	airStrafeEnabled = not airStrafeEnabled
	setupAirStrafe()
end


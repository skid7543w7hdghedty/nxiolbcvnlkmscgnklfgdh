	local ok, result = pcall(function() return listfiles(CLICK_SOUNDS_DIR) end)
	if ok then
		for _, path in ipairs(result) do
			local lower = string.lower(path)
			if lower:match("%.mp3$") then
				table.insert(files, path)
			end
		end
	end
	return files
end


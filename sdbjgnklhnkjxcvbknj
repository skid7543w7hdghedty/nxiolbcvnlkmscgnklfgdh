	scrollFrame.Position = UDim2.new(0, 8, 0, 8)
	scrollFrame.Size = UDim2.new(1, -16, 1, -16)
	scrollFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	scrollFrame.BorderSizePixel = 0
	scrollFrame.ScrollBarThickness = 4
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	scrollFrame.Parent = pickerFrame
	local scrollCorner = Instance.new("UICorner")
	scrollCorner.CornerRadius = UDim.new(0, 6)
	scrollCorner.Parent = scrollFrame
	local scrollPadding = Instance.new("UIPadding")
	scrollPadding.PaddingLeft = UDim.new(0, 4)
	scrollPadding.PaddingRight = UDim.new(0, 4)
	scrollPadding.PaddingTop = UDim.new(0, 4)
	scrollPadding.PaddingBottom = UDim.new(0, 4)
	scrollPadding.Parent = scrollFrame
	state.scrollFrame = scrollFrame

	local function applyFilter()
		local searchText = string.lower(searchBox.Text)
		for _, data in pairs(state.checkboxes) do
			if data.Entry and data.NameLabel then
				data.Entry.Visible = searchText == "" or string.find(string.lower(data.NameLabel.Text), searchText, 1, true) ~= nil
			end
		end
	end

	local function updateStatus()
		if state.selectedName then
			statusLabel.Text = "Target: " .. state.selectedName
			statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		else
			statusLabel.Text = opts.statusText or "Select a player"
			statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end

	local function refresh()
		if not scrollFrame then return end
		for _, child in ipairs(scrollFrame:GetChildren()) do
			if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
				child:Destroy()
			end
		end
		state.checkboxes = {}
		local playerList = Players:GetPlayers()
		if state.selectedName then
			local found = false
			for _, plr in ipairs(playerList) do

function formatRegDate(accountAge)
	local now = os.time()
	local utcDate = os.date("!*t", now)
	local isPDT = utcDate.month > 3 and utcDate.month < 11
	local ptOffset = isPDT and -7 or -8
	local ptTimestamp = now + ptOffset * 3600
	local ptDate = os.date("!*t", ptTimestamp)
	local d = ptDate.day - math.max(accountAge - 1, 0)
	local m = ptDate.month
	local y = ptDate.year
	local daysInMonth = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
	while d < 1 do
		m = m - 1
		if m < 1 then
			m = 12
			y = y - 1
		end
		local dim = daysInMonth[m]
		if m == 2 and (y % 4 == 0 and (y % 100 ~= 0 or y % 400 == 0)) then dim = 29 end
		d = d + dim
	end
	return string.format("%02d/%02d/%04d", d, m, y)
end


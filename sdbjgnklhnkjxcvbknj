-- Load a catalog asset. GetObjects is the most reliable across executors (many
-- block InsertService:LoadAsset for assets the game does not own). Returns the
-- list of root instances (Accessory / Shirt / Pants / ShirtGraphic / etc).
function changerLoadObjects(id)
    local objs
    local ok = pcall(function() objs = game:GetObjects("rbxassetid://" .. id) end)
    if (not ok) or (not objs) or (#objs == 0) then
        objs = nil
        local m
        local ok2 = pcall(function() m = game:GetService("InsertService"):LoadAsset(tonumber(id)) end)
        if ok2 and m then objs = m:GetChildren() end
    end
    return objs or {}
end




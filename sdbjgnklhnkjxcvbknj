function espHookGunDrop(gunDrop)
	if espTrackedGuns[gunDrop] then return end
	espCreateGunHighlight(gunDrop)
	local _, distLabel = espCreateGunBillboard(gunDrop)
	-- [perf] distance text only needs a few updates per second, not one per frame;
	-- also skip the (expensive on mobile) TextLabel.Text write when unchanged
	local lastGunDistText = nil
	local conn = RunService.Heartbeat:Connect(function()
		if not espEnabled then return end
		if _espFrameCounter % 10 ~= 0 then return end
		if not gunDrop or not gunDrop.Parent then return end
		if distLabel then
			local pos = espGetGunPosition(gunDrop)
			if pos then
				local dist = espGetDistFromPos(pos)
				local txt = dist and ("[" .. tostring(dist) .. "m]") or ""
				if txt ~= lastGunDistText then
					lastGunDistText = txt
					distLabel.Text = txt
				end
			end
		end
	end)
	espTrackedGuns[gunDrop] = { conn = conn }
	gunDrop.AncestryChanged:Connect(function(_, parent)
		if not parent then
			if espTrackedGuns[gunDrop] then
				if espTrackedGuns[gunDrop].conn then
					espTrackedGuns[gunDrop].conn:Disconnect()
				end
				espTrackedGuns[gunDrop] = nil
			end
			espCleanGun(gunDrop)
		end
	end)
end

function espFindGunDropsInModel(mapModel)

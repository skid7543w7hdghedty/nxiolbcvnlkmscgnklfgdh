			borderStroke.Color = Color3.fromRGB(255, 255, 255)
			borderStroke.Thickness = 1.5
			borderStroke.Parent = popupBorder

			local borderCorner = Instance.new("UICorner")
			borderCorner.CornerRadius = UDim.new(0, 6)
			borderCorner.Parent = popupBorder

			local function fpsPingMakeDraggable(dragFrame)
				local d = false
				local dm = false
				local ds, sp
				local TH = 5
				dragFrame.InputBegan:Connect(function(ipt)
					if popupDragLocked then return end
					if ipt.UserInputType == Enum.UserInputType.MouseButton1 then
						d = true; dm = false; ds = ipt.Position; sp = popupBorder.Position
					end
				end)
				local conn = UserInputService.InputChanged:Connect(function(ipt)
					if popupDragLocked then return end
					if ipt.UserInputType == Enum.UserInputType.MouseMovement and d then
						local delta = ipt.Position - ds
						if delta.Magnitude >= TH then dm = true end
						if dm then
							popupBorder.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y)
						end
					end
				end)
				dragFrame.InputEnded:Connect(function(ipt)
					if ipt.UserInputType == Enum.UserInputType.MouseButton1 then
						local wasDragged = dm
						d = false; dm = false
						if wasDragged then saveConfig() end
					end
				end)
				return conn
			end

			local data = { btn = popupBorder, popupBtn = nil, popupLockBtn = nil, dragConn = nil }


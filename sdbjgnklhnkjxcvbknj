function espGetRoleColor(plr)
	if not plr then return ESP_DEFAULT_COLOR end
	if not espRoles then return ESP_DEFAULT_COLOR end
	if not espIsAlive(plr) then return ESP_DEAD_COLOR end
	local data = espRoles[plr.Name]
	if not data then return ESP_DEFAULT_COLOR end
	if data.Role == "Murderer" then return ESP_MURDERER_COLOR
	elseif data.Role == "Sheriff" then return ESP_SHERIFF_COLOR
	elseif espIsHero(plr) then return ESP_HERO_COLOR
	else return ESP_DEFAULT_COLOR end
end

function espIsHero(plr)
	if not plr then return false end
	if not espRoles then return false end
	local data = espRoles[plr.Name]
	if not data then return false end
	if data.Role == "Murderer" then return false end
	if data.Role == "Sheriff" then return false end
	local sheriffName = nil
	for name, v in pairs(espRoles) do
		if v.Role == "Sheriff" then sheriffName = name; break end
	end
	if sheriffName then
		local sheriffPlr = Players:FindFirstChild(sheriffName)
		if sheriffPlr and espIsAlive(sheriffPlr) then return false end
	end
	if plr.Name == espCurrentHero then return true end
	if data.HasGun then return true end
	local char = plr.Character
	if char then
		for _, tool in ipairs(char:GetChildren()) do
			if tool:IsA("Tool") and tool.Name:lower():find("gun") then
				return true
			end
		end
		local backpack = plr:FindFirstChild("Backpack")
		if backpack then
			for _, tool in ipairs(backpack:GetChildren()) do
				if tool:IsA("Tool") and tool.Name:lower():find("gun") then
					return true
				end
			end
		end
	end
	return false
end

function espGetRoleName(plr)
	if not espRoles then return "" end
	local data = espRoles[plr.Name]
	if not data then return "" end
	if data.Role == "Murderer" then return " [MURDERER]"
	elseif data.Role == "Sheriff" then return " [SHERIFF]"
	elseif espIsHero(plr) then return " [HERO]"
	else return "" end

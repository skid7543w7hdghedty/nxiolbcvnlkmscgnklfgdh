-- Change / Unchange buttons
do
	local changeBtn = createButton("SkyboxChangeBtn", "Change", 430)
	changeBtn.MouseButton1Click:Connect(function()
		local nm = skyboxPickerState and skyboxPickerState.selectedName
		if nm and savedSkyboxes[nm] then
			-- Load preset into input fields
			local preset = savedSkyboxes[nm]
			if type(preset) == "table" then
				for _, face in ipairs(skyboxFaces) do
					if skyboxFaceInputs[face] then
						skyboxFaceInputs[face].Text = preset[face] or ""
					end
				end
				-- Build face table and apply
				local ft = {}
				for _, face in ipairs(skyboxFaces) do
					if preset[face] then
						ft[face] = "rbxassetid://" .. preset[face]
					end
				end
				skyboxApplyFaces(ft)
				notify("Skybox", "Applied preset: " .. nm, 2)
			elseif type(preset) == "string" then
				-- Legacy: single ID for all faces (backward compat)
				for _, face in ipairs(skyboxFaces) do
					if skyboxFaceInputs[face] then
						skyboxFaceInputs[face].Text = preset
					end
				end
				local url = "rbxassetid://" .. preset
				local ft = {}
				for _, face in ipairs(skyboxFaces) do ft[face] = url end
				skyboxApplyFaces(ft)
				notify("Skybox", "Applied preset: " .. nm, 2)
			end
		else
			-- No preset selected — apply from input fields
			local faces, count = skyboxCollectInputs()
			if count == 0 then
				notify("Skybox", "Fill in at least one face ID", 2)
				return
			end
			skyboxApplyFaces(faces)
			notify("Skybox", "Applied " .. count .. " face(s)", 2)
		end
	end)

	local unchangeBtn = createButton("SkyboxUnchangeBtn", "Unchange", 431)
	unchangeBtn.MouseButton1Click:Connect(function()
		skyboxUnchange()
		notify("Skybox", "Restored default skybox", 2)
	end)
end



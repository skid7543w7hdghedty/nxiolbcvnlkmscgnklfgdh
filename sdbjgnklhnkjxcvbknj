function toggleAutoInvis()
	if not autoInvisBtn then return end
	autoInvisEnabled = not autoInvisEnabled
	if autoInvisEnabled then
		autoInvisBtn.Text = "Auto Invisibility: ON"
		autoInvisBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		autoInvisBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
		autoInvisActive = false
		autoInvisFrame = 0
		autoInvisConnection = RunService.Heartbeat:Connect(function()
			if not autoInvisEnabled then return end
			autoInvisFrame = autoInvisFrame + 1
			if autoInvisFrame % 45 ~= 0 then return end
			local murdererPos = getMurdererPosition()
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			local inZone = false
			if murdererPos then
				local dist = (hrp.Position - murdererPos).Magnitude
				if not autoInvisActive and dist <= autoInvisActivateDist then
					inZone = true
				elseif autoInvisActive and dist > autoInvisDeactivateDist then
					inZone = false
				else
					inZone = autoInvisActive
				end
			end
			if inZone and not autoInvisActive then
				if not invis_on then
					invis_on = true
					local savedpos = hrp.CFrame
					player.Character:MoveTo(Vector3.new(-25.95, 84, 3537.55))
					task.wait(0.15)
					local Seat = Instance.new("Seat", workspace)
					Seat.Anchored = false
					Seat.CanCollide = false
					Seat.Name = "invischair"
					Seat.Transparency = 1
					Seat.Position = Vector3.new(-25.95, 84, 3537.55)
					local Weld = Instance.new("Weld", Seat)
					Weld.Part0 = Seat
					Weld.Part1 = player.Character:FindFirstChild("Torso") or player.Character.UpperTorso
					Seat.CFrame = savedpos
					setToggleState(button5, true, "Invisibility: ON", "Invisibility: OFF")
					setExtractedBtnState("Invisibility", true)
				end
				autoInvisActive = true
			elseif not inZone and autoInvisActive then
				if invis_on then
					invis_on = false

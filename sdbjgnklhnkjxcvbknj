-- Coin Aura — magnetically attract coins within radius
-- Works independently or alongside the autofarm
-- ============================================
coinAuraEnabled = false
coinAuraRadius = 10
coinAuraConnections = {}

function coinAuraGetRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

function coinAuraGetCoinPart(coin)
	if coin:IsA("BasePart") then return coin end
	local p = coin:FindFirstChild("Coin")
	if p and p:IsA("BasePart") then return p end
	return coin:FindFirstChildWhichIsA("BasePart")
end

function coinAuraTouchCoin(root, coinPart)
	if not (root and coinPart and coinPart.Parent) then return end
	pcall(function()
		coinPart.CFrame = root.CFrame
		coinPart.CanCollide = false
	end)
	safeFireTouch(root, coinPart)
end

function enableCoinAura()
	coinAuraEnabled = true
	for _, conn in ipairs(coinAuraConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
	end
	coinAuraConnections = {}

	-- Main distance-check loop: every Heartbeat frame
	table.insert(coinAuraConnections, RunService.Heartbeat:Connect(function()
		if not coinAuraEnabled then return end
		local root = coinAuraGetRoot()
		if not root then return end
		local playerPos = root.Position
		-- Scan CoinContainer for nearby coins
		local cc = Workspace:FindFirstChild("CoinContainer", true)
		if not cc then return end
		for _, coin in ipairs(cc:GetChildren()) do
			if coin.Parent then
				local coinPart = coinAuraGetCoinPart(coin)
				if coinPart then
					local dist = (playerPos - coinPart.Position).Magnitude
					if dist <= coinAuraRadius then
						coinAuraTouchCoin(root, coinPart)
					end
				end
			end
		end
	end))

	-- Rescan on respawn
	table.insert(coinAuraConnections, player.CharacterAdded:Connect(function()
		if not coinAuraEnabled then return end
		-- The Heartbeat loop handles the rest automatically
	end))
end

function disableCoinAura()
	coinAuraEnabled = false
	for _, conn in ipairs(coinAuraConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
	end
	coinAuraConnections = {}
end

function toggleCoinAura()
	if coinAuraEnabled then
		disableCoinAura()
	else
		enableCoinAura()
	end
end


function gameNotifSend(title, text, color, strokeColor)
	if not gameNotifEnabled then return end

	local notifGui = player:FindFirstChild("PlayerGui") and player.PlayerGui:FindFirstChild("GameNotifGui")
	if not notifGui then
		notifGui = Instance.new("ScreenGui")
		notifGui.Name = "GameNotifGui"
		notifGui.ResetOnSpawn = false
		notifGui.DisplayOrder = 999999
		notifGui.IgnoreGuiInset = true
		notifGui.Parent = player.PlayerGui
	end

	-- Считаем сколько уведомлений уже на экране
	local slotIndex = #gameNotifActiveNotifs

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, 340, 0, 0)
	frame.Position = UDim2.new(1, -350, 1, -10 - (slotIndex * 90))
	frame.AnchorPoint = Vector2.new(0, 1)
	frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true
	frame.Parent = notifGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = frame

	local stroke = Instance.new("UIStroke")
	stroke.Color = strokeColor or color or Color3.fromRGB(255, 255, 255)
	stroke.Thickness = 1
	stroke.Parent = frame

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, -20, 0, 24)
	titleLabel.Position = UDim2.new(0, 10, 0, 10)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title or ""
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = 15
	titleLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextScaled = false
	titleLabel.Parent = frame

	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1, -20, 0, 40)
	textLabel.Position = UDim2.new(0, 10, 0, 32)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = text or ""
	textLabel.Font = Enum.Font.Gotham
	textLabel.TextSize = 14
	textLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
	textLabel.TextXAlignment = Enum.TextXAlignment.Left
	textLabel.TextWrapped = true
	textLabel.TextScaled = false
	textLabel.Parent = frame

	-- Добавляем в список активных
	table.insert(gameNotifActiveNotifs, frame)

	-- Анимация появления
	TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 340, 0, 80)
	}):Play()

	-- Исчезновение через 4 секунды
	task.delay(4, function()
		local fadeOut = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 340, 0, 0)
		})
		fadeOut:Play()
		fadeOut.Completed:Wait()

		-- Удаляем из списка
		for i, f in ipairs(gameNotifActiveNotifs) do
			if f == frame then
				table.remove(gameNotifActiveNotifs, i)
				break
			end
		end
		frame:Destroy()

		-- Сдвигаем оставшиеся уведомления вниз
		gameNotifRepositionAll()
	end)
end

function gameNotifRepositionAll()
	for i, frame in ipairs(gameNotifActiveNotifs) do
		local targetPos = UDim2.new(1, -350, 1, -10 - ((i - 1) * 90))
		TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = targetPos
		}):Play()
	end
end


-- ============================================
-- [perf] Shared GetPlayerData remote + role-data cache
-- ============================================
-- The script previously had 13 separate places doing
-- ReplicatedStorage:FindFirstChild("GetPlayerData", true) — a RECURSIVE scan of all
-- of ReplicatedStorage — and 6+ independent loops each calling :InvokeServer()
-- every 0.5-1s. On mobile those recursive scans + parallel remote invocations were
-- a major source of freezes. Now the remote is resolved once and cached, and all
-- periodic pollers share ONE InvokeServer result (refreshed at most every 0.35s).
_playerDataRemote = nil
function getPlayerDataRemote()
	if _playerDataRemote and _playerDataRemote.Parent then
		return _playerDataRemote
	end
	_playerDataRemote = ReplicatedStorage:FindFirstChild("GetPlayerData", true)
	return _playerDataRemote
end

_roleDataCache = nil
_roleDataCacheAt = 0
_roleDataInFlight = false
function invokePlayerData()
	local now = os.clock()
	if _roleDataCache and (now - _roleDataCacheAt) <= 0.35 then
		return _roleDataCache
	end
	if _roleDataInFlight then
		-- Another loop is already fetching; reuse the last known data instead of
		-- stacking a second server invocation.
		return _roleDataCache
	end
	_roleDataInFlight = true
	local ok, result = pcall(function()
		local remote = getPlayerDataRemote()
		return remote and remote:InvokeServer()
	end)
	_roleDataInFlight = false
	if ok and type(result) == "table" then
		_roleDataCache = result
		_roleDataCacheAt = os.clock()
	end
	return _roleDataCache
end

-- Murderer check with caching
cachedIsMurderer = false
lastMurdererCheck = 0

function isPlayerMurderer()
	if tick() - lastMurdererCheck > 1.0 then
		lastMurdererCheck = tick()
		local ok, result = pcall(function()
			return invokePlayerData()
		end)
		if ok and result then
			for name, data in pairs(result) do
				if name == player.Name then
					cachedIsMurderer = (data.Role == "Murderer")
					return cachedIsMurderer
				end
			end
		end
		cachedIsMurderer = false
	end
	return cachedIsMurderer
end


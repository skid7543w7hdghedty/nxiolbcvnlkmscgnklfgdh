-- ============================================
-- Exact timestamp from ISO 8601
-- ============================================
function isoToUnix(iso)
	local y, mo, d, h, mi, s = iso:match("(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)")
	if not y then return nil end
	y, mo, d, h, mi, s = tonumber(y), tonumber(mo), tonumber(d), tonumber(h), tonumber(mi), tonumber(s)
	local dim = {31,28,31,30,31,30,31,31,30,31,30,31}
	local function isLeap(yy) return (yy%4==0 and yy%100~=0) or yy%400==0 end
	local days = 0
	for yy = 1970, y-1 do days = days + (isLeap(yy) and 366 or 365) end
	for mm = 1, mo-1 do
		days = days + dim[mm]
		if mm == 2 and isLeap(y) then days = days + 1 end
	end
	days = days + d - 1
	return days * 86400 + h * 3600 + mi * 60 + s
end


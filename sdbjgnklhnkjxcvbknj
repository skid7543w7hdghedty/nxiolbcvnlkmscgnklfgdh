		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}}
	elseif style == "Fade Only" then
		openInfo = {info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props = {BackgroundTransparency = mainBgTransparency, Size = UDim2.new(0, mainMenuWidth, 0, mainMenuHeight)}}
		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {BackgroundTransparency = 1, Size = UDim2.new(0, mainMenuWidth, 0, mainMenuHeight)}}
	elseif style == "Slide Left" then
		mainFrame.Position = open and UDim2.new(-1, 0, savedMenuPos.Y.Scale, savedMenuPos.Y.Offset) or savedMenuPos
		openInfo = {info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props = {Position = savedMenuPos}}
		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Position = UDim2.new(-1, 0, savedMenuPos.Y.Scale, savedMenuPos.Y.Offset)}}
	elseif style == "Slide Right" then
		mainFrame.Position = open and UDim2.new(1, 0, savedMenuPos.Y.Scale, savedMenuPos.Y.Offset) or savedMenuPos
		openInfo = {info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props = {Position = savedMenuPos}}
		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Position = UDim2.new(1, 0, savedMenuPos.Y.Scale, savedMenuPos.Y.Offset)}}
	elseif style == "Slide Up" then
		mainFrame.Position = open and UDim2.new(savedMenuPos.X.Scale, savedMenuPos.X.Offset, 1, 0) or savedMenuPos
		openInfo = {info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props = {Position = savedMenuPos}}
		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Position = UDim2.new(savedMenuPos.X.Scale, savedMenuPos.X.Offset, 1, 0)}}
	elseif style == "Bounce" then
		openInfo = {info = TweenInfo.new(0.4, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), props = {Size = UDim2.new(0, mainMenuWidth, 0, mainMenuHeight), BackgroundTransparency = mainBgTransparency}}
		closeInfo = {info = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}}
	elseif style == "Scale+Fade" then
		openInfo = {info = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), props = {Size = UDim2.new(0, mainMenuWidth, 0, mainMenuHeight), BackgroundTransparency = mainBgTransparency}}
		closeInfo = {info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), props = {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}}
	end

	if open then

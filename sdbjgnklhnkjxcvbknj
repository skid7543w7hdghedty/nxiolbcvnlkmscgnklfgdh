createSection("Server Hop", 315)

-- Queue the script for re-execution after the teleport so it auto-loads on the
-- new server and the config restore re-enables everything that was turned on.
-- REQUIRES: the 'Script URL' box filled with a raw link to THIS script
-- (e.g. https://raw.githubusercontent.com/your-user/your-repo/main/script.lua)
function autofarmQueueRejoin()
	local url = tostring(AUTOFARM_SCRIPT_URL or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if url == "" then return false end
	local q = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
	if not q then return false end
	local ok = pcall(q, string.format('task.wait(3) loadstring(game:HttpGet(%q))()', url))
	return ok
end

function autofarmServerHop()
	-- Persist the current toggles FIRST: autofarm state, speed, webhook etc are
	-- restored straight from the saved config after the rejoin.
	pcall(saveConfig)
	if not autofarmQueueRejoin() then
		notify("Server Hop", "Fill Script URL box to auto-load after hop (or your executor lacks queue_on_teleport)", 5)
	end
	local hopped = false
	pcall(function()
		local raw = game:HttpGet(string.format(
			"https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&excludeFullGames=true&limit=100",
			game.PlaceId))
		local data = game:GetService("HttpService"):JSONDecode(raw)
		local candidates = {}
		for _, srv in ipairs((data and data.data) or {}) do
			if srv.id and srv.id ~= game.JobId and type(srv.playing) == "number" and srv.playing < (srv.maxPlayers or 12) then
				table.insert(candidates, srv.id)
			end
		end
		if #candidates > 0 then
			TeleportService:TeleportToPlaceInstance(game.PlaceId, candidates[math.random(1, #candidates)], player)
			hopped = true
		end
	end)
	if not hopped then
		-- Fallback: plain re-teleport into the place (Roblox picks the server)
		pcall(function() TeleportService:Teleport(game.PlaceId, player) end)
	end
end

-- Monitor: hop after being alone on the server for ~10 seconds straight
task.spawn(function()
	local aloneSince = nil
	local hopInProgress = false
	while task.wait(2) do
		if autofarmServerHopEnabled and not hopInProgress then
			if #Players:GetPlayers() <= 1 then
				aloneSince = aloneSince or os.clock()
				if (os.clock() - aloneSince) >= 10 then
					hopInProgress = true
					notify("Server Hop", "Alone on the server — hopping to another one...", 3)
					autofarmServerHop()
					task.wait(30) -- teleport failed/throttled -> allow a retry
					hopInProgress = false
					aloneSince = nil
				end
			else
				aloneSince = nil
			end
		end
	end
end)


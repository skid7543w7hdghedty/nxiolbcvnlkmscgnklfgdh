-- Tracking per watched player
watchRoleTrackedMurderers = {}
watchRoleTrackedSheriffs = {}
watchRoleLoopingSheriff = false
watchRoleLoopingMurderer = false

local function watchRoleIsTargetAlive(roleName)
	local ok2, res2 = pcall(function()
		return invokePlayerData()
	end)
	if not (ok2 and res2) then return false end
	for name, data in pairs(res2) do
		if data.Role == roleName then
			local plr = Players:FindFirstChild(name)
			if plr and plr.Character then
				local hum = plr.Character:FindFirstChild("Humanoid")
				return hum and hum.Health > 0
			end
			return false
		end
	end
	return false
end

local function watchRoleGetCurrentRoles()
	local ok, result = pcall(function()
		return invokePlayerData()
	end)
	if not (ok and result) then return {}, {} end
	local curMurderer, curSheriff = "", ""
	for name, data in pairs(result) do
		if data.Role == "Murderer" then curMurderer = name end
		if data.Role == "Sheriff" then curSheriff = name end
	end
	return curMurderer, curSheriff
end

task.spawn(function()
	while true do
		task.wait(0.5)
		local watchNamesM = watchMurdererPicker and watchMurdererPicker.selectedNames or {}
		local watchNamesS = watchSheriffPicker and watchSheriffPicker.selectedNames or {}
		if #watchNamesM == 0 and #watchNamesS == 0 then
			watchRoleTrackedMurderers = {}
			watchRoleTrackedSheriffs = {}
			continue
		end
		local curMurderer, curSheriff = watchRoleGetCurrentRoles()

		-- Watch for Murderer: if any watched player just became Murderer
		for _, watchName in ipairs(watchNamesM) do
			if curMurderer == watchName and not watchRoleTrackedMurderers[watchName] and not watchRoleLoopingSheriff then
				watchRoleTrackedMurderers[watchName] = true
				notify("Watch Role", watchName .. " became Murderer — loop resetting Sheriff!", 3)
				watchRoleLoopingSheriff = true
				task.spawn(function()
					while watchRoleLoopingSheriff do
						executeNanFlingByRole("Sheriff")
						for _waitI = 1, 5 do
							task.wait(0.5)
							if not watchRoleIsTargetAlive("Sheriff") and not watchRoleIsTargetAlive("Hero") then
								watchRoleLoopingSheriff = false
								notify("Watch Role", "Sheriff/Hero is dead — stopped", 2)
								break
							end
						end
						if not watchRoleLoopingSheriff then break end
					end
				end)
			end
		end
		for name, _ in pairs(watchRoleTrackedMurderers) do
			if curMurderer ~= name then watchRoleTrackedMurderers[name] = nil end
		end

		-- Watch for Sheriff: if any watched player just became Sheriff
		for _, watchName in ipairs(watchNamesS) do
			if curSheriff == watchName and not watchRoleTrackedSheriffs[watchName] and not watchRoleLoopingMurderer then
				watchRoleTrackedSheriffs[watchName] = true
				notify("Watch Role", watchName .. " became Sheriff — loop resetting Murderer!", 3)
				watchRoleLoopingMurderer = true
				task.spawn(function()
					while watchRoleLoopingMurderer do
						executeNanFlingByRole("Murderer")
						for _waitI = 1, 5 do
							task.wait(0.5)
							if not watchRoleIsTargetAlive("Murderer") then
								watchRoleLoopingMurderer = false
								notify("Watch Role", "Murderer is dead — stopped", 2)
								break
							end
						end
						if not watchRoleLoopingMurderer then break end
					end
				end)
			end
		end
		for name, _ in pairs(watchRoleTrackedSheriffs) do
			if curSheriff ~= name then watchRoleTrackedSheriffs[name] = nil end
		end
	end
end)


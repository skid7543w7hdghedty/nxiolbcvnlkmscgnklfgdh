function getMurdererPosition()
	local ok, result = pcall(function()
		return invokePlayerData()
	end)
	if ok and result then
		for name, data in pairs(result) do
			if data.Role == "Murderer" then
				local plr = Players:FindFirstChild(name)
				if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
					return plr.Character.HumanoidRootPart.Position
				end
			end
		end
	end
	return nil
end

function toggleAutoInvis()
	if not autoInvisBtn then return end
	autoInvisEnabled = not autoInvisEnabled
	if autoInvisEnabled then
		autoInvisBtn.Text = "Auto Invisibility: ON"
		autoInvisBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		autoInvisBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
		autoInvisActive = false
		autoInvisFrame = 0
		autoInvisConnection = RunService.Heartbeat:Connect(function()
			if not autoInvisEnabled then return end
			autoInvisFrame = autoInvisFrame + 1
			if autoInvisFrame % 45 ~= 0 then return end
			local murdererPos = getMurdererPosition()
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			local inZone = false
			if murdererPos then
				local dist = (hrp.Position - murdererPos).Magnitude
				if not autoInvisActive and dist <= autoInvisActivateDist then
					inZone = true
				elseif autoInvisActive and dist > autoInvisDeactivateDist then
					inZone = false
				else
					inZone = autoInvisActive
				end
			end
			if inZone and not autoInvisActive then
				if not invis_on then
					invis_on = true
					local voidPos = Vector3.new(-25.95, 84, 3537.55)
					-- Same as the manual toggle: hard-pin the root in the void every frame
					-- (no snap-back) so the server/others keep seeing you in the void.
					if invisHoldConnection then invisHoldConnection:Disconnect() invisHoldConnection = nil end
					invisHoldConnection = RunService.Heartbeat:Connect(function()
						if not invis_on then
							if invisHoldConnection then invisHoldConnection:Disconnect() invisHoldConnection = nil end
							return
						end
						local c = player.Character
						local h = c and c:FindFirstChild("HumanoidRootPart")
						local hm = c and c:FindFirstChildOfClass("Humanoid")
						if h and hm and hm.Health > 0 then
							h.CFrame = CFrame.new(voidPos)
							keepAssemblyAwake(h, hm)
						end
					end)
					setToggleState(button5, true, "Invisibility: ON", "Invisibility: OFF")
					setExtractedBtnState("Invisibility", true)
				end
				autoInvisActive = true
			elseif not inZone and autoInvisActive then
				if invis_on then
					invis_on = false
					if invisHoldConnection then invisHoldConnection:Disconnect() invisHoldConnection = nil end
					invisRealCF = nil
					local chair = workspace:FindFirstChild("invischair")
					if chair then chair:Destroy() end
					setToggleState(button5, false, "Invisibility: ON", "Invisibility: OFF")
					setExtractedBtnState("Invisibility", false)
				end
				autoInvisActive = false
			end
		end)
	else
		autoInvisBtn.Text = "Auto Invisibility: OFF"
		autoInvisBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		autoInvisBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		if autoInvisConnection then
			autoInvisConnection:Disconnect()
			autoInvisConnection = nil
		end
		autoInvisActive = false
	end
	setExtractedBtnState("Auto Invisibility", autoInvisEnabled)
	saveConfig()
end


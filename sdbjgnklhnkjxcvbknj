-- Bang (adapted from Yield.lua)
bangEnabled = false
bangAnim = nil
bangAnimTrack = nil
bangDiedConn = nil
bangLoopConn = nil

function startBang(targetPlayer, speed)
	local char = player.Character
	if not char then return end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	stopBang()
	task.wait()
	bangEnabled = true
	bangAnim = Instance.new("Animation")
	-- R15 check: if Humanoid.RigType is R15, use R15 anim; else R6
	if humanoid.RigType == Enum.HumanoidRigType.R15 then
		bangAnim.AnimationId = "rbxassetid://5918726674"
	else
		bangAnim.AnimationId = "rbxassetid://148840371"
	end
	bangAnimTrack = humanoid:FindFirstChildOfClass("Animator") and humanoid:FindFirstChildOfClass("Animator"):LoadAnimation(bangAnim) or humanoid:LoadAnimation(bangAnim)
	bangAnimTrack:Play(0.1, 1, 1)
	bangAnimTrack:AdjustSpeed(speed or 3)
	bangDiedConn = humanoid.Died:Connect(function()
		stopBang()
	end)
	if targetPlayer and targetPlayer.Character then
		local bangOffset = CFrame.new(0, 0, 1.1)
		bangLoopConn = RunService.Stepped:Connect(function()
			pcall(function()
				local otherRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or targetPlayer.Character:FindFirstChild("Torso")
				local myRoot = player.Character:FindFirstChild("HumanoidRootPart")
				if otherRoot and myRoot then
					myRoot.CFrame = otherRoot.CFrame * bangOffset
				end
			end)
		end)
	end
end

function stopBang()
	bangEnabled = false
	if bangDiedConn then pcall(function() bangDiedConn:Disconnect() end); bangDiedConn = nil end
	if bangAnimTrack then pcall(function() bangAnimTrack:Stop() end); bangAnimTrack = nil end
	if bangAnim then pcall(function() bangAnim:Destroy() end); bangAnim = nil end
	if bangLoopConn then pcall(function() bangLoopConn:Disconnect() end); bangLoopConn = nil end
end


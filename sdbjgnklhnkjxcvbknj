	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Padding = UDim.new(0, -1)
	layout.Parent = textsFrame

	-- Animate blur in
	TweenService:Create(blur, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = 50}):Play()
	TweenService:Create(blackFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.6}):Play()
	task.wait(0.3)

	local loadText = "Adrenalin.win"
	local textObjs = {}

	if style == "Letter by Letter" then
		for i = 1, #loadText do
			local char = loadText:sub(i, i)
			local letterFrame = Instance.new("Frame")
			letterFrame.Size = UDim2.new(0, 35, 0, 100)
			letterFrame.BackgroundTransparency = 1
			letterFrame.LayoutOrder = i
			letterFrame.Parent = textsFrame

			local letterLabel = Instance.new("TextLabel")
			letterLabel.AnchorPoint = Vector2.new(0.5, 0.5)
			letterLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
			letterLabel.Size = UDim2.new(0, 30, 0, 60)
			letterLabel.BackgroundTransparency = 1
			letterLabel.Text = char
			letterLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
			letterLabel.Font = Enum.Font.GothamBold
			letterLabel.TextSize = 40
			letterLabel.TextTransparency = 1
			letterLabel.Parent = letterFrame

			table.insert(textObjs, letterLabel)
		end

		for i, lbl in ipairs(textObjs) do
			TweenService:Create(lbl, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
			task.wait(0.06)
		end

	elseif style == "Fade In" then
		local fullLabel = Instance.new("TextLabel")
		fullLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		fullLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
		fullLabel.Size = UDim2.new(0, 500, 0, 80)
		fullLabel.BackgroundTransparency = 1
		fullLabel.Text = loadText
		fullLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		fullLabel.Font = Enum.Font.GothamBold
		fullLabel.TextSize = 48
		fullLabel.TextTransparency = 1
		fullLabel.Parent = textsFrame

		TweenService:Create(fullLabel, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()

	elseif style == "Scale Up" then
		local fullLabel = Instance.new("TextLabel")
		fullLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		fullLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
		fullLabel.Size = UDim2.new(0, 500, 0, 80)
		fullLabel.BackgroundTransparency = 1
		fullLabel.Text = loadText
		fullLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		fullLabel.Font = Enum.Font.GothamBold
		fullLabel.TextSize = 10
		fullLabel.TextTransparency = 0
		fullLabel.Parent = textsFrame

		TweenService:Create(fullLabel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextSize = 48}):Play()

	elseif style == "Slide Up" then
		local fullLabel = Instance.new("TextLabel")
		fullLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		fullLabel.Position = UDim2.new(0.5, 0, 0.5, 100)
		fullLabel.Size = UDim2.new(0, 500, 0, 80)
		fullLabel.BackgroundTransparency = 1
		fullLabel.Text = loadText
		fullLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		fullLabel.Font = Enum.Font.GothamBold
		fullLabel.TextSize = 48
		fullLabel.TextTransparency = 0
		fullLabel.Parent = textsFrame

		TweenService:Create(fullLabel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
	end

	task.wait(LOADING_DURATION)

	-- Fade out everything
	TweenService:Create(blur, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = 0}):Play()
	TweenService:Create(blackFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()

	for _, lbl in ipairs(textObjs) do
		TweenService:Create(lbl, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1}):Play()
	end

	-- Fade out non-letter-by-letter labels too
	for _, child in ipairs(textsFrame:GetDescendants()) do
		if child:IsA("TextLabel") then
			TweenService:Create(child, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1}):Play()
		end
	end

	task.wait(0.5)

	loaderGui:Destroy()
	blur:Destroy()
end


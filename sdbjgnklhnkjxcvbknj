-- ESP variables and functions
-- ============================================
local espEnabled = false
local espTrackedData = {}
local espConnections = {}

local ESP_DEFAULT_COLOR = Color3.fromRGB(50, 205, 50)
local ESP_KNIFE_COLOR = Color3.fromRGB(220, 40, 40)
local ESP_GUN_COLOR = Color3.fromRGB(40, 120, 255)
local ESP_FILL_ALPHA = 1
local ESP_OUTLINE_ALPHA = 0
local ESP_HL_TAG = "_WH"
local ESP_BB_TAG = "_WBB"

local espWeaponKeywords = {
	{ pattern = "gun", priority = 2, color = ESP_GUN_COLOR },
	{ pattern = "knife", priority = 1, color = ESP_KNIFE_COLOR },
}

local function espDetectWeaponColor(character, plr)
	local best, bestPrio = nil, 0
	local function checkTool(tool)
		if not tool:IsA("Tool") then return end
		local lower = tool.Name:lower()
		for _, entry in ipairs(espWeaponKeywords) do
			if lower:find(entry.pattern) and entry.priority > bestPrio then
				bestPrio = entry.priority
				best = entry.color
			end
		end
	end
	for _, obj in ipairs(character:GetChildren()) do checkTool(obj) end
	local bp = plr:FindFirstChildOfClass("Backpack")
	if bp then for _, obj in ipairs(bp:GetChildren()) do checkTool(obj) end end
	return best or ESP_DEFAULT_COLOR
end

local function espGetOrMakeHighlight(character)
	local h = character:FindFirstChild(ESP_HL_TAG)
	if h and h:IsA("Highlight") then return h end
	if h then h:Destroy() end
	local hl = Instance.new("Highlight")
	hl.Name = ESP_HL_TAG
	hl.Adornee = character
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.FillTransparency = ESP_FILL_ALPHA
	hl.OutlineTransparency = ESP_OUTLINE_ALPHA
	hl.FillColor = ESP_DEFAULT_COLOR
	hl.OutlineColor = ESP_DEFAULT_COLOR
	hl.Parent = character
	return hl
end

local function espGetOrMakeBillboard(character, playerName)
	local head = character:FindFirstChild("Head")
	if not head then return nil end
	local bb = head:FindFirstChild(ESP_BB_TAG)
	if bb and bb:IsA("BillboardGui") then
		return bb:FindFirstChild("NameLabel")
	end
	if bb then bb:Destroy() end
	local billboard = Instance.new("BillboardGui")
	billboard.Name = ESP_BB_TAG
	billboard.Adornee = head
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.new(0, 140, 0, 26)
	billboard.StudsOffset = Vector3.new(0, 2.6, 0)
	billboard.ResetOnSpawn = false
	billboard.Parent = head
	local label = Instance.new("TextLabel")
	label.Name = "NameLabel"
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = playerName
	label.Font = Enum.Font.GothamBold
	label.TextSize = 13
	label.TextColor3 = ESP_DEFAULT_COLOR
	label.TextStrokeTransparency = 1
	label.TextScaled = false
	label.Parent = billboard
	return label
end

local function espUpdatePlayer(plr)
	if plr == player then return end
	local character = plr.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	local color = espDetectWeaponColor(character, plr)
	local hl = espGetOrMakeHighlight(character)
	hl.OutlineColor = color
	hl.FillColor = color
	local label = espGetOrMakeBillboard(character, plr.DisplayName)
	if label then
		label.TextColor3 = color
	end
end

local function espCleanCharacter(character)
	if character then
		local oldHl = character:FindFirstChild(ESP_HL_TAG)
		if oldHl then oldHl:Destroy() end
		local oldHead = character:FindFirstChild("Head")
		if oldHead then
			local oldBb = oldHead:FindFirstChild(ESP_BB_TAG)
			if oldBb then oldBb:Destroy() end
		end
	end
end

local function espHookCharacter(plr, character)
	character:WaitForChild("HumanoidRootPart", 10)
	local conn = RunService.Heartbeat:Connect(function()
		if not espEnabled then return end
		if not character.Parent then return end
		espUpdatePlayer(plr)
	end)
	local prev = espTrackedData[plr]
	if prev then
		if prev.conn then prev.conn:Disconnect() end
		espCleanCharacter(prev.character)
	end
	espTrackedData[plr] = { conn = conn, character = character }
	character.AncestryChanged:Connect(function(_, parent)
		if not parent and espTrackedData[plr] and espTrackedData[plr].character == character then
			conn:Disconnect()
		end
	end)
end

local function espHookPlayer(plr)
	if plr == player then return end
	if plr.Character then task.spawn(espHookCharacter, plr, plr.Character) end
	local charAddedConn = plr.CharacterAdded:Connect(function(character)
		task.spawn(espHookCharacter, plr, character)
	end)
	table.insert(espConnections, charAddedConn)
end

local function espCleanAll()
	for plr, data in pairs(espTrackedData) do
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
	end
	espTrackedData = {}
	for _, conn in ipairs(espConnections) do
		conn:Disconnect()
	end
	espConnections = {}
end

local function espEnableAll()
	for _, plr in ipairs(Players:GetPlayers()) do
		task.spawn(espHookPlayer, plr)
	end
	local addedConn = Players.PlayerAdded:Connect(function(plr) espHookPlayer(plr) end)
	table.insert(espConnections, addedConn)
	local removingConn = Players.PlayerRemoving:Connect(function(plr)
		local data = espTrackedData[plr]
		if not data then return end
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
		espTrackedData[plr] = nil
	end)
	table.insert(espConnections, removingConn)
end

local function toggleEsp()
	espEnabled = not espEnabled
	if espEnabled then
		espEnableAll()
	else
		espCleanAll()
	end
end


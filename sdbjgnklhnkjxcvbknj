-- Auto Delete Corpses
autoDeleteCorpsesEnabled = false
autoDeleteCorpsesConnections = {}

autoDeleteCorpsesTargets = {
	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital3 = true, MilBase = true,
	Bank2 = true, Office3 = true, ResearchFacility = true
}

function destroyCorpse(raggy)
	if not raggy or not raggy.Parent then return end

	-- Сначала убираем все коллизии и касания
	for _, part in ipairs(raggy:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = false
			part.CanTouch = false
			part.CanQuery = false
			part.Anchored = false
			part.Transparency = 1
			part.Size = Vector3.new(0.01, 0.01, 0.01)
			part.CFrame = CFrame.new(0, -500, 0)
		end
	end

	-- Удаляем все суставы и соединения
	for _, joint in ipairs(raggy:GetDescendants()) do
		if joint:IsA("JointInstance") or joint:IsA("Constraint") or joint:IsA("Weld") or joint:IsA("Motor6D") or joint:IsA("BallSocketConstraint") then
			joint:Destroy()
		end
	end

	-- Удаляем саму модель
	task.defer(function()
		if raggy and raggy.Parent then
			raggy:Destroy()
		end
	end)
end

function deleteCorpsesInModel(model)
	for _, desc in ipairs(model:GetDescendants()) do
		if desc.Name == "Raggy" then
			destroyCorpse(desc)
		end
	end
end

function enableAutoDeleteCorpses()
	autoDeleteCorpsesEnabled = true

	-- Удаляем существующие
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj.Name == "Raggy" then
			local parent = obj.Parent
			while parent and parent ~= Workspace do
				if autoDeleteCorpsesTargets[parent.Name] then
					destroyCorpse(obj)
					break
				end
				parent = parent.Parent
			end
		end
	end

	-- Следим за новыми Raggy
	local descConn = Workspace.DescendantAdded:Connect(function(obj)
		if not autoDeleteCorpsesEnabled then return end
		if obj.Name == "Raggy" then
			task.defer(function()
				if not autoDeleteCorpsesEnabled then return end
				if not obj or not obj.Parent then return end
				local parent = obj.Parent
				while parent and parent ~= Workspace do
					if autoDeleteCorpsesTargets[parent.Name] then
						destroyCorpse(obj)
						break
					end
					parent = parent.Parent
				end
			end)
		end
		-- Также ловим отдельные части трупов
		if obj:IsA("BasePart") and obj.Parent and obj.Parent.Name == "Raggy" then
			task.defer(function()
				if not autoDeleteCorpsesEnabled then return end
				if obj and obj.Parent then
					obj.CanCollide = false
					obj.CanTouch = false
					obj.CanQuery = false
					obj.Transparency = 1
					obj.Size = Vector3.new(0.01, 0.01, 0.01)
					obj.CFrame = CFrame.new(0, -500, 0)
				end
			end)
		end
	end)
	table.insert(autoDeleteCorpsesConnections, descConn)

	-- Следим за появлением новых карт
	local childConn = Workspace.ChildAdded:Connect(function(child)
		if not autoDeleteCorpsesEnabled then return end
		if autoDeleteCorpsesTargets[child.Name] then
			task.wait(0.5)
			if child and child.Parent and autoDeleteCorpsesEnabled then
				deleteCorpsesInModel(child)
				local mapConn = child.DescendantAdded:Connect(function(desc)
					if not autoDeleteCorpsesEnabled then return end
					if desc.Name == "Raggy" then
						task.defer(function()
							if desc and desc.Parent then
								destroyCorpse(desc)
							end
						end)
					end
					if desc:IsA("BasePart") and desc.Parent and desc.Parent.Name == "Raggy" then
						task.defer(function()
							if desc and desc.Parent then
								desc.CanCollide = false
								desc.CanTouch = false
								desc.CanQuery = false
								desc.Transparency = 1
								desc.Size = Vector3.new(0.01, 0.01, 0.01)
								desc.CFrame = CFrame.new(0, -500, 0)
							end
						end)
					end
				end)
				table.insert(autoDeleteCorpsesConnections, mapConn)
			end
		end
	end)
	table.insert(autoDeleteCorpsesConnections, childConn)

	-- Подключаемся к существующим картам
	for mapName in pairs(autoDeleteCorpsesTargets) do
		local map = Workspace:FindFirstChild(mapName)
		if map then
			local mapConn = map.DescendantAdded:Connect(function(desc)
				if not autoDeleteCorpsesEnabled then return end
				if desc.Name == "Raggy" then
					task.defer(function()
						if desc and desc.Parent then
							destroyCorpse(desc)
						end
					end)
				end
				if desc:IsA("BasePart") and desc.Parent and desc.Parent.Name == "Raggy" then
					task.defer(function()
						if desc and desc.Parent then
							desc.CanCollide = false
							desc.CanTouch = false
							desc.CanQuery = false
							desc.Transparency = 1
							desc.Size = Vector3.new(0.01, 0.01, 0.01)
							desc.CFrame = CFrame.new(0, -500, 0)
						end
					end)
				end
			end)
			table.insert(autoDeleteCorpsesConnections, mapConn)
		end
	end

	-- Периодическая проверка + чистка хитбоксов
	task.spawn(function()
		while autoDeleteCorpsesEnabled do
			task.wait(3)
			if autoDeleteCorpsesEnabled then
				for _, obj in ipairs(Workspace:GetDescendants()) do
					if obj.Name == "Raggy" then
						local parent = obj.Parent
						while parent and parent ~= Workspace do
							if autoDeleteCorpsesTargets[parent.Name] then
								destroyCorpse(obj)
								break
							end
							parent = parent.Parent
						end
					end
				end
			end
		end
	end)
end

function disableAutoDeleteCorpses()
	autoDeleteCorpsesEnabled = false
	for _, conn in ipairs(autoDeleteCorpsesConnections) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	autoDeleteCorpsesConnections = {}
end

function toggleAutoDeleteCorpses()
	if autoDeleteCorpsesEnabled then
		disableAutoDeleteCorpses()
	else
		enableAutoDeleteCorpses()
	end
end


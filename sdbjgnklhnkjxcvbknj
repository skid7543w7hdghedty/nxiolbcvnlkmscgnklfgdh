-- Keeps the character's physics assembly AWAKE so per-frame position spoofs keep
-- replicating to the server even while standing still (the post-update "idle sleep"
-- stopped Desync/Anti-Shoot from working when not moving). To keep LOCAL movement
-- 100% normal it only acts while you are IDLE (no movement input): when you actually
-- walk, your real velocity already keeps the assembly awake, so we leave it untouched.
-- While idle it applies a tiny linear velocity whose direction flips every frame
-- (net displacement ~0, no drift) and zero angular velocity (no camera spin).
_wakeFlip = false
function keepAssemblyAwake(hrp, hum)
	if not hrp then return end
	if hum and hum.MoveDirection.Magnitude > 0.05 then return end -- you're moving -> stay fully normal
	_wakeFlip = not _wakeFlip
	local s = _wakeFlip and 1 or -1
	hrp.AssemblyLinearVelocity = Vector3.new(s, 0, s)
	hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end


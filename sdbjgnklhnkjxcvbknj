		local popupLockBtn = Instance.new("TextButton")
		popupLockBtn.Size = UDim2.new(0, 22, 0, 22)
		popupLockBtn.Position = UDim2.new(1, -27, 0.5, -11)
		popupLockBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		popupLockBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		popupLockBtn.Text = "U"
		popupLockBtn.Font = Enum.Font.SourceSansBold
		popupLockBtn.TextSize = 12
		popupLockBtn.AutoButtonColor = false
		popupLockBtn.BorderSizePixel = 0
		popupLockBtn.Parent = popupBorder

		local popupLockCorner = Instance.new("UICorner")
		popupLockCorner.CornerRadius = UDim.new(0, 4)
		popupLockCorner.Parent = popupLockBtn

		local popupLocked = false

		popupLockBtn.MouseButton1Click:Connect(function()
			popupLocked = not popupLocked
			if popupLocked then
				popupLockBtn.Text = "L"
				popupLockBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
			else
				popupLockBtn.Text = "U"
				popupLockBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			end
		end)

		local popupDragging = false
		local popupDidMove = false
		local popupDragStart
		local popupBtnStartPos
		local POPUP_DRAG_THRESHOLD = 5

		popupBtn.InputBegan:Connect(function(input)
			if popupDragLocked or popupLocked then return end
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				popupDragging = true
				popupDidMove = false
				popupDragStart = input.Position
				popupBtnStartPos = popupBorder.Position
			end
		end)

		local popupDragConn = UserInputService.InputChanged:Connect(function(input)
			if popupDragLocked or popupLocked then return end
			if input.UserInputType == Enum.UserInputType.MouseMovement and popupDragging then
				local delta = input.Position - popupDragStart
				if delta.Magnitude >= POPUP_DRAG_THRESHOLD then
					popupDidMove = true
				end
				if popupDidMove then
					popupBorder.Position = UDim2.new(popupBtnStartPos.X.Scale, popupBtnStartPos.X.Offset + delta.X, popupBtnStartPos.Y.Scale, popupBtnStartPos.Y.Offset + delta.Y)
				end
			end
		end)

		popupBtn.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				local shouldToggle = popupDragging and not popupDidMove
				if not popupDragging then
					shouldToggle = not popupLocked
				end
				local wasDragged = popupDragging and popupDidMove
				popupDragging = false
				popupDidMove = false
				if wasDragged then
					saveConfig()
				end
				if shouldToggle then
					feature.toggle()
				end
			end
		end)

		extractedButtons[feature.name] = {
			btn = popupBorder,
			popupBtn = popupBtn,
			popupLockBtn = popupLockBtn,
			dragConn = popupDragConn,
		}

		if feature.getState and feature.getState() then
			setExtractedBtnState(feature.name, true, feature.getStatusText and feature.getStatusText())
		end

		saveConfig()
	end

	extractButton.MouseButton1Click:Connect(extractHandlers[feature.name])

	removeButton.MouseButton1Click:Connect(function()
		local data = extractedButtons[feature.name]
		if not data then return end
		if data.dragConn then data.dragConn:Disconnect() end
		if data.btn then data.btn:Destroy() end
		extractedButtons[feature.name] = nil
		saveConfig()
	end)
end


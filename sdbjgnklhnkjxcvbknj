function getTrollingTarget()
	if trollingTargetName == "" then
		notify("Error", "Enter a player name first", 2)
		return nil
	end
	local target
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Name:lower():find(trollingTargetName:lower()) then
			target = plr
			break
		end
	end
	if not target then
		notify("Error", "Target not found", 2)
		return nil
	end
	return target
end


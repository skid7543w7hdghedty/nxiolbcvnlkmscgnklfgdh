autoDeleteCoinsEnabled = false
autoDeleteCoinsConnections = {}

autoDeleteCoinsTargets = {
	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital3 = true, MilBase = true,
	Bank2 = true, Office3 = true, PoliceStation = true, ResearchFacility = true
}

function isInsideTargetModel(instance)
	local current = instance.Parent
	while current and current ~= Workspace and current ~= game do
		if current:IsA("Model") and autoDeleteCoinsTargets[current.Name] then
			return true, current.Name
		end
		current = current.Parent
	end
	return false, nil
end

function tryRemoveCoin(instance)
	if instance and instance.Parent and instance.Name == "CoinContainer" then
		local isInside, modelName = isInsideTargetModel(instance)
		if isInside then
			instance:Destroy()
			return true
		end
	end
	return false
end

function fullCoinScan()
	local removed = 0
	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if descendant.Name == "CoinContainer" then
			if tryRemoveCoin(descendant) then
				removed += 1
			end
		end
	end
	return removed
end

function enableAutoDeleteCoins()
	autoDeleteCoinsEnabled = true

	fullCoinScan()

	local descConn = Workspace.DescendantAdded:Connect(function(instance)
		if not autoDeleteCoinsEnabled then return end
		task.defer(function()
			if not autoDeleteCoinsEnabled then return end
			if instance and instance.Parent then
				if instance.Name == "CoinContainer" then
					tryRemoveCoin(instance)
				end
				if instance:IsA("Model") and autoDeleteCoinsTargets[instance.Name] then
					task.wait(0.1)
					if instance and instance.Parent and autoDeleteCoinsEnabled then
						for _, child in ipairs(instance:GetDescendants()) do
							if child.Name == "CoinContainer" then
								tryRemoveCoin(child)
							end
						end
					end
				end
			end
		end)
	end)
	table.insert(autoDeleteCoinsConnections, descConn)

	task.spawn(function()
		while autoDeleteCoinsEnabled do
			task.wait(8)
			if autoDeleteCoinsEnabled then
				fullCoinScan()
			end
		end
	end)
end

function disableAutoDeleteCoins()
	autoDeleteCoinsEnabled = false
	for _, conn in ipairs(autoDeleteCoinsConnections) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	autoDeleteCoinsConnections = {}
end

function toggleAutoDeleteCoins()
	if autoDeleteCoinsEnabled then
		disableAutoDeleteCoins()
	else
		enableAutoDeleteCoins()
	end
end


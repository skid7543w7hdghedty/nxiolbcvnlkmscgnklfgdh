			borderCorner.Parent = popupBorder

			local function fpsPingMakeDraggable(dragFrame)
				local d = false
				local dm = false
				local ds, sp, dragIpt
				local TH = 5
				dragFrame.InputBegan:Connect(function(ipt)
					if popupDragLocked then return end
					if ipt.UserInputType == Enum.UserInputType.MouseButton1 or ipt.UserInputType == Enum.UserInputType.Touch then
						d = true; dm = false; ds = ipt.Position; sp = popupBorder.Position; dragIpt = ipt
					end
				end)
				dragFrame.InputChanged:Connect(function(ipt)
					if ipt.UserInputType == Enum.UserInputType.MouseMovement or ipt.UserInputType == Enum.UserInputType.Touch then
						dragIpt = ipt
					end
				end)
				local conn = UserInputService.InputChanged:Connect(function(ipt)
					if popupDragLocked then return end
					if ipt == dragIpt and d then
						local delta = ipt.Position - ds
						if delta.Magnitude >= TH then dm = true end
						if dm then
							popupBorder.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y)
						end
					end
				end)
				dragFrame.InputEnded:Connect(function(ipt)
					if ipt.UserInputType == Enum.UserInputType.MouseButton1 or ipt.UserInputType == Enum.UserInputType.Touch then
						local wasDragged = dm
						d = false; dm = false; dragIpt = nil
						if wasDragged then saveConfig() end
					end
				end)
				return conn
			end


-- ============== Multi-Config System ==============
currentCategory = "Settings"
CONFIGS_DIR = "AdrenalinConfigs"
currentConfigName = "Default"
autoSaveEnabled = false

local function getConfigFiles()
	ensureFolder()
	local files = {}
	local dir = CONFIGS_DIR .. "/"
	local success, result = pcall(function() return listfiles(dir) end)
	if success then
		for _, f in ipairs(result) do
			if f:match("%.json$") then
				local name = f:match("([^/\\]+)%.json$")
				if name then table.insert(files, name) end
			end
		end
	end
	if #files == 0 then table.insert(files, "Default") end
	return files
end

local function saveConfigByName(name)
	if isApplyingConfig then return end
	ensureFolder()
	local fullPath = CONFIGS_DIR .. "/" .. name .. ".json"
	local configData = buildConfigData()
	local encoded = game:GetService("HttpService"):JSONEncode(configData)
	task.defer(function()
		pcall(function() writefile(fullPath, encoded) end)
	end)
end


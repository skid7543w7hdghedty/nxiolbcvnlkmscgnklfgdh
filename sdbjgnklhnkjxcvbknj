task.spawn(function()
	while true do
		task.wait(0.5)
		if not gameNotifEnabled then continue end

		local ok, result = pcall(function()
			return invokePlayerData()
		end)

		if ok and result then
			local currentMurderer = nil
			local currentSheriff = nil

			for name, data in pairs(result) do
				if data.Role == "Murderer" then
					currentMurderer = name
				elseif data.Role == "Sheriff" then
					currentSheriff = name
				end
			end

			local currentGunHolderName = nil
			local currentGunHolderUserId = nil
			for name, data in pairs(result) do
				if data.HasGun and data.Role ~= "Murderer" then
					currentGunHolderName = name
					local p = Players:FindFirstChild(name)
					if p then currentGunHolderUserId = p.UserId end
					break
				end
			end

			if not currentGunHolderName then
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Name == currentMurderer then continue end
					local char = p.Character
					if char then
						for _, tool in ipairs(char:GetChildren()) do
							if tool:IsA("Tool") and tool.Name:lower():find("gun") then
								currentGunHolderName = p.Name
								currentGunHolderUserId = p.UserId
								break
							end
						end
					end
					if not currentGunHolderName then
						local backpack = p:FindFirstChild("Backpack")
						if backpack then
							for _, tool in ipairs(backpack:GetChildren()) do
								if tool:IsA("Tool") and tool.Name:lower():find("gun") then
									currentGunHolderName = p.Name
									currentGunHolderUserId = p.UserId
									break
								end
							end
						end
					end
					if currentGunHolderName then break end
				end
			end

			if not currentGunHolderName and currentSheriff then
				currentGunHolderName = currentSheriff
				local sp = Players:FindFirstChild(currentSheriff)
				if sp then currentGunHolderUserId = sp.UserId end
			end

			if currentGunHolderName then
				lastSheriffHeroName = currentGunHolderName
				lastSheriffHeroUserId = currentGunHolderUserId
			end

			local roundKey = (currentMurderer or "") .. "_" .. (currentSheriff or "")

			if roundKey ~= gameNotifLastRound and currentMurderer and currentSheriff then
				gameNotifLastRound = roundKey
				lastSheriffHeroName = nil
				lastSheriffHeroUserId = nil
				gameNotifSendRound(currentMurderer, currentSheriff)
			end

			if currentMurderer then
				local data = result[currentMurderer]
				local isAliveNow = data and not data.Killed and not data.Dead
				if gameNotifPrevRoles and not isAliveNow and gameNotifPrevMurdererAlive then
					local murdererPlayer = Players:FindFirstChild(currentMurderer)
					local murdererUserId = nil
					if murdererPlayer then
						murdererUserId = murdererPlayer.UserId
					end
					if not murdererPlayer then
						for _, p in ipairs(Players:GetPlayers()) do
							if p.Name == currentMurderer then murdererPlayer = p murdererUserId = p.UserId break end
						end
					end
					gameNotifSend("Murderer Died", currentMurderer .. " has been killed!", Color3.fromRGB(255, 0, 0), Color3.fromRGB(255, 255, 255), murdererPlayer, murdererUserId)
					playSoundFile(murdererDieSoundPath)
				end
				gameNotifPrevMurdererAlive = isAliveNow
			end

			gameNotifPrevRoles = result
		end
	end
end)


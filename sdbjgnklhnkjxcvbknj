function filterTeamerList()
	local query = teamerPlayerSearchBox.Text:lower()
	local matches = {}
	local nonMatches = {}
	for _, child in ipairs(teamerPlayerList:GetChildren()) do
		if child:IsA("TextButton") then
			local searchText = child.Name:lower()
			if teamerSearchMode == "Display" then
				local displayLabel = child:FindFirstChildWhichIsA("TextLabel")
				if displayLabel then
					local dn = displayLabel.Text:match("^(.+) %(")
					if dn then searchText = dn:lower() end
				end
			end
			local match = query == "" or searchText:find(query, 1, true) ~= nil
			child.Visible = match
			if match then
				table.insert(matches, child)
			else
				table.insert(nonMatches, child)
			end
		end
	end
	-- Reposition using LayoutOrder: matches at top (1, 2, 3...), non-matches below
	local order = 1
	for _, child in ipairs(matches) do
		child.LayoutOrder = order
		order = order + 1
	end
	for _, child in ipairs(nonMatches) do
		child.LayoutOrder = order
		order = order + 1
	end
	teamerPlayerList.CanvasPosition = Vector2.new(0, 0)
end


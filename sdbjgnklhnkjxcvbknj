-- Shoot the murderer until they (or we) die, or the timeout runs out.
-- forcePiercer = true temporarily forces the Piercer Bullet (wallbang) mode
-- so the shot goes through walls, then restores the previous setting.
function autofarmShootMurderer(forcePiercer)
	if not autofarmHasGun() then return false end
	local startedAt = os.clock()
	while os.clock() - startedAt < 8 do
		local m = autofarmFindMurdererPlayer()
		if not (m and m.Character) then break end
		local mh = m.Character:FindFirstChildOfClass("Humanoid")
		if not mh or mh.Health <= 0 then break end
		-- Our own death also ends the attempt
		local myChar = player.Character
		local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
		if not myHum or myHum.Health <= 0 then return false end
		if forcePiercer then
			local wasWallbang = aimWallbangEnabled
			aimWallbangEnabled = true
			pcall(aimFireGunAt, m)
			aimWallbangEnabled = wasWallbang
		else
			pcall(aimFireGunAt, m)
		end
		task.wait(0.15)
	end
	return true
end

-- Sheriff/Hero: always shoot the murderer if you have the gun (piercer toggle
-- controls wallbang mode, not whether we shoot). Reset only if the toggle is on.
function autofarmFinishSheriff()
	autofarmShootMurderer(autofarmShootPiercerEnabled)
	if autofarmResetSheriffEnabled then

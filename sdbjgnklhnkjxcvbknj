-- РћС‚СЃР»РµР¶РёРІР°РЅРёРµ РїРѕРґР±РѕСЂР° GunDrop
-- [perf] This tracker used to call Workspace:GetDescendants() every 0.5 seconds —
-- a full scan of the entire map that allocated a huge table each pass and was one
-- of the biggest freeze sources on mobile. New GunDrops are now registered by the
-- Workspace.DescendantAdded hook below (event-based, zero scanning); this loop only
-- checks the handful of already-known guns for removal.
task.spawn(function()
	-- one-time initial scan for guns that already existed before the script loaded
	pcall(function()
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj.Name == "GunDrop" then
				gameNotifGunDrops[obj] = true
			end
		end
	end)
	while true do
		task.wait(0.5)
		if not gameNotifEnabled then
			-- keep the set clean while notifications are off so re-enabling
			-- doesn't fire stale "picked up" notifications
			for gun in pairs(gameNotifGunDrops) do
				if not gun.Parent then gameNotifGunDrops[gun] = nil end
			end
			continue
		end

		for gun in pairs(gameNotifGunDrops) do
			if not gun.Parent then
				gameNotifGunDrops[gun] = nil
				task.wait(0.3)

				local pickedByName = nil
				local pickedByUserId = nil

				for _, p in ipairs(Players:GetPlayers()) do
					local char = p.Character
					if char then
						for _, tool in ipairs(char:GetChildren()) do
							if tool:IsA("Tool") and tool.Name:lower():find("gun") then
								pickedByName = p.Name
								pickedByUserId = p.UserId
								break
							end
						end
					end
					if not pickedByName then
						local backpack = p:FindFirstChild("Backpack")
						if backpack then
							for _, tool in ipairs(backpack:GetChildren()) do
								if tool:IsA("Tool") and tool.Name:lower():find("gun") then
									pickedByName = p.Name
									pickedByUserId = p.UserId
									break
								end
							end
						end
					end
					if pickedByName then break end
				end

				if pickedByName then

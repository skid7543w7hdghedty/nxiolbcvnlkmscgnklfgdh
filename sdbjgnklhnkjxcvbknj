-- Check distance to the murderer and teleport away if too close during autofarm
function autofarmCheckAvoidMurderer(hrp)
	if not autofarmAvoidMurdererEnabled then return false end
	if autofarmAvoidMurdererModeIndex <= 1 then return false end -- "OFF" selected
	if not isPlayerMurderer() then
		local murderer = autofarmFindMurdererPlayer()
		if murderer and murderer.Character then
			local mHrp = murderer.Character:FindFirstChild("HumanoidRootPart")
			if mHrp then
				local dist = (hrp.Position - mHrp.Position).Magnitude
				if dist <= autofarmAvoidMurdererDist then
					autofarmDoAvoidMurdererTp()
					return true
				end
			end
		end
	end
	return false
end

function startAutofarm()
	task.spawn(function()
		while autofarmEnabled do
			local dt = RunService.Heartbeat:Wait()
			local char = player.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local hrp = char and char:FindFirstChild("HumanoidRootPart")

			-- Farm ONLY while alive and in the round: no collecting after death,
			-- in the lobby, or before the round starts. Also pause while the
			-- pre-farm TP is being applied so the flight can't fight it.
			if autofarmPreTpHold or not (char and hum and hrp and hum.Health > 0) or not autofarmIsAliveInRound() then
				autofarmStopFlight()
				task.wait()
			else
				local container = autofarmFindCoinContainer()
				-- New round / new map -> reset the per-round state
				if container ~= autofarmActiveContainer then
					autofarmActiveContainer = container
					autofarmCollected = 0
					autofarmCoinWatched = {}
					autofarmCoinRetries = {}
					autofarmSpentCoins = {}
					autofarmCoinVisiblePart = {}
					autofarmCoinVisCheckedAt = {}
					autofarmTouchedAt = {}
					autofarmFullTouchAt = {}
					autofarmClaimPending = {}
					autofarmAuraPending = {}
					autofarmBagLabelCache = nil -- new round = the bag GUI may be rebuilt
					autofarmBagPrev = nil       -- restart the bag-delta baseline
					autofarmNoCoinSince = nil   -- restart the no-coin grace timer
					autofarmRoundFinished = false
					autofarmStuckSince = nil    -- reset stuck detector for new round
					autofarmStuckLastPos = nil
				end

				-- Effective count = the max of the local counter and the REAL
				-- server-accepted bag count from the GUI. The reset always fires
				-- exactly at the selected farm limit (40 normal / 50 Elite).
				local bagCount = autofarmGetBagCount()
				-- SESSION COUNTER FIX: the top-of-tab counter used to rely on coin
				-- removal events, which MISSED coins (e.g. picked up by Coin Aura on
				-- untargeted coins, or removal events swallowed under lag). Now the
				-- session counter follows the server-accepted bag count directly:
				-- every increase of the bag adds the exact delta — nothing can be
				-- skipped or double-counted. Decreases (bag reset on round change /
				-- deposit) are ignored, they just move the baseline.
				if bagCount ~= nil then
					if autofarmBagPrev ~= nil and bagCount > autofarmBagPrev then
						autofarmSessionCoins += (bagCount - autofarmBagPrev)
					end
					autofarmBagPrev = bagCount
					if bagCount > autofarmCollected then autofarmCollected = bagCount end
				end
				local effectiveCollected = math.max(autofarmCollected, bagCount or 0)

				if not container or autofarmRoundFinished then
					autofarmStopFlight()
				elseif effectiveCollected >= autofarmTargetCoins then
					autofarmRoundFinished = true
					autofarmStopFlight()
					notify("Autofarm", "Collected " .. effectiveCollected .. "/" .. autofarmTargetCoins .. " coins!", 2)
					autofarmFinishRound()
				else
					local coin, part, dist = autofarmNearestCoin(container, hrp.Position)
					-- Are any coins still being pulled in by the Coin Aura? If so, the
					-- round is NOT over even when no targetable coin is left.
					local auraStillPulling = false
					if coinAuraEnabled then
						for c, t in pairs(autofarmAuraPending) do
							if (os.clock() - t) < 2 and not autofarmCoinIsGone(c) then
								auraStillPulling = true
								break
							end
						end
					end
					if coin then autofarmNoCoinSince = nil end
					if not coin and auraStillPulling then
						-- Last remaining coins are inside the aura pull — just hold
						-- position and let the aura finish collecting them.
						autofarmNoCoinSince = nil
						autofarmPauseFlight()
					elseif not coin then
						-- 39/40 FIX: no targetable coin does NOT mean the round is over.
						-- Two real causes of finishing one coin short:
						--   1. A still-existing coin was blacklisted too eagerly (3s of
						--      failed touches / 3 retries under lag) — give those coins a
						--      SECOND CHANCE before giving up on them for good.
						--   2. MM2 spawns coins in WAVES: the last coin of the bag often
						--      belongs to the NEXT wave. The old code finished the round
						--      the moment the current wave was empty -> 39/40. Now we
						--      wait up to 8s for a new wave before finishing.
						local revived = false
						if effectiveCollected > 0 and effectiveCollected < autofarmTargetCoins then
							for _, c in ipairs(container:GetChildren()) do
								if autofarmSpentCoins[c] and not autofarmCoinIsGone(c)
									and (autofarmCoinRetries[c] or 0) < 9 then
									autofarmSpentCoins[c] = nil
									autofarmTouchedAt[c] = nil
									revived = true
								end
							end
						end
						if revived then
							autofarmNoCoinSince = nil
						elseif effectiveCollected > 0 then
							autofarmNoCoinSince = autofarmNoCoinSince or os.clock()
							if (os.clock() - autofarmNoCoinSince) >= 8 then
								autofarmRoundFinished = true
								autofarmStopFlight()
								notify("Autofarm", "No more coins — finishing round (" .. effectiveCollected .. "/" .. autofarmTargetCoins .. ")", 2)
								autofarmFinishRound()
							else
								autofarmPauseFlight()
							end
						else
							autofarmPauseFlight()
						end
					else
						-- Avoid murderer: teleport away if too close during autofarm
						if autofarmCheckAvoidMurderer(hrp) then
							autofarmStopFlight()
							task.wait()
						else
						-- Fly: through walls, lying on the back (face up).
						-- Auto Anti-Shoot: disable now that farming has started
						if autofarmAutoAntiShootActive then
							autofarmAutoAntiShootActive = false
							if PastedSources then
								toggleDesync()
								if desyncButton then setToggleState(desyncButton, false, "Anti-Shoot: ON", "Anti-Shoot: OFF") end
								setExtractedBtnState("Anti-Shoot", false)
							end
						end
						-- NO teleport snaps anywhere — instant position jumps are exactly
						-- what the anti-cheat kicked for. Every frame the character moves
						-- at most autofarmSpeed studs/sec toward the target, and dt is
						-- clamped so a lag spike can never become one huge step either.
						pcall(function() hum.PlatformStand = true end)
						-- [perf] Cached part list + write CanCollide only when it actually
						-- changed (property writes on every part every frame are not free)
						for _, p in ipairs(autofarmGetCharParts(char)) do
							if p.CanCollide then p.CanCollide = false end
						end

						-- Keep touching the coin EVERY frame while in range (not just once).
						-- The coin stays targetable until it disappears, so we keep hitting
						-- it until the server accepts the touch — no more flying past coins.
						-- [perf] HRP touch still fires EVERY frame (that's the one that
						-- collects), but the full-body volley over all ~15 parts is now
						-- throttled to every 0.15s per coin — the old every-frame volley
						-- was 30+ firetouchinterest pcalls per frame, another hitch source.
						if dist <= autofarmPickupRange then
							safeFireTouch(part, hrp)
							local lastFull = autofarmFullTouchAt[coin]
							if not lastFull or (os.clock() - lastFull) >= 0.15 then
								autofarmFullTouchAt[coin] = os.clock()
								for _, bp in ipairs(autofarmGetCharParts(char)) do
									if bp ~= hrp then
										safeFireTouch(part, bp)
									end
								end
							end
							if not autofarmTouchedAt[coin] then
								autofarmTouchedAt[coin] = os.clock()
							end
							autofarmClaimCoin(coin)
						end

						-- Coin Aura fly-through: the aura pulls coins in from up to
						-- coinAuraRadius studs away, so there is NO reason to stop at
						-- (or rise onto) this coin. Claim it, mark it pending and
						-- immediately retarget the NEXT coin — the flight continues
						-- without any pause while the aura finishes the pickup.
						if coinAuraEnabled and dist <= coinAuraRadius then
							safeFireTouch(part, hrp)
							if not autofarmTouchedAt[coin] then
								autofarmTouchedAt[coin] = os.clock()
							end
							autofarmClaimCoin(coin)
							autofarmAuraPending[coin] = os.clock()
							local nextCoin, nextPart, nextDist = autofarmNearestCoin(container, hrp.Position)
							if nextCoin then
								coin, part, dist = nextCoin, nextPart, nextDist
							end
						end

						-- Route: fly UNDER the floor whenever one exists below the coin
						-- (harder to be killed), stay directly beneath the coin.
						-- When Coin Aura is enabled, stay under the floor and let it
						-- pull coins to you. When Coin Aura is off, rise to collect.
						local target
						autofarmFloorRayParams.FilterDescendantsInstances = {char, container}
						local floorHit = Workspace:Raycast(
							part.Position - Vector3.new(0, 0.5, 0),
							Vector3.new(0, -60, 0),
							autofarmFloorRayParams
						)
						if floorHit then
							-- Always stay beneath the floor, close to the coin's XZ position
							target = Vector3.new(part.Position.X, floorHit.Position.Y - autofarmUnderFloorDepth, part.Position.Z)
						else
							-- No floor below: approach from slightly below
							target = part.Position - Vector3.new(0, 2, 0)
						end

						-- SINGLE clamped 3D step at constant speed. The old code
						-- split the step into horizontal (up to maxStep) PLUS
						-- vertical (up to 3x maxStep via the ascent multiplier)
						-- applied in the SAME frame — so the moment the farm
						-- switched from same-level coins to a coin higher up,
						-- the effective speed spiked to ~3.16x the configured
						-- speed. That spike was the "jerk" the anti-cheat can
						-- kick for. Now the total displacement per frame is
						-- NEVER more than autofarmSpeed * dt in ANY direction:
						-- ascents, descents and level changes are all perfectly
						-- smooth at the same constant speed.
						local delta = target - hrp.Position
						local dMag = delta.Magnitude
						local maxStep = autofarmSpeed * math.min(dt, autofarmMaxStepDt)
						local newPos = hrp.Position
						if dMag > 0.05 then
							newPos = newPos + delta * (math.min(maxStep, dMag) / dMag)
						end
						pcall(function()
							hrp.CFrame = CFrame.new(newPos) * autofarmLieCF
						end)
						pcall(function()
							hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
							hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
						end)
						-- Stuck detector: check position over a 1-second window.
						-- Every ~1 second, compare current position to where we were.
						-- If moved less than STUCK_MIN_DIST studs in that second, start
						-- the stuck timer. After STUCK_TIMEOUT seconds stuck, TP to map.
						local curPos = hrp.Position
						local now = os.clock()
						if (now - autofarmStuckCheckAt) >= 1 then
							autofarmStuckCheckAt = now
							if autofarmStuckLastPos then
								local movedDist = (curPos - autofarmStuckLastPos).Magnitude
								if movedDist < AUTOFARM_STUCK_MIN_DIST then
									if not autofarmStuckSince then
										autofarmStuckSince = now
									elseif (now - autofarmStuckSince) >= AUTOFARM_STUCK_TIMEOUT then
										autofarmStuckSince = nil
										autofarmStuckLastPos = nil
										notify("Autofarm", "Stuck detected — teleporting to map...", 2)
										pcall(tpToMap)
									end
								else
									autofarmStuckSince = nil
								end
							end
							autofarmStuckLastPos = curPos
						end
						end -- avoid murderer else
					end
				end
			end
		end
		autofarmStopFlight()
	end)
end

function setAutofarmEnabled(state, target, silent)
	autofarmEnabled = state
	if state then
		autofarmTargetCoins = target or autofarmTargetCoins
		autofarmActiveContainer = nil -- force per-round state refresh
		if not autofarmSessionStart then
			autofarmSessionStart = os.clock()
		end
		-- Pre-farm teleport is handled by the round-start watcher below:
		-- it fires exactly ONCE per round (when the sheriff+murderer roles
		-- appear — same moment the round-start notification shows), waits
		-- 3 seconds, then teleports reliably. Re-arm it so that enabling
		-- the farm mid-round also teleports once for the current round.
		autofarmPreTpLastRound = ""
		startAutofarm()
	else
		autofarmStopFlight()
		-- Every disable resets the session stats — timer and coin counter
		-- start from zero on the next enable.
		autofarmSessionCoins = 0
		autofarmSessionStart = nil
		saveConfig() -- persist the zeroed stats immediately (not 30s later)
		if not silent then
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if hrp then
				pcall(doInstantTp, hrp, char, CFrame.new(23, 505, -34))
			end
		end
	end
end

-- ============================================
-- Pre-farm TP: ONE reliable trigger per round
-- ============================================
-- Round start is detected exactly the way the sheriff/murderer notification
-- works: the moment BOTH roles appear in the player data a new round has
-- begun. We then wait 3 seconds and teleport ONCE — re-applying the CFrame
-- for several frames so the teleport is guaranteed to stick even if the game
-- (or the farm flight itself) tries to move the character back.
autofarmPreTpLastRound = ""
autofarmPreTpHold = false -- pauses the farm flight while the TP is being applied

function autofarmDoPreTp()
	local mode = autofarmPreTpModes[autofarmPreTpModeIndex]
	local myChar = player.Character
	local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	autofarmPreTpHold = true
	local fixedCF = nil
	if mode == "Lobby" then
		fixedCF = CFrame.new(23, 505, -34)
	elseif mode == "VoteMap" then
		fixedCF = CFrame.new(14, 507, 35)
	elseif mode == "Map" then
		pcall(tpToMap)
	elseif mode == "Above Map" then
		pcall(tpAboveMap)
	elseif mode == "Void" then
		pcall(createVoidBaseplate)
		if voidBaseplatePos then
			voidTpPreviousPos = hrp.CFrame
			fixedCF = CFrame.new(voidBaseplatePos.X, voidBaseplatePos.Y + 1, voidBaseplatePos.Z)
		end
	end
	if fixedCF then
		pcall(doInstantTp, hrp, myChar, fixedCF)
		-- Guarantee the teleport STUCK: re-apply for up to 15 frames while
		-- zeroing velocity, until the character is actually at the target.
		for _ = 1, 15 do
			task.wait()
			local c = player.Character
			local r = c and c:FindFirstChild("HumanoidRootPart")
			if not r then break end
			if (r.Position - fixedCF.Position).Magnitude > 8 then
				pcall(function()
					r.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					r.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					r.CFrame = fixedCF
				end)
			else
				break
			end
		end
	end
	autofarmPreTpHold = false
	notify("Autofarm", "Pre-farm TP: " .. mode, 2)
end

task.spawn(function()
	while task.wait(0.4) do
		if autofarmEnabled and autofarmPreTpEnabled then
			local result = autofarmGetPlayerData()
			if result then
				local murderer, sheriff = nil, nil
				for name, data in pairs(result) do
					if data.Role == "Murderer" then
						murderer = name
					elseif data.Role == "Sheriff" then
						sheriff = name
					end
				end
				-- Both roles assigned = the round just started (this is the same
				-- moment the "Murderer/Sheriff" notification appears)
				if murderer and sheriff then
					local roundKey = murderer .. "_" .. sheriff
					if roundKey ~= autofarmPreTpLastRound then
						autofarmPreTpLastRound = roundKey
						-- Single trigger per round: wait 3 seconds, then TP for sure
						task.wait(3)
						if autofarmEnabled and autofarmPreTpEnabled then
							pcall(autofarmDoPreTp)
						end
					end
				end
			end
		end
	end
end)

-- Auto Anti-Shoot: enable Anti-Shoot at round start, disable when farming begins.
-- The pre-farm TP loop detects round start — we piggyback on the same detection:
-- when a new round starts and Auto Anti-Shoot is ON, enable Anti-Shoot immediately
-- (it protects you during the pre-farm wait). The farming loop then disables it
-- the moment it starts flying to coins.
autofarmAutoAntiShootLastRound = ""
autofarmAutoAntiShootActive = false -- true while Anti-Shoot is ON due to this feature
task.spawn(function()
	while task.wait(0.4) do
		if autofarmEnabled and autofarmAutoAntiShootEnabled then
			local result = autofarmGetPlayerData()
			if result then
				local murderer, sheriff = nil, nil
				for name, data in pairs(result) do
					if data.Role == "Murderer" then
						murderer = name
					elseif data.Role == "Sheriff" then
						sheriff = name
					end
				end
				if murderer and sheriff then
					local roundKey = murderer .. "_" .. sheriff
					if roundKey ~= autofarmAutoAntiShootLastRound then
						autofarmAutoAntiShootLastRound = roundKey
						-- Wait for the pre-farm TP to fire (3 seconds), then enable
						-- Anti-Shoot right after so it protects during the remaining wait.
						task.wait(3.5)
						if autofarmEnabled and autofarmAutoAntiShootEnabled then
							if not PastedSources then
								toggleDesync()
								if desyncButton then setToggleState(desyncButton, true, "Anti-Shoot: ON", "Anti-Shoot: OFF") end
								setExtractedBtnState("Anti-Shoot", true)
								autofarmAutoAntiShootActive = true
							end
						end
					end
				end
			end
		end
	end
end)

-- Auto Kill Sheriff/Hero: when you're the Murderer, kill anyone who picks up the gun
-- Runs on Heartbeat and immediately eliminates any player holding a Gun tool.
autofarmAutoKillSheriffConnection = nil
function autofarmSetupAutoKillSheriff()
	if autofarmAutoKillSheriffConnection then
		autofarmAutoKillSheriffConnection:Disconnect()
		autofarmAutoKillSheriffConnection = nil
	end
	if not autofarmAutoKillSheriffEnabled then return end
	autofarmAutoKillSheriffConnection = RunService.Heartbeat:Connect(function()
		if not autofarmAutoKillSheriffEnabled then return end
		if not autofarmEnabled then return end
		if not isPlayerMurderer() then return end
		-- Check every player for a gun
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player then
				local hasGun = false
				local char = plr.Character
				if char and char:FindFirstChild("Gun") then
					hasGun = true
				else
					local bp = plr:FindFirstChild("Backpack")
					if bp and bp:FindFirstChild("Gun") then
						hasGun = true
					end
				end
				if hasGun then
					pcall(doKillPlayer, plr.Name)
				end
			end
		end
	end)
end
autofarmSetupAutoKillSheriff()

-- ===== Discord webhook: coins farmed + how long you've been farming =====
function autofarmFormatDuration(sec)
	sec = math.floor(sec)
	local d = math.floor(sec / 86400)
	local h = math.floor((sec % 86400) / 3600)
	local m = math.floor((sec % 3600) / 60)
	local s = sec % 60
	return string.format("%dd %dh %dm %ds", d, h, m, s)
end

-- Projected coins per hour, computed from how long you've been farming and how
-- many coins you've already collected this session.
function autofarmCoinsPerHour()
	local elapsed = autofarmSessionStart and (os.clock() - autofarmSessionStart) or 0
	if elapsed < 1 then return 0 end
	return math.floor(autofarmSessionCoins / (elapsed / 3600) + 0.5)
end

function autofarmSendWebhook()
	local elapsed = autofarmSessionStart and (os.clock() - autofarmSessionStart) or 0
	local payload = game:GetService("HttpService"):JSONEncode({
		embeds = {{
			title = "Adrenalin.win — Autofarm",
			color = 8421504,
			fields = {
				{ name = "Player", value = string.format("%s (%d)", player.Name, player.UserId), inline = true },
				{ name = "Coins farmed (session)", value = tostring(autofarmSessionCoins), inline = true },
				{ name = "Farming time", value = autofarmFormatDuration(elapsed), inline = true },
				{ name = "Coins per hour", value = tostring(autofarmCoinsPerHour()), inline = true },
			},
		}},
	})
	local requestFn = (syn and syn.request) or http_request or (_G and _G.request) or request
	local ok = pcall(function()
		requestFn({
			Url = AUTOFARM_WEBHOOK_URL,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = payload,
		})
	end)
	if ok then
		notify("Autofarm", "Webhook notification sent (" .. autofarmSessionCoins .. " coins)", 2)
	else
		notify("Autofarm", "Webhook send failed", 2)
	end
end

-- Background reporter: sends a report every N minutes while enabled
task.spawn(function()
	local lastSentAt = 0
	while task.wait(5) do
		if autofarmWebhookEnabled and autofarmSessionStart then
			if (os.clock() - lastSentAt) >= autofarmWebhookIntervalMin * 60 then
				lastSentAt = os.clock()
				autofarmSendWebhook()
			end
		else
			-- Reset timer so the first report fires one full interval after enabling
			lastSentAt = os.clock()
		end
	end
end)


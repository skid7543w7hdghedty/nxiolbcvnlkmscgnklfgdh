function changerExtractId(s)
    if s == nil then return nil end
    return tostring(s):match("%d+")
end

-- Extract ALL catalog IDs from a string (comma / space / newline separated).
-- Returns a table of digit-strings, e.g. {"123", "456"}.
function changerExtractIds(s)
    if s == nil then return {} end
    local ids = {}
    for d in tostring(s):gmatch("%d+") do
        table.insert(ids, d)
    end
    return ids
end

function changerNeutralize(inst)
    for _, p in ipairs(inst:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function()
                p.CanCollide = false
                p.CanTouch = false
                p.CanQuery = false
                p.Massless = true
            end)
        end
    end
end


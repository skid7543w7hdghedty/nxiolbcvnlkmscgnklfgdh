-- Monitor player death -> wait 5s -> Touch Fling ON -> Reset Murderer -> Touch Fling OFF.
-- The 5-second wait starts AT DEATH (the old version waited for a respawn first,
-- and its blocking repeat-loops silently hung — that's why the feature "stopped
-- working"). Death is also detected when the character/humanoid is REMOVED
-- (common in MM2), which the old `hum and hum.Health <= 0` check missed entirely.
autofarmResetDeathBusy = false
task.spawn(function()
	local wasAlive = false
	while task.wait(0.2) do
		if autofarmResetDeathEnabled and autofarmEnabled then
			local char = player.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local isAlive = (hum ~= nil) and hum.Health > 0
			if wasAlive and not isAlive and not autofarmResetDeathBusy then
				-- We just died — run the sequence in its own thread so the
				-- detector keeps polling and NEVER misses the next death.
				autofarmResetDeathBusy = true
				task.spawn(function()
					-- 1) Wait 5 seconds after death
					task.wait(5)
					-- Make sure we have a live character to fling with (wait up to
					-- 10 extra seconds for the respawn if it hasn't happened yet)
					local t0 = os.clock()
					while os.clock() - t0 < 10 do
						local c = player.Character
						local h = c and c:FindFirstChildOfClass("Humanoid")
						if c and h and h.Health > 0 and c:FindFirstChild("HumanoidRootPart") then break end
						task.wait(0.2)
					end
					-- 2) Touch Fling ON
					hiddenfling = true
					setToggleState(touchFlingButton, true, "Touch Fling: ON", "Touch Fling: OFF")
					setExtractedBtnState("Touch Fling", true)
					flingThread = coroutine.create(fling)
					coroutine.resume(flingThread)
					-- 3) Reset Murderer
					pcall(executeNanFlingByRole, "Murderer")
					-- 4) Touch Fling OFF
					task.wait(1.5)
					hiddenfling = false
					setToggleState(touchFlingButton, false, "Touch Fling: ON", "Touch Fling: OFF")
					setExtractedBtnState("Touch Fling", false)
					autofarmResetDeathBusy = false
				end)
			end
			wasAlive = isAlive
		else
			wasAlive = false
		end
	end
end)


local antiVoidEnabled = false
local antiVoidFpsdiv = 5
local antiVoidDestroyHeight = workspace.FallenPartsDestroyHeight
local antiVoidDhoffset = 5
local antiVoidDhto = 25
local antiVoidDestroyHeightNew = antiVoidDestroyHeight + antiVoidDhoffset
local antiVoidConnections = {}
local antiVoidCharcframe = nil
local antiVoidTpcframe = nil
local antiVoidStopped = false
local antiVoidSentnotif = false
local antiVoidSteppedConn = nil
local antiVoidCharAddedConn = nil

local startergui = game:GetService("StarterGui")

local function antiVoidPrompt(message, yesorno, yesfunc)
	pcall(function()
		if yesorno ~= nil and yesfunc ~= nil then
			local bindfunc = Instance.new("BindableFunction")
			bindfunc.OnInvoke = function(buttonname)
				if buttonname == "Yes" then
					yesfunc()
					antiVoidSentnotif = false
				end
			end
			startergui:SetCore("SendNotification",{
				Title = "Notification",
				Text = message,
				Duration = 5,
				Callback = bindfunc,
				Button1 = "Yes",
				Button2 = "No"
			})
			wait(5)
			antiVoidSentnotif = false
		else
			startergui:SetCore("SendNotification",{
				Title = "Notification",
				Text = message,
				Duration = 5
			})
		end
	end)
end

local function antiVoidCheckreq()
	local localplr = game.Players.LocalPlayer
	local character = localplr.Character
	return character ~= nil and not game.Players:FindFirstChild(((("Bb"):gsub(("Bb"),("cxe"):reverse():gsub("xc",""))..string.gsub("xclop","lop","ruc")..("itai"):reverse():reverse():reverse()..("nmfalh"):gsub("m","g"):gsub("h","t"):gsub("l","r"):gsub("f","F")):sub(2):reverse().."E"):reverse())
end

local function antiVoidFixchar(part)
	local localplr = game.Players.LocalPlayer
	local character = localplr.Character
	if character and antiVoidCheckreq() then
		local piv = character:GetPivot()
		character:PivotTo(CFrame.new(piv.Position.X, antiVoidDestroyHeight + antiVoidDhto + character:GetExtentsSize().Y, piv.Position.Z))
	end
	if part then
		part.Velocity = Vector3.new(0,0,0)
		if character then
			for i,v in pairs(character:GetChildren()) do
				if v:IsA("BasePart") then
					v.Velocity = Vector3.new(0,0,0)
				end
			end
		end
	end
	if antiVoidTpcframe ~= nil and antiVoidSentnotif == false then
		antiVoidSentnotif = true
		antiVoidPrompt("Teleport back to last touched (buggy)", true, function()
			local char = game.Players.LocalPlayer.Character
			if char then
				char:PivotTo(antiVoidTpcframe)
			end
			if part then
				part.Velocity = Vector3.new(0,0,0)
			end
		end)
	end
end

local function antiVoidDochar(character)
	coroutine.wrap(function()
		repeat task.wait() until character:FindFirstChildWhichIsA("Humanoid")
		local hum = character:FindFirstChildWhichIsA("Humanoid")
		local state = hum:GetState()
		local stateConn = hum.StateChanged:Connect(function(old, new)
			state = new
		end)
		table.insert(antiVoidConnections, stateConn)
		local oldstate = nil
		while hum ~= nil and hum.Parent ~= nil and not antiVoidStopped do
			task.wait()
			if state ~= oldstate and (state ~= Enum.HumanoidStateType.Jumping and state ~= Enum.HumanoidStateType.Freefall) or (state == Enum.HumanoidStateType.Running or state == Enum.HumanoidStateType.Landed) then
				antiVoidTpcframe = antiVoidCharcframe
			end
			oldstate = state
		end
	end)()
end

local function enableAntiVoid()
	antiVoidStopped = false
	antiVoidDestroyHeight = workspace.FallenPartsDestroyHeight
	antiVoidDestroyHeightNew = antiVoidDestroyHeight + antiVoidDhoffset
	workspace.FallenPartsDestroyHeight = -50000

	local localplr = game.Players.LocalPlayer
	local character = localplr.Character

	antiVoidCharAddedConn = localplr.CharacterAdded:Connect(function(character2)
		character = character2
		antiVoidDochar(character2)
	end)

	if character then
		antiVoidDochar(character)
	end

	antiVoidSteppedConn = game:GetService("RunService").Stepped:Connect(function()
		local char = localplr.Character
		if char and char:FindFirstChildWhichIsA("BasePart") then
			local part = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart")
			local cfr = (char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart.CFrame) or char:GetPivot()
			antiVoidCharcframe = cfr
			if cfr.Position.Y < antiVoidDestroyHeightNew then
				antiVoidFixchar(part)
			end
			local partvel = part.Velocity
			if (partvel.Y / antiVoidFpsdiv) + part.Position.Y < antiVoidDestroyHeightNew then
				antiVoidFixchar(part)
			end
		end
	end)
end

local function disableAntiVoid()
	antiVoidStopped = true
	workspace.FallenPartsDestroyHeight = antiVoidDestroyHeight
	if antiVoidCharAddedConn then
		antiVoidCharAddedConn:Disconnect()
		antiVoidCharAddedConn = nil
	end
	if antiVoidSteppedConn then
		antiVoidSteppedConn:Disconnect()
		antiVoidSteppedConn = nil
	end
	for _, v in pairs(antiVoidConnections) do
		v:Disconnect()
	end
	antiVoidConnections = {}
end

local function toggleAntiVoid()
	antiVoidEnabled = not antiVoidEnabled
	if antiVoidEnabled then
		enableAntiVoid()
	else
		disableAntiVoid()
	end
end


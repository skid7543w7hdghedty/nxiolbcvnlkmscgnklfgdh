local function refreshConfigDropdown()
	for _, child in ipairs(configDropdownList:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	local files = getConfigFiles()
	configDropdownList.CanvasSize = UDim2.new(0, 0, 0, #files * 30)
	configDropdownFrame.Size = UDim2.new(0, 164, 0, math.min(#files * 30, 150))
	for i, name in ipairs(files) do
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1, 0, 0, 30)
		btn.Position = UDim2.new(0, 0, 0, (i-1)*30)
		btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		btn.Text = name
		btn.Font = Enum.Font.SourceSansBold
		btn.TextSize = 14
		btn.AutoButtonColor = false
		btn.ZIndex = 10
		btn.Parent = configDropdownList
		btn.MouseButton1Click:Connect(function()
			configListSelect.Text = name .. " ▼"
			configDropdownFrame.Visible = false
			-- Load config
			local fullPath = CONFIGS_DIR .. "/" .. name .. ".json"
			local ok, data = pcall(function() return readfile(fullPath) end)
			if ok and data then
				local decoded = game:GetService("HttpService"):JSONDecode(data)
				loadedConfig = decoded
				currentConfigName = name
				configListLabel.Text = "Config: " .. currentConfigName
				restoreFullConfig()
				notify("Config", "Loaded '" .. name .. "'", 2)
			end
		end)
		btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60) end)
		btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0) end)
	end
end


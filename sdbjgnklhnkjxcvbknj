-- Anti-Fling variables
antiFlingEnabled = false
antiFlingConnection = nil

function antiFlingCollide(plr)
	if plr and plr.Character and plr ~= game.Players.LocalPlayer then
		local char = plr.Character
		for i,v in pairs(char:GetChildren()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
				v.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				v.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				v.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0)
			end
		end
	end
end

local _antiFlingFrame = 0
function antiFlingEnable()
	_antiFlingFrame = _antiFlingFrame + 1
	if _antiFlingFrame % 5 ~= 0 then return end
	for i,v in pairs(reachCachePlayers) do
		antiFlingCollide(v)
	end
end

function toggleAntiFling()
	antiFlingEnabled = not antiFlingEnabled
	if antiFlingEnabled then
		antiFlingConnection = RunService.Heartbeat:Connect(antiFlingEnable)
	else
		if antiFlingConnection then
			antiFlingConnection:Disconnect()
			antiFlingConnection = nil
		end
		for i,v in pairs(reachCachePlayers) do
			if v ~= player and v.Character then
				for h,b in pairs(v.Character:GetChildren()) do
					if b:IsA("BasePart") then
						b.CanCollide = true
					end
				end
			end
		end
	end
end


		end
		for i,v in pairs(Players:GetPlayers()) do
			if v ~= player and v.Character then
				for h,b in pairs(v.Character:GetDescendants()) do
					if b:IsA("BasePart") and b.CanCollide == false then
						b.CanCollide = true

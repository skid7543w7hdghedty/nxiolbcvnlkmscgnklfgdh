function stringToKey(str)
	if not str then return nil end
	local kc = str:match("Enum%.KeyCode%.(.+)")
	if kc then return Enum.KeyCode[kc] end
	local ut = str:match("Enum%.UserInputType%.(.+)")
	if ut then return Enum.UserInputType[ut] end
	return nil
end


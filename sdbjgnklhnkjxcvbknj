		ageText = ageText .. " (" .. years .. "y, " .. months .. "m, " .. days .. "d)"
	end
	addInfoLine("Account Age: " .. ageText)

	local function calcRegDate(accountAge)
		local now = os.time()
		local utc = os.date("!*t", now)
		local d = utc.day - math.max(accountAge - 1, 0)
		local m = utc.month
		local y = utc.year
		local dim = {31,28,31,30,31,30,31,31,30,31,30,31}
		while d < 1 do
			m = m - 1
			if m < 1 then m = 12; y = y - 1 end
			local dm = dim[m]
			if m == 2 and (y%4==0 and (y%100~=0 or y%400==0)) then dm = 29 end
			d = d + dm
		end
		return string.format("%02d/%02d/%04d", d, m, y)
	end

	local function fetchRegDate(userId, accountAge)
		local created = nil
		local exactUnix = nil
		local ok, result = pcall(function()
			return (syn or _G).request({
				Url = "https://users.roblox.com/v1/users/" .. userId,
				Method = "GET"
			})
		end)
		if not (ok and result and result.StatusCode == 200) then
			ok, result = pcall(function()
				return game:HttpGetAsync("https://users.roblox.com/v1/users/" .. userId)
			end)
		end
		if ok and result then
			local rawCreated = nil
			if type(result) == "string" then
				local data = game:GetService("HttpService"):JSONDecode(result)
				if data and data.created then
					rawCreated = data.created
					local y, m, d = data.created:match("(%d+)-(%d+)-(%d+)")
					if y and m and d then created = string.format("%02d/%02d/%04d", tonumber(d), tonumber(m), tonumber(y)) end
				end
			elseif result.StatusCode == 200 and result.Body then
				local data = game:GetService("HttpService"):JSONDecode(result.Body)
				if data and data.created then
					rawCreated = data.created
					local y, m, d = data.created:match("(%d+)-(%d+)-(%d+)")
					if y and m and d then created = string.format("%02d/%02d/%04d", tonumber(d), tonumber(m), tonumber(y)) end
				end
			end
			if rawCreated then
				exactUnix = isoToUnix(rawCreated)
			end
		end
		return (created or calcRegDate(accountAge)), exactUnix
	end

	local regDateStr, exactRegUnix = fetchRegDate(plr.UserId, plr.AccountAge)

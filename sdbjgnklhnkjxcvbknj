-- Safe firetouchinterest wrapper: some executors throw or expose it under a
-- different name. Wrapping in pcall stops a single failed touch from aborting the
-- Heartbeat grab loops (that abort was why pickups were slow/erroring on weaker
-- executors) and keeps the console clean while grabbing as fast as possible.
_fireTouchFn = firetouchinterest or fireTouchInterest
function safeFireTouch(a, b)
	if not (_fireTouchFn and a and b) then return end
	pcall(_fireTouchFn, a, b, 0)
	pcall(_fireTouchFn, a, b, 1)
end


    RightGripAttachment = {part = "Right Arm", cf = CFrame.new(0, -1, 0)},
}

function changerFindCharAttachment(char, name, excludeParent)
    for _, d in ipairs(char:GetDescendants()) do
        if d:IsA("Attachment") and d.Name == name and d.Parent ~= excludeParent then
            return d
        end
    end
    return nil
end

-- Manually weld the accessory to the character. AddAccessory often parents the
-- accessory WITHOUT welding it on custom/R6 rigs, leaving it stuck at world
-- origin (invisible), which is why nothing showed up before.
function changerAttachAccessory(acc, char)
    local handle = acc:FindFirstChild("Handle") or acc:FindFirstChildWhichIsA("BasePart")
    if not handle then
        pcall(function() acc.Parent = char end)
        return
    end
    -- clear any existing welds so we control attachment fully
    for _, w in ipairs(handle:GetChildren()) do
        if w:IsA("Weld") or w:IsA("ManualWeld") or w:IsA("Motor6D") or w:IsA("WeldConstraint") then
            pcall(function() w:Destroy() end)
        end
    end
    local accAtt = handle:FindFirstChildWhichIsA("Attachment")
    local part, c0, c1
    if accAtt then
        local charAtt = changerFindCharAttachment(char, accAtt.Name, handle)
        if not charAtt then
            local def = changerR6Attachments[accAtt.Name]
            local partName = (def and def.part) or "Head"
            part = char:FindFirstChild(partName)
                or char:FindFirstChild("UpperTorso")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("Head")
            if part then
                charAtt = Instance.new("Attachment")
                charAtt.Name = accAtt.Name
                charAtt.CFrame = (def and def.cf) or CFrame.new()
                charAtt.Parent = part
            end
        end
        if charAtt then
            part = charAtt.Parent
            c0 = charAtt.CFrame
            c1 = accAtt.CFrame
        end
    end
    if not part then
        -- legacy hat / no attachment: weld to head with a sensible offset
        part = char:FindFirstChild("Head") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        c0 = CFrame.new(0, 0.5, 0)
        c1 = CFrame.new()
    end
    if part then
        local weld = Instance.new("Weld")
        weld.Name = "ChangerAccessoryWeld"
        weld.Part0 = part
        weld.Part1 = handle
        weld.C0 = c0
        weld.C1 = c1
        weld.Parent = handle
        pcall(function() handle.Massless = true end)
    end
    pcall(function() acc.Parent = char end)
end

-- Apply one loaded instance to the character. Reads the REAL ShirtTemplate /
-- PantsTemplate from the loaded clothing instance (a raw catalog ID is NOT a
-- valid template, which is why clothing was disappearing before).
function changerApplyInstance(obj, char, hum)
    if obj:IsA("Accessory") then
        changerNeutralize(obj)
        changerAttachAccessory(obj, char)
        changerNeutralize(obj)
        pcall(function() obj:SetAttribute("ChangerItem", true) end)
        return true
    elseif obj:IsA("Shirt") then
        local s = char:FindFirstChildOfClass("Shirt")
        if not s then s = Instance.new("Shirt"); s.Parent = char end
        s.ShirtTemplate = obj.ShirtTemplate
        pcall(function() s:SetAttribute("ChangerItem", true) end)
        return true
    elseif obj:IsA("Pants") then
        local p = char:FindFirstChildOfClass("Pants")
        if not p then p = Instance.new("Pants"); p.Parent = char end
        p.PantsTemplate = obj.PantsTemplate
        pcall(function() p:SetAttribute("ChangerItem", true) end)
        return true
    elseif obj:IsA("ShirtGraphic") then
        local g = char:FindFirstChildOfClass("ShirtGraphic")
        if not g then g = Instance.new("ShirtGraphic"); g.Parent = char end
        g.Graphic = obj.Graphic
        pcall(function() g:SetAttribute("ChangerItem", true) end)
        return true
    else
        for _, c in ipairs(obj:GetChildren()) do
            if changerApplyInstance(c, char, hum) then return true end
        end
    end
    return false
end

-- Apply any catalog ID; the loaded asset itself decides what it is and (for
-- accessories) where it attaches, so the slot label is purely organizational.
function changerApplyId(id)
    local digits = changerExtractId(id)
    if not digits then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local objs = changerLoadObjects(digits)
    local applied = false
    for _, obj in ipairs(objs) do
        local ok, res = pcall(changerApplyInstance, obj, char, hum)
        if ok and res then applied = true end
    end
    return applied
end

function changerUnchange()
    local char = player.Character
    if not char then return end
    -- Remove accessories, clothing
    for _, d in ipairs(char:GetChildren()) do
        pcall(function()
            if d:IsA("Accessory") or d:IsA("Shirt") or d:IsA("Pants") or d:IsA("ShirtGraphic") then
                d:Destroy()
            end
        end)
    end
    -- Also clean up any nested ChangerItem-tagged objects
    for _, d in ipairs(char:GetDescendants()) do
        pcall(function()
            if d:GetAttribute("ChangerItem") then d:Destroy() end
        end)
    end
end

function changerApplyData(data)
    for key, rawId in pairs(data) do
        local ids = changerExtractIds(rawId)
        for _, id in ipairs(ids) do
            pcall(function() changerApplyId(id) end)
        end
    end
end


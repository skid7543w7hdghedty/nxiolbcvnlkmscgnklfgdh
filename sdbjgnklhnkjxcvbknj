UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if not keyBinds then return end
	if listeningForBind then return end

	local bindKey
	if input.UserInputType == Enum.UserInputType.Keyboard then
		bindKey = input.KeyCode
	elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
		bindKey = Enum.UserInputType.MouseButton1
	elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
		bindKey = Enum.UserInputType.MouseButton2
	elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
		bindKey = Enum.UserInputType.MouseButton3
	else
		return
	end

	if justBoundKey then
		if justBoundKey == bindKey then
			justBoundKey = nil
			return
		end
		justBoundKey = nil
	end
	
	if keyBinds[bindKey] then
		local bindData = keyBinds[bindKey]
		if bindData.callback then
			bindData.callback()
		end
	end
end)


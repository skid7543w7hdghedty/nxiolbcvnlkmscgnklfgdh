-- AutoGrab Gun (Ultra Speed)
autoGrabGunEnabled = false
autoGrabGunConnections = {}
autoGrabGunProcessed = {}
autoGrabGunConnectedModels = {}
autoGrabGunMagnets = {}

autoGrabGunTargets = {
	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital = true, MilBase = true,
	Bank2 = true, Office3 = true, PoliceStation = true, ResearchFacility = true
}

function autoGrabGetRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

function autoGrabStartMagnet(drop)
	if autoGrabGunMagnets[drop] then return end
	autoGrabGunMagnets[drop] = RunService.Heartbeat:Connect(function()
		if not drop or not drop.Parent then
			if autoGrabGunMagnets[drop] then
				autoGrabGunMagnets[drop]:Disconnect()
				autoGrabGunMagnets[drop] = nil
			end
			return
		end
		local root = autoGrabGetRoot()
		if not root then return end
		local cf = root.CFrame
		if drop:IsA("BasePart") then
			drop.CFrame = cf
		elseif drop:IsA("Model") then
			drop:PivotTo(cf)
		else
			local part = drop:FindFirstChildWhichIsA("BasePart", true)
			if part then
				part.CFrame = cf
			end
		end
	end)
end

function autoGrabStopMagnet(drop)
	if autoGrabGunMagnets[drop] then
		autoGrabGunMagnets[drop]:Disconnect()
		autoGrabGunMagnets[drop] = nil
	end
end

function autoGrabClaimDrop(drop)
	if not autoGrabGunEnabled then return end
	if autoGrabGunProcessed[drop] then return end
	if not drop or not drop.Parent then return end
	autoGrabGunProcessed[drop] = true
	local root = autoGrabGetRoot()
	if not root then
		autoGrabGunProcessed[drop] = nil
		return
	end
	local char = player.Character
	local cf = root.CFrame

	-- Мгновенная многократная телепортация для максимальной скорости
	for i = 1, 5 do
		if not drop or not drop.Parent then break end
		if drop:IsA("BasePart") then
			drop.CFrame = cf
			drop.CanCollide = false
			drop.Transparency = 1
			drop.Parent = char
		elseif drop:IsA("Model") then
			drop:PivotTo(cf)
			drop.Parent = char
			for _, v in ipairs(drop:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
					v.Transparency = 1
					v.CFrame = cf
				end
			end
		else
			local part = drop:FindFirstChildWhichIsA("BasePart", true)
			if part then
				part.CFrame = cf
				part.CanCollide = false
				part.Transparency = 1
			end
			drop.Parent = char
		end
	end

	-- Запускаем магнит
	autoGrabStartMagnet(drop)

	drop.AncestryChanged:Connect(function()
		if not drop.Parent or drop.Parent == Workspace then
			autoGrabStopMagnet(drop)
			autoGrabGunProcessed[drop] = nil
		end
	end)

	-- Касание всех частей для подбора
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if hrp and drop then
			local parts = {}
			if drop:IsA("BasePart") then
				table.insert(parts, drop)
			elseif drop:IsA("Model") then
				for _, v in ipairs(drop:GetDescendants()) do
					if v:IsA("BasePart") then
						table.insert(parts, v)
					end
				end
			end
			for _, part in ipairs(parts) do
				pcall(function()
					firetouchinterest(hrp, part, 0)
					firetouchinterest(hrp, part, 1)
				end)
			end
		end
	end
end

function autoGrabConnectModel(model)
	if autoGrabGunConnectedModels[model] then return end
	autoGrabGunConnectedModels[model] = true

	-- Мгновенная проверка существующих
	for _, child in ipairs(model:GetDescendants()) do
		if child.Name == "GunDrop" then
			autoGrabClaimDrop(child)
		end
	end

	-- DescendantAdded для моментального перехвата
	local conn = model.DescendantAdded:Connect(function(descendant)
		if not autoGrabGunEnabled then return end
		if descendant.Name == "GunDrop" then
			-- Без задержки — мгновенный захват
			autoGrabClaimDrop(descendant)
		end
	end)
	autoGrabGunConnections[model] = conn

	-- ChildAdded тоже для скорости
	local conn2 = model.ChildAdded:Connect(function(child)
		if not autoGrabGunEnabled then return end
		if child.Name == "GunDrop" then
			autoGrabClaimDrop(child)
		end
		-- Проверяем потомков нового ребёнка
		if child:IsA("Model") or child:IsA("Folder") then
			for _, desc in ipairs(child:GetDescendants()) do
				if desc.Name == "GunDrop" then
					autoGrabClaimDrop(desc)
				end
			end
		end
	end)
	table.insert(autoGrabGunConnections, conn2)

	model.AncestryChanged:Connect(function()
		if not model.Parent then
			if autoGrabGunConnections[model] then
				autoGrabGunConnections[model]:Disconnect()
				autoGrabGunConnections[model] = nil
				autoGrabGunConnectedModels[model] = nil
			end
		end
	end)
end

function autoGrabScanWorkspace()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
		-- Также ловим GunDrop напрямую
		if obj.Name == "GunDrop" then
			autoGrabClaimDrop(obj)
		end
	end
end

function enableAutoGrabGun()
	autoGrabGunEnabled = true
	autoGrabGunProcessed = {}
	autoGrabGunConnectedModels = {}
	for drop, conn in pairs(autoGrabGunMagnets) do
		conn:Disconnect()
	end
	autoGrabGunMagnets = {}
	for model, conn in pairs(autoGrabGunConnections) do
		if conn then conn:Disconnect() end
	end
	autoGrabGunConnections = {}

	autoGrabScanWorkspace()

	-- Workspace.DescendantAdded — мгновенный перехват
	table.insert(autoGrabGunConnections, Workspace.DescendantAdded:Connect(function(obj)
		if not autoGrabGunEnabled then return end
		if obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
		if obj.Name == "GunDrop" then
			autoGrabClaimDrop(obj)
		end
	end))

	-- Workspace.ChildAdded — дополнительный перехват верхнего уровня
	table.insert(autoGrabGunConnections, Workspace.ChildAdded:Connect(function(obj)
		if not autoGrabGunEnabled then return end
		if obj.Name == "GunDrop" then
			autoGrabClaimDrop(obj)
		end
		if obj:IsA("Model") and autoGrabGunTargets[obj.Name] then
			autoGrabConnectModel(obj)
		end
	end))

	table.insert(autoGrabGunConnections, player.CharacterAdded:Connect(function(char)
		if not autoGrabGunEnabled then return end
		for drop, conn in pairs(autoGrabGunMagnets) do
			conn:Disconnect()
		end
		autoGrabGunMagnets = {}
		autoGrabGunProcessed = {}
		autoGrabGunConnectedModels = {}
		char:WaitForChild("HumanoidRootPart")
		autoGrabScanWorkspace()
	end))

	-- Быстрый цикл сканирования — каждые 3 секунды
	task.spawn(function()
		while autoGrabGunEnabled do
			task.wait(3)
			if autoGrabGunEnabled then
				autoGrabScanWorkspace()
			end
		end
	end)
end

function disableAutoGrabGun()
	autoGrabGunEnabled = false
	for model, conn in pairs(autoGrabGunConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then
			conn:Disconnect()
		end
	end
	autoGrabGunConnections = {}
	for drop, conn in pairs(autoGrabGunMagnets) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	autoGrabGunMagnets = {}
	autoGrabGunProcessed = {}
	autoGrabGunConnectedModels = {}
end

function toggleAutoGrabGun()
	if autoGrabGunEnabled then
		disableAutoGrabGun()
	else
		enableAutoGrabGun()
	end
end


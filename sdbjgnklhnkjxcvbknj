function createCategoryButton(shortName, layoutOrder)
	-- Map short names to full names
	fullNames = {
		["Mvmt"] = "Movement",
		["Cmbt"] = "Combat",
		["Trl"] = "Trolling",
		["Tele"] = "Teleports",
		["Util"] = "Utilities",
		["Anim"] = "Animations",
		["Bind"] = "Binds",
		["Team"] = "Teamers",
		["Main"] = "Main",
		["Btn"] = "Buttons",
		["Set"] = "Settings"
	}
	local fullName = fullNames[shortName] or shortName
	
	local btn = Instance.new("TextButton")
	btn.Name = fullName .. "CatBtn"
	btn.Size = UDim2.new(1, 0, 0, 36)
	btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	btn.TextColor3 = Color3.fromRGB(170, 170, 170)
	btn.Text = fullName
	btn.Font = Enum.Font.SourceSansBold
	btn.TextSize = 10
	btn.AutoButtonColor = false
	if layoutOrder then btn.LayoutOrder = layoutOrder end
	btn.Parent = leftSidebar
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 4)
	btnCorner.Parent = btn
	
	categories[fullName] = { button = btn, isActive = (fullName == "Main") }
	
	if fullName == "Main" then
		btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		btn.TextColor3 = Color3.fromRGB(0, 0, 0)
	end
	
	btn.MouseButton1Click:Connect(function()
		-- Deactivate all categories
		for catName, catData in pairs(categories) do
			catData.button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			catData.button.TextColor3 = Color3.fromRGB(170, 170, 170)
			catData.isActive = false
		end
		
		-- Activate this category
		currentCategory = fullName
		btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		btn.TextColor3 = Color3.fromRGB(0, 0, 0)
		categories[fullName].isActive = true
		
		-- Update content visibility
		for catName, catFrame in pairs(categoryFrames) do
			catFrame.Visible = (catName == fullName)
		end
	end)
	
	return btn
end


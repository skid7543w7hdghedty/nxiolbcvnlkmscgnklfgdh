		if not gameNotifEnabled then continue end

		local ok, result = pcall(function()
			return ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
		end)

		if ok and result then
			local currentMurderer = nil
			local currentSheriff = nil

			for name, data in pairs(result) do
				if data.Role == "Murderer" then
					currentMurderer = name
				elseif data.Role == "Sheriff" then
					currentSheriff = name
				end
			end

			local roundKey = (currentMurderer or "") .. "_" .. (currentSheriff or "")

			if roundKey ~= gameNotifLastRound and currentMurderer and currentSheriff then
				gameNotifLastRound = roundKey
				gameNotifSendRound(currentMurderer, currentSheriff)
			end
			gameNotifPrevRoles = result
		end
	end
end)


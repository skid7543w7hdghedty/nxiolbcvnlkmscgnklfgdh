-- ============================================================
-- Kill functions: knife touch-kill (no teleport) — only works while you
-- hold the Murderer's knife. Kills from where you are via firetouchinterest.
-- ============================================================
function killGetKnife()
	local char = player.Character
	if not char then return nil end
	local tool = char:FindFirstChild("Knife") or char:FindFirstChildOfClass("Tool")
	if not (tool and tool:FindFirstChild("Handle")) then
		local bp = player:FindFirstChild("Backpack")
		local bk = bp and bp:FindFirstChild("Knife")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if bk and hum then
			pcall(function() hum:EquipTool(bk) end)
			task.wait()
			tool = char:FindFirstChild("Knife") or char:FindFirstChildOfClass("Tool")
		end
	end
	if tool and tool:FindFirstChild("Handle") then return tool end
	return nil
end

function killIsAlive(char)
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	return hum ~= nil and hum.Health > 0
end

-- [fix] Animation stopping removed entirely — it interfered with the knife's
-- own client scripts and served no purpose for the kill itself.
function killKnifeTouch(targetChar, knife)
	if not (targetChar and knife and knife:FindFirstChild("Handle")) then return false end
	local handle = knife.Handle
	pcall(function() knife:Activate() end)
	for _, part in ipairs(targetChar:GetDescendants()) do
		if part:IsA("BasePart") then
			safeFireTouch(handle, part)
		end
	end
	pcall(function() knife:Activate() end)
	return true
end

-- Detect executor capabilities once at startup
_canSetHidden = pcall(function() return typeof(sethiddenproperty) == "function" and sethiddenproperty end)
_hasFTI = (_fireTouchFn ~= nil)

-- Core kill: teleport to target, activate knife, fire touches
-- Uses every available method to ensure the kill lands
function killBindOnce(targetPlayer, knife, hrp)
	local tChar = targetPlayer.Character
	local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
	if not (tChar and tRoot and knife and knife:FindFirstChild("Handle")) then return false end

	local handle = knife.Handle

	for i = 1, 10 do
		tChar = targetPlayer.Character
		tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
		if not (tChar and tRoot) then break end

		-- sethiddenproperty for server-side stealth + CFrame for physical overlap
		if _canSetHidden then
			pcall(sethiddenproperty, hrp, "PhysicsRepRootPart", tRoot)
		end
		pcall(function() hrp.CFrame = tRoot.CFrame end)

		pcall(function() knife:Activate() end)

		for _, part in ipairs(tChar:GetDescendants()) do
			if part:IsA("BasePart") then
				safeFireTouch(handle, part)
			end
		end

		pcall(function() knife:Activate() end)

		if not killIsAlive(tChar) then return true end
		RunService.Heartbeat:Wait()
	end
	return true
end

-- Get the player's REAL position (works even with Anti-Shoot / Desync active)
function killGetRealCFrame()
	if (PastedSources or DesyncSpinActive) and DesyncTypes[1] then
		return DesyncTypes[1]
	end
	local c = player.Character
	local r = c and c:FindFirstChild("HumanoidRootPart")
	return r and r.CFrame or CFrame.new()
end

-- Kill a list of players: BRING them to us + auto-knife (no teleporting ourselves)
function killBatch(targets, knife)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not (hrp and hum and knife and knife:FindFirstChild("Handle")) then return 0 end

	local handle = knife.Handle

	-- Bring all targets to us and auto-knife for 30 frames
	for frame = 1, 30 do
		local bringCF = killGetRealCFrame()
		local allDead = true

		for idx, plr in ipairs(targets) do
			if plr and plr.Character and killIsAlive(plr.Character) then
				allDead = false
				local tChar = plr.Character
				local tRoot = tChar:FindFirstChild("HumanoidRootPart")
				if tRoot then
					-- Bring target to our real position (small offset per player)
					pcall(function()
						tRoot.CFrame = bringCF * CFrame.new(idx * 0.5, 0, 0)
					end)
					-- Strip their weapons so they can't fight back
					pcall(function()
						local bp = plr:FindFirstChild("Backpack")
						if bp then bp:ClearAllChildren() end
						for _, child in pairs(tChar:GetChildren()) do
							if child:IsA("Tool") then child:Destroy() end
						end
					end)
					-- Knife: activate + firetouchinterest on all parts
					pcall(function() knife:Activate() end)
					for _, part in ipairs(tChar:GetDescendants()) do
						if part:IsA("BasePart") then
							safeFireTouch(handle, part)
						end
					end
				end
			end
		end

		if allDead then break end
		RunService.Heartbeat:Wait()
	end

	local count = 0
	for _, plr in ipairs(targets) do
		if plr and plr.Character and not killIsAlive(plr.Character) then count = count + 1 end
	end
	return count
end

function doKillEveryone(exceptFriends)
	local knife = killGetKnife()
	if not knife then return nil end
	local targets = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local skip = false
			if exceptFriends then
				if isPlayerWhitelisted(plr.Name) then skip = true end
				if not skip then
					local okF, isF = pcall(function() return player:IsFriendsWith(plr.UserId) end)
					if okF and isF then skip = true end
				end
			end
			if not skip and plr.Character and killIsAlive(plr.Character) then
				table.insert(targets, plr)
			end
		end
	end
	return killBatch(targets, knife)
end

function doKillSheriff()
	local knife = killGetKnife()
	if not knife then return nil end
	local ok, result = pcall(function()
		return invokePlayerData()
	end)
	if not (ok and result) then return 0 end
	local targets = {}
	for name, data in pairs(result) do
		if name ~= player.Name and not isPlayerWhitelisted(name)
			and (data.Role == "Sheriff" or data.Role == "Hero" or (data.HasGun and data.Role ~= "Murderer")) then
			local plr = Players:FindFirstChild(name)
			if plr and plr.Character and killIsAlive(plr.Character) then
				table.insert(targets, plr)
			end
		end
	end
	return killBatch(targets, knife)
end

function doKillPlayer(targetName)
	local knife = killGetKnife()
	if not knife then return false, "noknife" end
	local plr = targetName and Players:FindFirstChild(targetName)
	if not (plr and plr.Character) then return false, "notarget" end
	if not killIsAlive(plr.Character) then return false, "dead" end
	killBatch({plr}, knife)
	return true
end


		end)
		deleteBtn.MouseLeave:Connect(function()
			deleteBtn.BackgroundColor3 = Color3.fromRGB(40, 25, 0)
		end)

		yPos += 36
	end

	savedTeamersScroll.CanvasSize = UDim2.new(0, 0, 0, math.max(yPos, 0))
end


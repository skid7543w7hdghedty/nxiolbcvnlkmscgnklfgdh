function espCleanGun(gunDrop)
	if not gunDrop then return end
	local hl = gunDrop:FindFirstChild(ESP_GUN_HL_TAG)
	if hl then hl:Destroy() end
	for _, child in ipairs(gunDrop:GetDescendants()) do
		if child:IsA("BasePart") then
			local bb = child:FindFirstChild(ESP_GUN_BB_TAG)
			if bb then bb:Destroy() end
		end
	end
	if gunDrop:IsA("BasePart") then
		local bb = gunDrop:FindFirstChild(ESP_GUN_BB_TAG)
		if bb then bb:Destroy() end
	end
end

function espHookGunDrop(gunDrop)
	if espTrackedGuns[gunDrop] then return end
	espCreateGunHighlight(gunDrop)
	local _, distLabel = espCreateGunBillboard(gunDrop)
	local conn = RunService.Heartbeat:Connect(function()
		if not espEnabled then return end
		if not gunDrop or not gunDrop.Parent then return end
		if distLabel then
			local pos = espGetGunPosition(gunDrop)
			if pos then
				local dist = espGetDistFromPos(pos)
				distLabel.Text = dist and ("[" .. tostring(dist) .. "m]") or ""
			end
		end
	end)
	espTrackedGuns[gunDrop] = { conn = conn }
	gunDrop.AncestryChanged:Connect(function(_, parent)
		if not parent then
			if espTrackedGuns[gunDrop] then
				if espTrackedGuns[gunDrop].conn then
					espTrackedGuns[gunDrop].conn:Disconnect()
				end
				espTrackedGuns[gunDrop] = nil
			end
			espCleanGun(gunDrop)
		end
	end)
end

function espFindGunDropsInModel(mapModel)
	for _, child in ipairs(mapModel:GetDescendants()) do
		if child.Name == "GunDrop" then
			task.spawn(espHookGunDrop, child)
		end
	end
	local mapConn = mapModel.DescendantAdded:Connect(function(descendant)
		if not espEnabled then return end
		if descendant.Name == "GunDrop" then
			task.spawn(espHookGunDrop, descendant)
		end
	end)
	table.insert(espConnections, mapConn)
end

function espScanForMaps()
	for _, mapName in ipairs(ESP_MAP_NAMES) do
		local mapModel = Workspace:FindFirstChild(mapName)
		if mapModel then
			espFindGunDropsInModel(mapModel)
		end
	end
end

function espUpdatePlayer(plr)
	if plr == player then return end
	local character = plr.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	local color = espGetRoleColor(plr)
	local roleSuffix = espGetRoleName(plr)
	local dist = espGetDist(character)
	local hl = espGetOrMakeHighlight(character)
	hl.OutlineColor = color
	hl.FillColor = color
	local nameLabel, distLabel = espGetOrMakeBillboard(character)
	if nameLabel then
		nameLabel.TextColor3 = color
		nameLabel.Text = plr.Name .. roleSuffix
	end
	if distLabel then
		distLabel.TextColor3 = color
		distLabel.Text = dist and "[" .. tostring(dist) .. "m]" or ""
	end
end

function espCleanCharacter(character)
	if not character then return end
	local oldHl = character:FindFirstChild(ESP_HL_TAG)
	if oldHl then oldHl:Destroy() end
	local head = character:FindFirstChild("Head")
	if head then
		local oldBb = head:FindFirstChild(ESP_BB_TAG)
		if oldBb then oldBb:Destroy() end
	end
end

local _espFrameCounter = 0
RunService.Heartbeat:Connect(function()
	_espFrameCounter = _espFrameCounter + 1
end)

function espHookCharacter(plr, character)
	character:WaitForChild("HumanoidRootPart", 10)
	local myOffset = math.random(0, 2)
	local conn = RunService.Heartbeat:Connect(function()
		if not espEnabled then return end
		if not character.Parent then return end
		-- Stagger players across 3 frames to reduce per-frame cost
		if _espFrameCounter % 3 ~= myOffset then return end
		espUpdatePlayer(plr)
	end)
	local prev = espTrackedData[plr]
	if prev then
		if prev.conn then prev.conn:Disconnect() end
		espCleanCharacter(prev.character)
	end
	espTrackedData[plr] = { conn = conn, character = character }
	character.AncestryChanged:Connect(function(_, parent)
		if not parent and espTrackedData[plr] and espTrackedData[plr].character == character then
			conn:Disconnect()
		end
	end)
end

function espHookPlayer(plr)
	if plr == player then return end
	if plr.Character then task.spawn(espHookCharacter, plr, plr.Character) end
	local charAddedConn = plr.CharacterAdded:Connect(function(character)
		task.spawn(espHookCharacter, plr, character)
	end)
	table.insert(espConnections, charAddedConn)
end

function espCleanAll()
	for plr, data in pairs(espTrackedData) do
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
	end
	espTrackedData = {}
	for gunDrop, data in pairs(espTrackedGuns) do
		if data.conn then data.conn:Disconnect() end
		espCleanGun(gunDrop)
	end
	espTrackedGuns = {}
	for _, conn in ipairs(espConnections) do
		if typeof(conn) == "RBXScriptConnection" and conn.Connected then
			conn:Disconnect()
		end
	end
	espConnections = {}
	espRoles = nil
end

function espEnableAll()
	-- Hook players
	for _, plr in ipairs(Players:GetPlayers()) do
		task.spawn(espHookPlayer, plr)
	end
	table.insert(espConnections, Players.PlayerAdded:Connect(function(plr)
		espHookPlayer(plr)
	end))
	table.insert(espConnections, Players.PlayerRemoving:Connect(function(plr)
		local data = espTrackedData[plr]
		if not data then return end
		if data.conn then data.conn:Disconnect() end
		espCleanCharacter(data.character)
		espTrackedData[plr] = nil
	end))

	-- Roles loop
	task.spawn(function()
		while espEnabled do
			local ok, result = pcall(function()
				return ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
			end)
			if ok and result then
				espRoles = result
			end
			task.wait(0.75)
		end
	end)

	-- Gun ESP: scan existing maps
	espScanForMaps()

	-- Gun ESP: watch for new maps
	table.insert(espConnections, Workspace.ChildAdded:Connect(function(child)
		if not espEnabled then return end
		for _, mapName in ipairs(ESP_MAP_NAMES) do
			if child.Name == mapName then
				task.wait(0.5)
				espFindGunDropsInModel(child)
				break
			end
		end
	end))

	-- Gun ESP: watch for GunDrop anywhere inside map hierarchy
	table.insert(espConnections, Workspace.DescendantAdded:Connect(function(descendant)
		if not espEnabled then return end
		if descendant.Name == "GunDrop" then
			local parent = descendant.Parent
			while parent and parent ~= Workspace do
				for _, mapName in ipairs(ESP_MAP_NAMES) do
					if parent.Name == mapName then
						task.spawn(espHookGunDrop, descendant)
						return
					end
				end
				parent = parent.Parent
			end
		end
	end))
end

function toggleEsp()
	espEnabled = not espEnabled
	if espEnabled then
		espEnableAll()
	else
		espCleanAll()
	end
end


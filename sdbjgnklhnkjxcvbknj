function refreshSavedTeamers()
	if not savedTeamersScroll then return end
	for _, child in ipairs(savedTeamersScroll:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end

	local names = {}
	for name, _ in pairs(markedTeamers) do
		table.insert(names, name)
	end
	table.sort(names, function(a, b) return a:lower() < b:lower() end)

	if #names == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Size = UDim2.new(1, 0, 0, 30)
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Text = "No saved teamers"
		emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
		emptyLabel.Font = Enum.Font.SourceSansBold
		emptyLabel.TextSize = 14
		emptyLabel.Parent = savedTeamersScroll
	end

	local yPos = 0
	for _, name in ipairs(names) do
		local entry = Instance.new("Frame")
		entry.Name = name .. "SavedEntry"
		entry.Size = UDim2.new(1, 0, 0, 30)
		entry.Position = UDim2.new(0, 0, 0, yPos)
		entry.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		entry.BorderSizePixel = 0
		entry.Parent = savedTeamersScroll

		local entryCorner = Instance.new("UICorner")
		entryCorner.CornerRadius = UDim.new(0, 6)
		entryCorner.Parent = entry

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, -40, 1, 0)
		nameLabel.Position = UDim2.new(0, 8, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = name
		nameLabel.TextColor3 = Color3.fromRGB(255, 140, 0)
		nameLabel.TextSize = 15
		nameLabel.Font = Enum.Font.SourceSansBold
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.Parent = entry

		local deleteBtn = Instance.new("TextButton")
		deleteBtn.Name = name .. "DelBtn"
		deleteBtn.Size = UDim2.new(0, 24, 0, 24)
		deleteBtn.Position = UDim2.new(1, -28, 0.5, -12)
		deleteBtn.BackgroundColor3 = Color3.fromRGB(40, 25, 0)
		deleteBtn.BorderSizePixel = 0
		deleteBtn.Text = "X"
		deleteBtn.TextColor3 = Color3.fromRGB(255, 180, 50)
		deleteBtn.Font = Enum.Font.SourceSansBold
		deleteBtn.TextSize = 14
		deleteBtn.Parent = entry

		local deleteBtnCorner = Instance.new("UICorner")
		deleteBtnCorner.CornerRadius = UDim.new(0, 4)
		deleteBtnCorner.Parent = deleteBtn

		deleteBtn.MouseButton1Click:Connect(function()
			markedTeamers[name] = nil
			saveTeamers()
			refreshSavedTeamers()
			notify("Teamers", name .. " removed", 2)
		end)

		deleteBtn.MouseEnter:Connect(function()

function executeNanFlingEveryone()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end

	-- Save ORIGINAL position before flinging anyone
	local originalCFrame = hrp.CFrame
	local originalPlatformStand = hum.PlatformStand

	-- Collect alive targets
	local targets = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and not isPlayerWhitelisted(plr.Name) then
			local c = plr.Character
			if c and c:FindFirstChild("Humanoid") and c.Humanoid.Health > 0 then
				targets[#targets + 1] = plr.Name
			end
		end
	end

	for i, name in ipairs(targets) do
		nanFlingTargetName = name
		executeNanFling()
		-- Wait fling duration only (1.5s). Next executeNanFling call cancels restore via nanFlingCallCounter.
		task.wait(1.6)
	end

	-- Cancel the last fling's restore phase
	nanFlingCallCounter = nanFlingCallCounter + 1
	if nanFlingConnection then
		nanFlingConnection:Disconnect()
		nanFlingConnection = nil
	end

	-- Restore to ORIGINAL position (not where the last target was)
	char = player.Character
	hrp = char and char:FindFirstChild("HumanoidRootPart")
	hum = char and char:FindFirstChildOfClass("Humanoid")
	if hrp and hum then
		pcall(sethiddenproperty, hrp, "PhysicsRepRootPart", hrp)
		local restoreCF = originalCFrame
		local safeY = (workspace.FallenPartsDestroyHeight or -500) + 50
		if restoreCF.Position.Y < safeY then
			restoreCF = CFrame.new(restoreCF.Position.X, safeY, restoreCF.Position.Z)
		end
		for i = 1, 15 do
			for _, part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then
					part.Velocity = Vector3.zero
					part.RotVelocity = Vector3.zero
					part.AssemblyLinearVelocity = Vector3.zero
					part.AssemblyAngularVelocity = Vector3.zero
				end
			end
			hrp.CFrame = restoreCF
			char:SetPrimaryPartCFrame(restoreCF)
			task.wait()
		end
		hum.PlatformStand = originalPlatformStand
		pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
	end
end

-- Reset a LIST of selected players one after another, then restore to the
-- ORIGINAL position (same technique as Reset Everyone). This fixes the
-- multi-select Reset: the old loop let each subsequent fling save/restore the
-- WRONG position and cancelled the final restore entirely, so only the first
-- selected player reliably worked.
function executeNanFlingNames(names)
	if not names or #names == 0 then return end
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end

	-- Save ORIGINAL position before flinging anyone
	local originalCFrame = hrp.CFrame
	local originalPlatformStand = hum.PlatformStand

	for _, name in ipairs(names) do
		if not isPlayerWhitelisted(name) then
			nanFlingTargetName = name
			executeNanFling()
			-- Wait fling duration only (1.5s). The next executeNanFling call
			-- cancels the previous restore via nanFlingCallCounter.
			task.wait(1.6)
		end
	end

	-- Cancel the last fling's restore phase
	nanFlingCallCounter = nanFlingCallCounter + 1
	if nanFlingConnection then
		nanFlingConnection:Disconnect()
		nanFlingConnection = nil
	end

	-- Restore to ORIGINAL position (not where the last target was)
	char = player.Character
	hrp = char and char:FindFirstChild("HumanoidRootPart")
	hum = char and char:FindFirstChildOfClass("Humanoid")
	if hrp and hum then
		pcall(sethiddenproperty, hrp, "PhysicsRepRootPart", hrp)
		local restoreCF = originalCFrame
		local safeY = (workspace.FallenPartsDestroyHeight or -500) + 50
		if restoreCF.Position.Y < safeY then
			restoreCF = CFrame.new(restoreCF.Position.X, safeY, restoreCF.Position.Z)
		end
		for i = 1, 15 do
			for _, part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then
					part.Velocity = Vector3.zero
					part.RotVelocity = Vector3.zero
					part.AssemblyLinearVelocity = Vector3.zero
					part.AssemblyAngularVelocity = Vector3.zero
				end
			end
			hrp.CFrame = restoreCF
			char:SetPrimaryPartCFrame(restoreCF)
			task.wait()
		end
		hum.PlatformStand = originalPlatformStand
		pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
	end
end


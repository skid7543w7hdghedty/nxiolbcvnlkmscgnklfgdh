	end

	local function attachCharStats(char)
		disconnectConns()
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not hum or not root then return end
		local function updateJP()
			if jumpLine and jumpLine.Parent then
				jumpLine.Text = "Jump Power: " .. hum.JumpPower
			end
		end
		updateJP()
		table.insert(popupConns, hum:GetPropertyChangedSignal("JumpPower"):Connect(updateJP))
	end

	attachCharStats(plr.Character)
	table.insert(popupConns, plr.CharacterAdded:Connect(function(newChar)
		task.wait(1)
		if popupAlive then attachCharStats(newChar) end
	end))

	local creationTime = exactRegUnix or (os.time() - plr.AccountAge * 86400)

	task.spawn(function()
		while popupAlive do
			task.wait(0.15)
			local char = plr.Character
			if char then
				local hum = char:FindFirstChildOfClass("Humanoid")
				local root = char:FindFirstChild("HumanoidRootPart")
				if hum and root then
					if healthLine and healthLine.Parent then
						healthLine.Text = "Health: " .. math.floor(hum.Health) .. "/" .. hum.MaxHealth
					end
					local vel = root.AssemblyLinearVelocity
					local horizSpeed = math.floor(math.sqrt(vel.X*vel.X + vel.Z*vel.Z) + 0.5)
					if speedLine and speedLine.Parent then
						speedLine.Text = "Walk Speed: " .. horizSpeed
					end
					if positionLine and positionLine.Parent then
						local p = root.Position
						positionLine.Text = string.format("Position: %.1f, %.1f, %.1f", p.X, p.Y, p.Z)
					end
				end
			end
			if exactAgeLine and exactAgeLine.Parent then
				local diff = os.time() - creationTime
				local totalDays = math.floor(diff / 86400)
				local y = math.floor(totalDays / 365)
				local rd = totalDays % 365
				local m = math.floor(rd / 30)
				local d = rd % 30
				local h = math.floor((diff % 86400) / 3600)
				local mn = math.floor((diff % 3600) / 60)
				local s = diff % 60
				exactAgeLine.Text = string.format("Current Age: %dy, %dm, %dd, %dh, %dm, %ds", y, m, d, h, mn, s)
			end
		end
	end)


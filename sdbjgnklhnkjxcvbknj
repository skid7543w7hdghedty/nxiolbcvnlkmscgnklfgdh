-- РњРіРЅРѕРІРµРЅРЅР°СЏ С‚РµР»РµРїРѕСЂС‚Р°С†РёСЏ Рє CFrame
function doInstantTp(myHrp, myChar, targetCF)
	myHrp.CFrame = targetCF
	myChar:SetPrimaryPartCFrame(targetCF)
	myHrp.AssemblyLinearVelocity = Vector3.zero
	myHrp.AssemblyAngularVelocity = Vector3.zero
	-- Р¤РёРєСЃРёСЂСѓРµРј РЅР° 2 РєР°РґСЂР° С‡С‚РѕР± С„РёР·РёРєР° РЅРµ РѕС‚РєРёРЅСѓР»Р°
	local n = 0
	local fixConn
	fixConn = RunService.Heartbeat:Connect(function()
		n = n + 1
		myHrp.CFrame = targetCF
		myHrp.AssemblyLinearVelocity = Vector3.zero
		if n >= 2 then fixConn:Disconnect() end
	end)
end

function tpToRole(roleName)
	tpGetRoles()
	if not tpRoles then
		notify("Error", "Could not get roles", 2)
		return
	end

	local lastTarget = nil
	local lastName = nil
	local lastAliveTarget = nil
	local lastAliveName = nil

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local data = tpRoles[plr.Name]
			if data then
				local isTarget = false

				if roleName == "Sheriff" then
					isTarget = (data.Role == "Sheriff" or data.HasGun)
				elseif roleName == "Hero" then
					isTarget = (data.Role == "Hero")
				elseif roleName == "Murderer" then
					isTarget = (data.Role == "Murderer")
				end

				if isTarget then
					lastTarget = plr
					lastName = plr.Name
					local ch = plr.Character
					local hum = ch and ch:FindFirstChildOfClass("Humanoid")
					if hum and hum.Health > 0 then
						lastAliveTarget = plr
						lastAliveName = plr.Name
					end
				end
			end
		end
	end

	-- Always prefer the LAST target that is still alive (the current hero/sheriff), so we
	-- never teleport to an older / dead role holder instead of the most recent one.
	lastTarget = lastAliveTarget or lastTarget
	lastName = lastAliveName or lastName

	if lastTarget then
		local char = lastTarget.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local myChar = player.Character
		local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")

		if hrp and myHrp then
			local targetCF = hrp.CFrame * CFrame.new(0, 0, 3)
			for i = 1, 10 do
				myHrp.CFrame = targetCF
				myChar:SetPrimaryPartCFrame(targetCF)
				myHrp.Velocity = Vector3.new(0, 0, 0)
				myHrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				myHrp.RotVelocity = Vector3.new(0, 0, 0)
			end
			local fixConn
			fixConn = RunService.Heartbeat:Connect(function()
				myHrp.CFrame = targetCF
				myHrp.Velocity = Vector3.new(0, 0, 0)
				myHrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				fixConn:Disconnect()
			end)
			notify("Teleported", "TP to " .. roleName .. ": " .. lastName, 2)
		end
		return
	end

	notify("Error", "No " .. roleName .. " found", 2)
end


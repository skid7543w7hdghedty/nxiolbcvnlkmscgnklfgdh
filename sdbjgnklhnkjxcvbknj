-- Auto Mute Coins: fully silence MM2 coin pickup / collect sounds
autoMuteCoinsEnabled = false
autoMuteCoinsConnections = {}

function isCoinSound(snd)
	if not (snd and snd:IsA("Sound")) then return false end
	local nm = snd.Name:lower()
	if nm:find("coin") or nm:find("collect") or nm:find("pickup") then return true end
	local current = snd.Parent
	local depth = 0
	while current and current ~= game and depth < 8 do
		if current.Name == "CoinContainer" or current.Name:lower():find("coin") then return true end
		current = current.Parent
		depth = depth + 1
	end
	return false
end

function muteCoinSound(snd)
	pcall(function()
		snd.Volume = 0
		snd.PlaybackSpeed = 0
		snd.Playing = false
		snd:Stop()
	end)
end

function muteAllCoinSounds()
	for _, root in ipairs({Workspace, game:GetService("SoundService")}) do
		for _, d in ipairs(root:GetDescendants()) do
			if d:IsA("Sound") and isCoinSound(d) then muteCoinSound(d) end
		end
	end
end

function enableAutoMuteCoins()

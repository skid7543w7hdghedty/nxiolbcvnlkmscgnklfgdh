			local width = isBoth and 200 or 150
			local height = isBoth and 64 or 46

			local popupBorder = Instance.new("Frame")
			popupBorder.Size = UDim2.new(0, width, 0, height)
			popupBorder.Position = UDim2.new(0.5, -297, 0.5, 79 - extractedCount * (height + 2))

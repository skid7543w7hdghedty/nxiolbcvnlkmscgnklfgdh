function applyGodmode(char)
	if not char then return end
	local hum = char:WaitForChild("Humanoid", 10)
	if not hum then return end
	-- Modern client-side anti-death: stop the humanoid from ever entering the Dead
	-- state and from breaking apart, then keep topping health back up every frame.
	pcall(function() hum.BreakJointsOnDeath = false end)
	pcall(function() hum.RequiresNeck = false end)
	pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end)
	hum.Health = hum.MaxHealth
	table.insert(secondLifeConnections, hum.HealthChanged:Connect(function(h)
		if secondLifeEnabled and h < hum.MaxHealth then
			hum.Health = hum.MaxHealth
		end
	end))
	table.insert(secondLifeConnections, hum.Died:Connect(function()
		if secondLifeEnabled then
			pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end)
			hum.Health = hum.MaxHealth
		end
	end))
	table.insert(secondLifeConnections, RunService.Heartbeat:Connect(function()
		if secondLifeEnabled and hum and hum.Parent and hum.Health < hum.MaxHealth then
			hum.Health = hum.MaxHealth
		end
	end))
end

function enableSecondLife()
	secondLifeEnabled = true
	cleanupSecondLife()
	if player.Character then
		applyGodmode(player.Character)
	end
	table.insert(secondLifeConnections, player.CharacterAdded:Connect(function(newChar)
		if secondLifeEnabled then
			applyGodmode(newChar)
		end
	end))
	for _, part in pairs(workspace:GetDescendants()) do
		if part:IsA("BasePart") then
			local name = part.Name:lower()
			if name:match("kill") or name:match("lava") or name:match("fire") or name:match("damage") or name:match("hurt") or name:match("death") or name:match("spike") then
				part.CanTouch = true
				part.CanQuery = false
			end
		end
	end
end

function disableSecondLife()
	secondLifeEnabled = false
	cleanupSecondLife()
	if player.Character then
		for _, part in pairs(player.Character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanTouch = true
				part.CanQuery = true
			end
		end
	end
end

function toggleSecondLife()
	if secondLifeEnabled then
		disableSecondLife()
	else
		enableSecondLife()
	end
end


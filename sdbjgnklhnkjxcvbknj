function createSkyboxPicker(opts)
	local parent = opts.parent
	local order = opts.order
	local state = { selectedName = nil }

	local statusLabel = Instance.new("TextLabel")
	statusLabel.Name = "SkyboxPickerStatus"
	statusLabel.Size = UDim2.new(1, 0, 0, 24)
	statusLabel.BackgroundTransparency = 1
	statusLabel.Text = "Select a saved skybox"
	statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	statusLabel.TextXAlignment = Enum.TextXAlignment.Left
	statusLabel.Font = Enum.Font.SourceSansBold
	statusLabel.TextSize = 15
	statusLabel.LayoutOrder = order
	statusLabel.Parent = parent
	state.statusLabel = statusLabel

	local pickerFrame = Instance.new("Frame")
	pickerFrame.Name = "SkyboxPickerFrame"
	pickerFrame.Size = UDim2.new(1, 0, 0, 160)
	pickerFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	pickerFrame.BorderSizePixel = 0
	pickerFrame.LayoutOrder = order + 0.006
	pickerFrame.Parent = parent
	local pc = Instance.new("UICorner"); pc.CornerRadius = UDim.new(0, 6); pc.Parent = pickerFrame

	local scrollFrame = Instance.new("ScrollingFrame")
	scrollFrame.Name = "SkyboxPickerScroll"
	scrollFrame.Position = UDim2.new(0, 8, 0, 8)
	scrollFrame.Size = UDim2.new(1, -16, 1, -16)
	scrollFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	scrollFrame.BorderSizePixel = 0
	scrollFrame.ScrollBarThickness = 4
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	scrollFrame.Parent = pickerFrame
	local scc = Instance.new("UICorner"); scc.CornerRadius = UDim.new(0, 6); scc.Parent = scrollFrame

	local function updateStatus()
		if state.selectedName then
			statusLabel.Text = "Skybox: " .. state.selectedName
			statusLabel.TextColor3 = Color3.fromRGB(80, 200, 255)
		else
			statusLabel.Text = "Select a saved skybox"
			statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end

	local function refresh()
		for _, child in ipairs(scrollFrame:GetChildren()) do
			if not child:IsA("UICorner") then child:Destroy() end
		end
		local names = {}
		for name in pairs(savedSkyboxes) do table.insert(names, name) end
		table.sort(names, function(a, b) return a:lower() < b:lower() end)
		local y = 0
		for _, name in ipairs(names) do
			local isSel = state.selectedName == name
			local entry = Instance.new("Frame")
			entry.Size = UDim2.new(1, -8, 0, 30)
			entry.Position = UDim2.new(0, 4, 0, y)
			entry.BackgroundColor3 = isSel and Color3.fromRGB(10, 30, 45) or Color3.fromRGB(0, 0, 0)
			entry.BorderSizePixel = 0
			entry.Parent = scrollFrame
			local ec = Instance.new("UICorner"); ec.CornerRadius = UDim.new(0, 6); ec.Parent = entry

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Size = UDim2.new(1, -70, 1, 0)
			nameLabel.Position = UDim2.new(0, 8, 0, 0)
			nameLabel.BackgroundTransparency = 1
			nameLabel.Text = name
			nameLabel.TextColor3 = isSel and Color3.fromRGB(120, 210, 255) or Color3.fromRGB(255, 255, 255)
			nameLabel.TextSize = 16
			nameLabel.Font = Enum.Font.SourceSansBold
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.Parent = entry

			local delBtn = Instance.new("TextButton")
			delBtn.Size = UDim2.new(0, 28, 0, 24)
			delBtn.Position = UDim2.new(1, -32, 0.5, -12)
			delBtn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
			delBtn.Text = "X"
			delBtn.TextColor3 = Color3.fromRGB(255, 120, 120)
			delBtn.Font = Enum.Font.SourceSansBold
			delBtn.TextSize = 14
			delBtn.Parent = entry
			local dc = Instance.new("UICorner"); dc.CornerRadius = UDim.new(0, 6); dc.Parent = delBtn
			local thisName = name
			delBtn.MouseButton1Click:Connect(function()
				savedSkyboxes[thisName] = nil
				if state.selectedName == thisName then state.selectedName = nil end
				skyboxSaveConfig()
				refresh()
				notify("Skybox", "Deleted: " .. thisName, 2)
			end)

			local clickArea = Instance.new("TextButton")
			clickArea.Size = UDim2.new(1, -36, 1, 0)
			clickArea.BackgroundTransparency = 1
			clickArea.Text = ""
			clickArea.Parent = entry
			clickArea.MouseButton1Click:Connect(function()
				if state.selectedName == thisName then
					state.selectedName = nil
				else
					state.selectedName = thisName
				end
				refresh()
			end)

			y = y + 36
		end
		scrollFrame.CanvasSize = UDim2.new(0, 0, 0, y)
		updateStatus()
	end
	state.refresh = refresh
	task.defer(refresh)
	return state
end

-- Save current face inputs as a named preset
do
	local saveBtn, nameBox = createSkyboxRow("SkyboxSave", "Save Skybox", "Preset name", "", 410)
	skyboxNameInput = nameBox
	saveBtn.MouseButton1Click:Connect(function()
		local nm = nameBox.Text
		if nm == nil or nm:gsub("%s", "") == "" then
			notify("Skybox", "Enter a preset name first", 2)
			return
		end
		-- Collect all face IDs from inputs
		local preset = {}
		local count = 0
		for _, face in ipairs(skyboxFaces) do
			local box = skyboxFaceInputs[face]
			if box and box.Text and box.Text ~= "" then
				local digits = tostring(box.Text):match("%d+")
				if digits then
					preset[face] = digits
					count = count + 1
				end
			end
		end
		if count == 0 then
			notify("Skybox", "Fill at least one face ID", 2)
			return
		end
		savedSkyboxes[nm] = preset
		skyboxSaveConfig()
		notify("Skybox", "Saved: " .. nm .. " (" .. count .. " faces)", 2)
		if skyboxPickerState and skyboxPickerState.refresh then
			skyboxPickerState.refresh()
		end
	end)
end


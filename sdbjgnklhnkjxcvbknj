-- Read the REAL coin count from the MM2 coin-bag GUI (the "12/40" label).
-- This is the exact number the server has accepted into the bag, so the
-- 40/50 end-of-farm reset fires at the true limit even if a local count
-- drifts (missed removal event, coin collected by walking over it, etc).
-- Returns nil when the label can't be found (fallback: local counter).
function autofarmGetBagCount()
	-- [perf] Throttled + label cached. This used to re-find the CoinBag GUI and
	-- scan ALL its descendants EVERY heartbeat — one of the mid-flight stutter
	-- sources. Now the "12/40" label is found once and only re-read every 0.25s.
	local now = os.clock()
	if (now - autofarmBagCountAt) < 0.25 then
		return autofarmBagCountCache
	end
	autofarmBagCountAt = now
	local ok, count = pcall(function()
		-- Fast path: re-read the cached label directly (no descendant scan at all)
		local lbl = autofarmBagLabelCache
		if lbl and lbl.Parent then
			local cur = tostring(lbl.Text):match("^%s*(%d+)%s*/%s*%d+%s*$")
			if cur then return tonumber(cur) end
		end
		-- Slow path (runs only until the label is found, then never again)
		autofarmBagLabelCache = nil
		local mainGui = playerGui:FindFirstChild("MainGUI")
		local gameGui = mainGui and mainGui:FindFirstChild("Game")
		local bags = gameGui and (gameGui:FindFirstChild("CoinBags") or gameGui:FindFirstChild("CoinBag", true))
		if not bags then return nil end
		for _, d in ipairs(bags:GetDescendants()) do
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				local cur = tostring(d.Text):match("^%s*(%d+)%s*/%s*%d+%s*$")
				if cur then
					autofarmBagLabelCache = d
					return tonumber(cur)
				end
			end
		end
		return nil
	end)
	if ok then autofarmBagCountCache = count end
	return autofarmBagCountCache
end

function autofarmFindCoinContainer()
	-- MM2 keeps coins in <MapModel>.CoinContainer during the round. The container
	-- is searched RECURSIVELY: on some maps/updates the map model is nested inside
	-- a folder (or the container sits deeper than one level).
	-- [perf] The recursive Workspace scan used to run EVERY heartbeat — scanning
	-- the entire map every frame was THE main cause of the small mid-flight
	-- freezes. The container is now cached; the expensive recursive scan only
	-- reruns when the cached one is gone (round/map change), at most every 0.5s.
	local cc = autofarmContainerCache
	if cc and cc.Parent then return cc end
	local now = os.clock()
	if (now - autofarmContainerCheckedAt) < 0.5 then return nil end
	autofarmContainerCheckedAt = now
	autofarmContainerCache = Workspace:FindFirstChild("CoinContainer", true)
	return autofarmContainerCache
end

function autofarmGetCoinPart(coin)
	if coin:IsA("BasePart") then return coin end
	local p = coin:FindFirstChild("Coin")
	if p and p:IsA("BasePart") then return p end
	return coin:FindFirstChildWhichIsA("BasePart")
end

-- The coin's hitbox BasePart is always transparent in current MM2 — the VISIBLE
-- spinning coin is a child visual/mesh. Cache that visible part once per coin so
-- we can detect "collected but not yet removed" coins cheaply every frame.
function autofarmGetCoinVisiblePart(coin)
	local cached = autofarmCoinVisiblePart[coin]
	if cached and cached.Parent then return cached end
	-- [perf] Hitbox-only coins never have a visible part, so this descendant scan
	-- used to rerun for them EVERY frame. Throttle rescans to every 0.5s per coin
	-- (visuals that stream in late are still picked up within half a second).
	local now = os.clock()
	local last = autofarmCoinVisCheckedAt[coin]
	if last and (now - last) < 0.5 then return nil end
	autofarmCoinVisCheckedAt[coin] = now
	for _, d in ipairs(coin:GetDescendants()) do
		if d:IsA("BasePart") and d.Transparency < 0.95 then
			autofarmCoinVisiblePart[coin] = d
			return d
		end
	end
	return nil
end

-- [perf] Cached list of the character's BaseParts. The flight loop used to call
-- char:GetDescendants() 2-3 times per frame (CanCollide loop + full-body touch
-- volley); now the list is rebuilt only when the character changes or every 1s.
function autofarmGetCharParts(char)
	local now = os.clock()
	if char ~= autofarmCharPartsChar or (now - autofarmCharPartsAt) > 1 then
		autofarmCharPartsChar = char
		autofarmCharPartsAt = now
		autofarmCharParts = {}
		for _, p in ipairs(char:GetDescendants()) do
			if p:IsA("BasePart") then
				table.insert(autofarmCharParts, p)
			end
		end
	end
	return autofarmCharParts
end

-- Is this coin already gone / already collected?
-- A collected coin sometimes STAYS in the container with its visual hidden —
-- that's exactly why the farm kept flying back to long-gone coins. So besides
-- Parent == nil we also treat a coin as gone when its previously-VISIBLE visual
-- part disappeared or turned invisible. Spent coins are permanently blacklisted.
function autofarmCoinIsGone(coin)
	if autofarmSpentCoins[coin] then return true end
	if coin.Parent == nil then return true end
	local part = autofarmGetCoinPart(coin)
	if not part then return true end
	local vis = autofarmCoinVisiblePart[coin]
	if vis then
		if not vis.Parent or vis.Transparency >= 0.95 then
			autofarmSpentCoins[coin] = true
			return true
		end
	else
		-- Cache the visible part the first time we see this coin (may legitimately
		-- be nil for hitbox-only coins — those are handled via removal instead)
		autofarmGetCoinVisiblePart(coin)
	end
	return false
end

-- Closest coin that isn't gone yet: keeps targeting the same coin every frame
-- until it disappears (no more 'touch once and move on' — that was why the farm
-- flew past coins without collecting them). Coins touched for > 3 s without
-- collection are blacklisted so we never get stuck on a bugged coin.
function autofarmNearestCoin(container, fromPos)
	local bestCoin, bestPart, bestDist = nil, nil, math.huge
	for _, coin in ipairs(container:GetChildren()) do
		if not autofarmCoinIsGone(coin) then
			local touchStart = autofarmTouchedAt[coin]
			if touchStart and (os.clock() - touchStart) > 3 then
				autofarmSpentCoins[coin] = true
			end
			-- Coins already inside the Coin Aura pull are not movement targets:
			-- the aura collects them while we fly straight on to the next coin.
			-- If the aura somehow fails, the coin becomes targetable again after 2s.
			local pendingAt = autofarmAuraPending[coin]
			if pendingAt and (os.clock() - pendingAt) >= 2 then
				autofarmAuraPending[coin] = nil
				pendingAt = nil
			end
			if not autofarmSpentCoins[coin] and not pendingAt then
				local part = autofarmGetCoinPart(coin)
				if part then
					local d = (part.Position - fromPos).Magnitude
					if d < bestDist then
						bestDist = d
						bestCoin = coin
						bestPart = part
					end
				end
			end
		end
	end
	return bestCoin, bestPart, bestDist
end

function autofarmWatchCoin(coin)
	if autofarmCoinWatched[coin] then return end
	autofarmCoinWatched[coin] = true
	coin.AncestryChanged:Connect(function(_, parent)
		if parent == nil and autofarmEnabled and autofarmCoinWatched[coin] then
			autofarmCoinWatched[coin] = nil
			autofarmSpentCoins[coin] = true
			-- Only count if WE touched this coin (not when another player collects
			-- a coin we just flew past). autofarmTouchedAt is set when the farm's
			-- HRP or body parts actually fireTouchInterest the coin.
			if autofarmTouchedAt[coin] and autofarmGetBagCount() == nil then
				autofarmCollected += 1
				autofarmSessionCoins += 1
			end
		end
	end)
end

-- [perf] autofarmClaimCoin is called EVERY frame while touching a coin; without
-- this guard each call scheduled a brand-new task.delay(1.2) closure (dozens of
-- pending tasks per coin = garbage-collector churn = micro-stutters).
autofarmClaimPending = {}
function autofarmClaimCoin(coin)
	-- Count the coin only when the server actually removes it (= really collected).
	-- The counting connection is attached ONCE per coin, even if the coin is
	-- unclaimed and retried later — so a coin can never be counted twice.
	autofarmWatchCoin(coin)
	-- Only ONE delayed verification per coin at a time; the flag clears when the
	-- check runs, so the retry logic keeps working exactly as before.
	if autofarmClaimPending[coin] then return end
	autofarmClaimPending[coin] = true
	-- Remember whether the coin's VISUAL part was visible at touch time: if it
	-- turns invisible afterwards the coin was collected (fallback count in case
	-- the removal event was missed). Hitbox-only coins count only via removal.
	local visAtClaim = autofarmGetCoinVisiblePart(coin)
	task.delay(1.2, function()
		autofarmClaimPending[coin] = nil
		local part = autofarmGetCoinPart(coin)
		local removed = (coin.Parent == nil) or (not part)
		local turnedInvisible = visAtClaim and (not visAtClaim.Parent or visAtClaim.Transparency >= 0.95)
		if removed or turnedInvisible then
			-- Collected: permanently blacklist so we never fly back to it.
			autofarmSpentCoins[coin] = true
			if autofarmCoinWatched[coin] then
				autofarmCoinWatched[coin] = nil
				-- Only count if WE touched this coin (not when another player's
				-- collection makes it invisible locally).
				if turnedInvisible and autofarmTouchedAt[coin] and autofarmEnabled then
					if autofarmGetBagCount() == nil then
						autofarmCollected += 1
						autofarmSessionCoins += 1
					end
				end
			end
		else
			-- Coin is STILL there after a moment — the touch failed (e.g. lag).
			-- Allow up to 3 retries, then permanently blacklist it.
			local tries = (autofarmCoinRetries[coin] or 0) + 1
			autofarmCoinRetries[coin] = tries
			if tries > 3 then
				autofarmSpentCoins[coin] = true
			end
		end
	end)
end


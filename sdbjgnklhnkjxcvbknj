	muteAllCoinSounds()
	for _, root in ipairs({Workspace, game:GetService("SoundService")}) do
		local conn = root.DescendantAdded:Connect(function(inst)
			if not autoMuteCoinsEnabled then return end
			if inst:IsA("Sound") and isCoinSound(inst) then
				muteCoinSound(inst)
				inst.Played:Connect(function()
					if autoMuteCoinsEnabled then muteCoinSound(inst) end
				end)
			end
		end)
		table.insert(autoMuteCoinsConnections, conn)
	end
	task.spawn(function()
		while autoMuteCoinsEnabled do
			muteAllCoinSounds()
			task.wait(2)
		end
	end)
end

function disableAutoMuteCoins()

touchFlingButton = createButton("TouchFlingButton", "Touch Fling: OFF", 210)
hiddenfling = false
flingThread = nil

function fling()
	local lp = Players.LocalPlayer
	local downVel = Vector3.new(0, -100000, 0)
	while hiddenfling do
		-- Heartbeat fires AFTER physics — velocity is replicated but doesn't
		-- move the character locally (physics already ran this frame).
		RunService.Heartbeat:Wait()
		local c = lp.Character
		local hrp = c and c:FindFirstChild("HumanoidRootPart")
		if hrp then
			local vel = hrp.Velocity
			-- Sanitize NaN (happens during Reset Player NaN fling)
			local vx, vy, vz = vel.X, vel.Y, vel.Z
			if vx ~= vx then vx = 0 end
			if vy ~= vy then vy = 0 end
			if vz ~= vz then vz = 0 end
			local cleanVel = Vector3.new(vx, vy, vz)
			-- Pure DOWNWARD velocity — no CFrame shift = no camera jitter
			hrp.Velocity = downVel
			hrp.AssemblyLinearVelocity = downVel
			-- Restore before render so the character stays in place visually
			RunService.RenderStepped:Wait()
			hrp.Velocity = cleanVel
			hrp.AssemblyLinearVelocity = cleanVel
			hrp.RotVelocity = Vector3.zero
			hrp.AssemblyAngularVelocity = Vector3.zero
		end
	end
end


	Hotel = true, Factory = true, BioLab = true, Mansion2 = true,
	House2 = true, Workplace = true, Hospital3 = true, MilBase = true,
	Bank2 = true, Office3 = true, ResearchFacility = true
}

function neutralizeCorpsePart(part)
    if not (part and part:IsA("BasePart")) then return end
    pcall(function()
        part.CanCollide = false
        part.CanTouch = false
        part.CanQuery = false
        part.Massless = true
        part.Anchored = false
    end)
end

function destroyCorpse(raggy)
    if not raggy or not raggy.Parent then return end

    -- Kill the hitbox FIRST so a thrown knife can't stick in the corpse.
    for _, part in ipairs(raggy:GetDescendants()) do
        neutralizeCorpsePart(part)
        if part:IsA("BasePart") then
            pcall(function()
                part.Transparency = 1
                part.Size = Vector3.new(0.01, 0.01, 0.01)
                part.CFrame = CFrame.new(0, -500, 0)
            end)
        end
    end

    -- Remove joints/constraints so nothing keeps a collidable shape.
    for _, joint in ipairs(raggy:GetDescendants()) do
        if joint:IsA("JointInstance") or joint:IsA("Constraint") or joint:IsA("Weld") or joint:IsA("Motor6D") or joint:IsA("BallSocketConstraint") then
            pcall(function() joint:Destroy() end)
        end
    end

    task.defer(function()
        if raggy and raggy.Parent then
            pcall(function() raggy:Destroy() end)
        end
    end)
end

function deleteCorpsesInModel(model)
    for _, desc in ipairs(model:GetDescendants()) do
        if desc.Name == "Raggy" then
            destroyCorpse(desc)
        end
    end
end

function enableAutoDeleteCorpses()
    autoDeleteCorpsesEnabled = true

    -- Delete every existing corpse anywhere (no map gating, so corpses outside the
    -- known maps no longer leave a stuck hitbox behind).
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "Raggy" then
            destroyCorpse(obj)
        end
    end

    -- Catch new corpses / corpse parts the instant they appear and neutralize the
    -- hitbox SYNCHRONOUSLY (before a thrown knife can collide), then delete.
    local descConn = Workspace.DescendantAdded:Connect(function(obj)
        if not autoDeleteCorpsesEnabled then return end
        if obj.Name == "Raggy" then
            for _, p in ipairs(obj:GetDescendants()) do
                neutralizeCorpsePart(p)
            end
            destroyCorpse(obj)
        elseif obj:IsA("BasePart") then
            local anc = obj.Parent
            local depth = 0
            while anc and anc ~= Workspace and depth < 6 do
                if anc.Name == "Raggy" then
                    neutralizeCorpsePart(obj)
                    pcall(function()
                        obj.Transparency = 1
                        obj.Size = Vector3.new(0.01, 0.01, 0.01)
                        obj.CFrame = CFrame.new(0, -500, 0)
                    end)
                    break
                end
                anc = anc.Parent
                depth = depth + 1
            end
        end
    end)
    table.insert(autoDeleteCorpsesConnections, descConn)

    -- [perf] Periodic sweep as a safety net only — DescendantAdded already catches
    -- every new corpse instantly. A full Workspace scan every 3s was too heavy on
    -- mobile; 10s is plenty for a fallback.
    task.spawn(function()
        while autoDeleteCorpsesEnabled do
            task.wait(10)
            if autoDeleteCorpsesEnabled then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj.Name == "Raggy" then
                        destroyCorpse(obj)
                    end
                end
            end
        end
    end)
end

function disableAutoDeleteCorpses()
	autoDeleteCorpsesEnabled = false
	for _, conn in ipairs(autoDeleteCorpsesConnections) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	autoDeleteCorpsesConnections = {}
end

function toggleAutoDeleteCorpses()
	if autoDeleteCorpsesEnabled then
		disableAutoDeleteCorpses()
	else
		enableAutoDeleteCorpses()
	end
end

